# ─────────────────────────────────────────────────────────────
# alt_support_bounce_v1 (BOUNCE1) — Support bounce longs canary
# WF-22 verdict: 🟢 VIABLE  AvgPF=1.421, PF>1.0: 14/22 (64%)
# Validated: 2026-04-16  Risk multiplier: 0.40× (canary entry)
#
# STRATEGY: Buy at key support levels when price bounces with
# a bullish confirmation candle after touching 1h support zone.
#
# KEY DESIGN:
#   4h regime check: EMA20/EMA50 gap small (flat) OR EMA20 > EMA50 (uptrend)
#   1h signal: price touches 72-bar low support, then bounces with bullish bar
#   RSI(14) on 1h <= 42 (oversold area — looking for dips not chasing)
#   Bullish confirmation: close > open, body >= 22% of range
#   Close within 1.4% below 20-period EMA (not too extended)
#
# PORTFOLIO ROLE (LONGS complement to HZBO1/ASB1/Elder shorts):
#   ATT1:   trendline BOUNCE (sloped, both directions) — PF=1.35
#   Elder:  MACD momentum shorts (trend following)    — PF=1.127
#   ASB1:   trendline BREAKDOWN (sloped, shorts-only) — PF=1.228
#   HZBO1:  zone BREAKDOWN (horizontal, shorts-only)  — PF=1.647
#   BOUNCE1: support BOUNCE (horizontal zones, longs)  — PF=1.421
#
# WHEN IT WORKS: bull trends and range markets (buys dips)
# WHEN IT WEAK:  strong bear trends (Oct-Nov 2025 BTC dump windows)
# WEAK windows: Aug-04 (0.533), Oct-18 (0.268), Nov-02 (0.395), Nov-17 (0.150)
# STRONG windows: May-21 (2.670), Jan-01 (2.935), Jan-31 (2.952), Mar-02 (2.560)
#
# Enable longs automatically — this is a pure long strategy.
# Disable manually if BTC is in confirmed bear trend.
# ─────────────────────────────────────────────────────────────

ENABLE_BOUNCE1_TRADING=1
BOUNCE1_RISK_MULT=0.40

# Wait for Codex to wire BOUNCE1 into smart_pump_reversal_bot.py
# This config documents the validated parameters for deployment.

# Symbols
ASB1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT

# ── Signal timeframe ─────────────────────────────────────────
# Defaults in alt_support_bounce_v1.py are suitable for these symbols.
# 1h signal bars, 4h regime check.

