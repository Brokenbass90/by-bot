ALPACA_API_KEY_ID=replace_me
ALPACA_API_SECRET_KEY=replace_me
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Dry-run by default. Set to 1 only after paper checks look clean.
ALPACA_SEND_ORDERS=0
ALPACA_CLOSE_STALE_POSITIONS=0

# Order sizing controls
ALPACA_MAX_POSITIONS=2
ALPACA_TARGET_ALLOC_PCT=0.45
ALPACA_MIN_DOLLAR_ORDER=50
ALPACA_MAX_PICK_AGE_DAYS=45
ALPACA_ALLOW_STALE_PICKS=0
# Autopilot wrapper can refresh picks first and ignore the pinned path below.
# Leave at 1 for the monthly auto-refresh -> rebalance cycle.
# ALPACA_AUTOPILOT_REFRESH=1
# Optional cap for sizing when account buying power is much larger than the sleeve capital.
# Example: set 500 for a small pilot sleeve even if Alpaca paper account shows 100k+.
# ALPACA_CAPITAL_OVERRIDE_USD=500

# Optional monthly pick source overrides
# Pin a stable baseline so latest experiments do not silently change the sleeve.
# When using scripts/run_equities_alpaca_monthly_autopilot.sh this becomes only a fallback.
# ALPACA_PICKS_CSV=backtest_runs/equities_monthly_research_20260310_135450_growth5_softcorr300_t055_invvol/picks.csv
# ALPACA_PICKS_MONTH=2026-03

# Optional DeepSeek advisor for daily/monthly Alpaca reports.
# Uses the shared DEEPSEEK_* settings if present in your local/server env.
ALPACA_DEEPSEEK_NOTE_ENABLE=1
ALPACA_DEEPSEEK_NOTE_MAX_CHARS=420
