## ═══════════════════════════════════════════════════════════════════════
## LIVE CANDIDATE — CORE-2 PACK
## Engine: alt_inplay_breakdown_v1 (motor) + alt_resistance_fade_v1 (stabilizer)
## Created: 2026-04-04  |  Regime: bear_chop (current)
##
## Backtest basis:
##   90d  +19.05%  PF 2.691  WR 61.8%  DD 4.43%   55 trades
##   180d +27.23%  PF 1.748  WR 53.4%  DD 10.32%  148 trades
##
## ARF1 density pocket:  +8.77%  PF 4.156  WR 68.8%  (current 90d)
## breakdown recent 180d: +22.20% PF 1.801  WR 51.8%
##
## Risk staging plan:
##   Week 1-2: ORCH_GLOBAL_RISK_MULT=0.50 → ~0.40-0.50% effective per trade
##   Week 3+:  lift to 0.70 after live data confirms edge
##   Month 2:  consider BREAKDOWN_RISK_MULT=1.0 if live WR ≥ 48%
## ═══════════════════════════════════════════════════════════════════════

## ── STRATEGY ON/OFF ────────────────────────────────────────────────────
## Motor: breakdown_v1
ENABLE_BREAKDOWN_TRADING=1
## Stabilizer: resistance_fade
ENABLE_FLAT_TRADING=1
## Everything else: OFF — not ready for core, repair separately
ENABLE_BREAKOUT_TRADING=0
ENABLE_SLOPED_TRADING=0
ENABLE_MIDTERM_TRADING=0
ENABLE_PUMP_FADE_TRADING=0
ENABLE_BOUNCE_TRADING=0
ENABLE_RANGE_TRADING=0

## ── RISK ENGINE ─────────────────────────────────────────────────────────
## Base risk (from account JSON or env override):
RISK_PER_TRADE_PCT=1.0
## Leverage: keep at 3x — provides enough room for 1.8 ATR stops
BYBIT_LEVERAGE=3

## Per-strategy risk multipliers:
## breakdown: 0.80x conservative start → effective = 1% × 0.80 × GLOBAL
BREAKDOWN_RISK_MULT=0.80
BREAKDOWN_MAX_OPEN_TRADES=1
## ARF1: highest WR (77.8%), proven → full 1.0x
FLAT_RISK_MULT=1.0
FLAT_MAX_OPEN_TRADES=1

## Global risk reduction for bear_chop regime:
## Week 1-2: use 0.50.  Week 3+: lift to 0.70 when live results confirmed.
## Effective risks:  breakdown = 1% × 0.80 × 0.50 = 0.40%/trade
##                  ARF1      = 1% × 1.00 × 0.50 = 0.50%/trade
ORCH_GLOBAL_RISK_MULT=0.50

## Max concurrent open positions across ALL strategies:
## 2 = 1 breakdown + 1 ARF1 running simultaneously is fine.
## Set via Telegram: /set max_positions 2
## Or in trade JSON config: "max_positions": 2

## ── EXECUTION SAFETY ────────────────────────────────────────────────────
## TP/SL hard failsafe: if exchange rejected TP/SL and no protection for
## GRACE_SEC, force-close the position with reduceOnly market order.
TPSL_HARD_FAIL_CLOSE=1
TPSL_HARD_FAIL_GRACE_SEC=15
## Structured live event stream for operator / AI / forensic review
LIVE_TRADE_EVENTS_JSONL=runtime/live_trade_events.jsonl
## Kline freshness guard: reject stale data
KLINE_STALE_GRACE_SEC=90
KLINE_STALE_MAX_BARS=2.5

## ── BREAKDOWN V1 — MOTOR ─────────────────────────────────────────────
## Symbols: top 5 liquid large-caps with reliable 1h structure
BREAKDOWN_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT
BREAKDOWN_ALLOW_SHORTS=1
## Both entry families on: failed_reclaim + continuation
BREAKDOWN_ALLOW_FAILED_RECLAIM=1
BREAKDOWN_ALLOW_CONTINUATION=1
## Regime filter: EMA21/55 on 4H — only trade when price < EMA21 < EMA55
## Keeps us out of false breakdowns in temporary dips during bull legs.
BREAKDOWN_REGIME_MODE=ema
## Structure: 48h lookback for support level detection
BREAKDOWN_LOOKBACK_H=48
## Entry filters:
BREAKDOWN_RSI_MAX=55
BREAKDOWN_BUFFER_ATR=0.10
BREAKDOWN_MIN_BREAK_ATR=0.20
BREAKDOWN_IMPULSE_BODY_MIN_FRAC=0.35
BREAKDOWN_MAX_DIST_ATR=2.0
## Trade management:
BREAKDOWN_SL_ATR=1.8
BREAKDOWN_RR=2.0
BREAKDOWN_TP1_FRAC=0.50
BREAKDOWN_MAX_RETEST_BARS=30
BREAKDOWN_TIME_STOP_BARS_5M=288
BREAKDOWN_COOLDOWN_BARS_5M=48
## Sleeve breaker: cut or block breakdown if recent live closes go bad
BREAKDOWN_BREAKER_ENABLE=1
BREAKDOWN_BREAKER_LOOKBACK_DAYS=30
BREAKDOWN_BREAKER_MIN_TRADES=6
BREAKDOWN_BREAKER_SOFT_NET_PNL=-2.0
BREAKDOWN_BREAKER_SOFT_MULT=0.50
BREAKDOWN_BREAKER_HARD_NET_PNL=-4.5

## ── RESISTANCE FADE V1 — STABILIZER ──────────────────────────────────
## New defaults already in code: lookback=48, min_range=4.5%, cooldown=48.
## Only explicit overrides from the proven bear_chop pocket here.
ARF1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,LTCUSDT,DOTUSDT,SUIUSDT
ARF1_MIN_RSI=58.0
ARF1_SL_ATR_MULT=0.85
ARF1_TP1_FRAC=0.60
ARF1_TP2_BUFFER_PCT=0.45
ARF1_TRAIL_ATR_MULT=0.0
ARF1_TIME_STOP_BARS_5M=576
ARF1_REJECT_BELOW_RES_ATR=0.12
ARF1_MAX_CLOSE_VS_EMA_PCT=1.2

## ── DEPLOY NOTES ────────────────────────────────────────────────────────
## 1. Load order on server:
##      EnvironmentFile=/path/to/server.env          (API keys, base config)
##      EnvironmentFile=/path/to/this_file.env       (strategy + risk overlay)
##    The last file wins on conflicts — strategy params here override base.
##
## 2. Before start:
##    - Confirm orchestrator_state.json shows regime=bear_chop.
##    - Set max_positions=2 in trade JSON or send /set max_positions 2 after start.
##    - Verify no open positions from previous run.
##
## 3. First 48 hours: monitor manually.
##    Accept:  trades firing within 30 min of signal, SL/TP confirmed on exchange.
##    Escalate: TPSL failsafe triggers, consecutive losses > 3, DD > 3%.
##
## 4. Upgrade path:
##    After 2 weeks, if live WR ≥ 45% and PF ≥ 1.4:
##      ORCH_GLOBAL_RISK_MULT=0.70
##      BREAKDOWN_RISK_MULT=1.0
