BREAKOUT_MAX_CHASE_PCT=0.11
BREAKOUT_MAX_DIST_ATR=1.4
BREAKOUT_RECLAIM_ATR=0.12
BREAKOUT_ALLOW_SHORTS=1

BREAKDOWN_RR=2.0
BREAKDOWN_SL_ATR=1.8
BREAKDOWN_MAX_DIST_ATR=2.0

MTPB_ALLOW_LONGS=1
MTPB_ALLOW_SHORTS=1
MTPB_TREND_MIN_GAP_PCT=0.20
MTPB_TREND_SLOPE_MIN_PCT=0.50
MTPB_LONG_RECLAIM_PCT=0.24
MTPB_SHORT_RECLAIM_PCT=0.24
MTPB_LONG_TOUCH_TOL_PCT=0.16
MTPB_SHORT_TOUCH_TOL_PCT=0.16
MTPB_RR=2.3
MTPB_COOLDOWN_BARS_5M=108
MTPB_TIME_STOP_BARS_5M=72
MTPB_LONG_MAX_PULLBACK_PCT=0.80
MTPB_SHORT_MAX_PULLBACK_PCT=0.80
MTPB_LONG_MAX_ATR_PCT_1H=1.80
MTPB_SHORT_MAX_ATR_PCT_1H=2.00
MTPB_TP1_RR=1.2
MTPB_TP2_RR=2.8
MTPB_TP1_FRAC=0.50
MTPB_USE_RUNNER_EXITS=0
MTPB_TRAIL_ATR_MULT=1.1
