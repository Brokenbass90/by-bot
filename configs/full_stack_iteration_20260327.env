## Full-stack annual backtest snapshot for the current crypto iteration.
## Purpose:
## - reproducible yearly portfolio run
## - mirrors the current live core plus the new midterm v3 candidate
## - keeps quiet-market sleeves on the currently proven symbol pockets

ENABLE_BREAKOUT_TRADING=1
ENABLE_MIDTERM_TRADING=1
ENABLE_SLOPED_TRADING=1
ENABLE_FLAT_TRADING=1
ENABLE_BREAKDOWN_TRADING=1

ASC1_SYMBOL_ALLOWLIST=ATOMUSDT,LINKUSDT,DOTUSDT
