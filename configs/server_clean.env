# ----------------------------------------------------------------
# SLOPED CHANNEL (ASC1) — ATOM + LINK + DOT shorts (expanded 2026-03-26)
# Backtest ATOM+LINK: 15 trades/year, WR 80%, PF 8.94, DD 0.88%
# Backtest ATOM+LINK+DOT (asc1_expansion_v1 best): net=+19.41%, PF=2.683, WR=52.8%, DD=1.91%
# Decision: added DOT — same DD envelope, better PF vs bare ATOM+LINK
# ----------------------------------------------------------------
ASC1_SYMBOL_ALLOWLIST=ATOMUSDT,LINKUSDT,DOTUSDT
ASC1_ALLOW_SHORTS=1
ASC1_ALLOW_LONGS=0

# Quality filters (verified on backtest — DO NOT RELAX)
ASC1_SHORT_MIN_REJECT_DEPTH_ATR=0.75
ASC1_SHORT_MAX_NEAR_UPPER_BARS=2
ASC1_SHORT_MIN_RSI=60
ASC1_SHORT_NEAR_UPPER_ATR=0.15

# 5m entry confirmation (wait up to 6 bars for confirming candle)
ASC1_CONFIRM_5M_BARS=6

# Position sizing
SLOPED_RISK_MULT=0.10
SLOPED_MAX_OPEN_TRADES=1
SLOPED_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# FLAT RESISTANCE FADE (ARF1) — 6 COINS (expanded 2026-03-25)
# Backtest 4 coins: trades=59 net=28.60% PF=3.635 WR=54.2% DD=1.62%
# Backtest 6 coins: trades=78 net=37.48% PF=3.495 WR=52.6% DD=1.59% neg_months=0
# Decision: expanded to 6 coins (+ADA+BCH), same DD, +9% net, 0 red months
# ----------------------------------------------------------------
ARF1_SYMBOL_ALLOWLIST=LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT,ADAUSDT,BCHUSDT

# Position sizing
FLAT_RISK_MULT=0.10
FLAT_MAX_OPEN_TRADES=1
FLAT_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# INPLAY BREAKOUT — top 10 coins, optimised by autoresearch v2_focus
# Backtest: 550 trades/year, WR 70%, PF 1.40, +26% — main volume strategy
# Settings: breakout_live_bridge_v2_focus best candidate (2026-03-21)
# ----------------------------------------------------------------
BREAKOUT_TOP_N=10
BREAKOUT_TRY_EVERY_SEC=30
BREAKOUT_ALLOW_SHORTS=0

# Quality filter (autoresearch-tuned — do not change without re-running research)
# 0.48 = confirmed best by full_stack_v2 autoresearch r003 (2026-03-23)
# NOTE: BT_ prefix is used by backtest engine; BREAKOUT_ prefix is used by live bot
BT_BREAKOUT_QUALITY_ENABLE=1
BT_BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_QUALITY_MIN_SCORE=0.48

# Entry filters
BREAKOUT_BUFFER_ATR=0.12
BREAKOUT_IMPULSE_ATR_MULT=1.0
BREAKOUT_MAX_CHASE_PCT=0.11
BREAKOUT_MAX_DIST_ATR=1.4
BREAKOUT_MAX_LATE_VS_REF_PCT=0.35
BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT=0.06
BREAKOUT_RECLAIM_ATR=0.12

