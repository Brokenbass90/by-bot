# ----------------------------------------------------------------
# CORE TRADING SETTINGS
# ----------------------------------------------------------------
DRY_RUN=false
BYBIT_LEVERAGE=3
RISK_PER_TRADE_PCT=1.0

# ----------------------------------------------------------------
# STRATEGY ON/OFF  (only sloped + flat enabled)
# ----------------------------------------------------------------
ENABLE_SLOPED_TRADING=1
ENABLE_FLAT_TRADING=1

ENABLE_BREAKOUT_TRADING=0
ENABLE_INPLAY_TRADING=0
ENABLE_RETEST_TRADING=0
ENABLE_RANGE_TRADING=0
ENABLE_PUMP_FADE_TRADING=0
ENABLE_MIDTERM_TRADING=0
ENABLE_TS132_TRADING=0

# ----------------------------------------------------------------
# SLOPED CHANNEL (ASC1) — ATOM + LINK shorts
# Backtest: 15 trades/year, WR 80%, PF 8.94, 0 red months, DD 0.88%
# ----------------------------------------------------------------
ASC1_SYMBOL_ALLOWLIST=ATOMUSDT,LINKUSDT
ASC1_ALLOW_SHORTS=1
ASC1_ALLOW_LONGS=0

# Quality filters (verified on backtest — DO NOT RELAX)
ASC1_SHORT_MIN_REJECT_DEPTH_ATR=0.75
ASC1_SHORT_MAX_NEAR_UPPER_BARS=2
ASC1_SHORT_MIN_RSI=60
ASC1_SHORT_NEAR_UPPER_ATR=0.15

# 5m entry confirmation (wait up to 6 bars for confirming candle)
ASC1_CONFIRM_5M_BARS=6

# Position sizing
SLOPED_RISK_MULT=0.10
SLOPED_MAX_OPEN_TRADES=1
SLOPED_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# FLAT RESISTANCE FADE (ARF1) — LINK + LTC + SUI + DOT
# Backtest: ~17 trades/year, WR ~59%, PF ~2.5
# ----------------------------------------------------------------
ARF1_SYMBOL_ALLOWLIST=LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT

# Position sizing
FLAT_RISK_MULT=0.10
FLAT_MAX_OPEN_TRADES=1
FLAT_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# DIAGNOSTICS & MISC
# ----------------------------------------------------------------
STRATEGY_STATS_TG_EVERY_SEC=86400
KILLER_GUARD_LOG_EVERY_SEC=3600
BOUNCE_DEBUG=0
BOUNCE_TG_LOGS=0
