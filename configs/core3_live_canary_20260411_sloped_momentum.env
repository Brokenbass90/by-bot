## Core-3 live promotion candidate as of 2026-04-11 — WITH ATT1 + ASM1 SLOPED STRATEGIES.
## Goal: add ATT1 (PF=1.26, 336 trades/yr) and ASM1 (PF=1.53, 171 trades/yr) to core config.
## IMPORTANT: Requires CODEX_TASK_att1_asm1_live_integration.md to be completed first
##            (smart_pump_reversal_bot.py must have ENABLE_ATT1_TRADING and ENABLE_ASM1_TRADING).
##
## Based on bear_chop_plus_range_probe_v1 strongest rows:
## - best row r109: +25.39%, PF 1.945, DD 3.53%, 124 trades, 3 red months
## - cluster confirmation r125-r128: +25.27%, PF 1.92, DD 4.08%, 127 trades

ENABLE_BREAKDOWN_TRADING=1
ENABLE_FLAT_TRADING=1
ENABLE_BREAKOUT_TRADING=0
ENABLE_SLOPED_TRADING=0
ENABLE_MIDTERM_TRADING=0
ENABLE_PUMP_FADE_TRADING=0
ENABLE_BOUNCE_TRADING=0
ENABLE_RANGE_TRADING=1
ENABLE_IVB1_TRADING=1
ENABLE_ELDER_TRADING=0

RISK_PER_TRADE_PCT=1.0
BYBIT_LEVERAGE=3
ORCH_GLOBAL_RISK_MULT=0.50
TPSL_HARD_FAIL_CLOSE=1
TPSL_HARD_FAIL_GRACE_SEC=15
MIN_NOTIONAL_USD=5.0

BREAKDOWN_RISK_MULT=0.80
BREAKDOWN_MAX_OPEN_TRADES=1
# Expanded to 5 symbols — validated by bear_chop_plus_range_probe_v1 (PF=1.90)
BREAKDOWN_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,LTCUSDT
BREAKDOWN_ALLOW_SHORTS=1
BREAKDOWN_ALLOW_FAILED_RECLAIM=1
BREAKDOWN_ALLOW_CONTINUATION=0
BREAKDOWN_TF_BREAK=60
BREAKDOWN_TF_ENTRY=5
BREAKDOWN_LOOKBACK_H=60
BREAKDOWN_RSI_MAX=60
BREAKDOWN_BUFFER_ATR=0.10
# Raised from 0.25 → higher quality breaks only (bear_chop_plus_range_probe best)
BREAKDOWN_MIN_BREAK_ATR=0.45
BREAKDOWN_IMPULSE_BODY_MIN_FRAC=0.35
BREAKDOWN_RETEST_TOUCH_ATR=0.35
BREAKDOWN_RECLAIM_ATR=0.12
BREAKDOWN_ENTRY_BODY_MIN_FRAC=0.18
BREAKDOWN_MAX_DIST_ATR=2.0
BREAKDOWN_SL_ATR=1.8
BREAKDOWN_RR=2.4
BREAKDOWN_TP1_FRAC=0.50
BREAKDOWN_TIME_STOP_BARS_5M=288
BREAKDOWN_COOLDOWN_BARS_5M=48
BREAKDOWN_REGIME_MODE=off
BREAKDOWN_FRESH_BREAK_BARS_5M=12
BREAKDOWN_FLAT_FILTER_BARS_5M=6
# Raised from 1.2 → 1.3 (allows slightly wider flat zones)
BREAKDOWN_FLAT_FILTER_MAX_RANGE_ATR=1.3
BREAKDOWN_FLAT_FILTER_LEVEL_BAND_ATR=0.4

FLAT_RISK_MULT=1.0
FLAT_MAX_OPEN_TRADES=1
# ARF1: alts-only universe — bear_chop_plus_range_probe_v1 best: PF=1.90 with 4 alts
# BTC/ETH removed from ARF1: their flat ranges are too efficient, fade signals weaker
# SOL removed: underperforms vs LINK/LTC/SUI/DOT in this regime
ARF1_SYMBOL_ALLOWLIST=LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT
# RSI gate tightened: 54 → 58 (only trade stronger pushes into resistance)
ARF1_MIN_RSI=58
ARF1_REJECT_BELOW_RES_ATR=0.10
ARF1_MAX_CLOSE_VS_EMA_PCT=1.1
ARF1_SIGNAL_TF=60
ARF1_SIGNAL_LOOKBACK=60

IVB1_RISK_MULT=1.0
IVB1_MAX_OPEN_TRADES=2
IVB1_MIN_VOL_MULT=1.3
IVB1_BREAKOUT_BUFFER_ATR=0.0
IVB1_RETRACE_MIN_FRAC=0.10
IVB1_RETRACE_MAX_FRAC=0.35
IVB1_SL_ATR=0.8
IVB1_RR=1.4
IVB1_REGIME_MODE=off
# IVB1 kept in the candidate so full dynamic validations still see the live-style stack.
IVB1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT

# Range scalp (ARS1) — ENABLED. Validated by bear_chop_plus_range_probe_v1.
# Trades BTC/ETH in tight BB ranges. Adds frequency in low-volatility periods.
ARS1_RISK_MULT=0.80
RANGE_RISK_MULT=0.80
ARS1_MAX_OPEN_TRADES=1
ARS1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT
# Only enter when band is wide enough to be worth fading (>3% width)
ARS1_MIN_BAND_WIDTH_PCT=3.0
ARS1_MAX_BAND_WIDTH_PCT=20.0
# RSI thresholds validated: long <38, short >65
ARS1_RSI_LONG_MAX=38
ARS1_RSI_SHORT_MIN=65
ARS1_ALLOW_LONGS=1
ARS1_ALLOW_SHORTS=1
ARS1_REGIME_MODE=off

# ============================================================
# Elder v2 — SHORTS-ONLY canary (NEW 2026-04-15)
# WF-22 verdict: 🟢 VIABLE  AvgPF=1.127, PF>1.0: 13/22 (59%)
# Key filter: ETS2_TREND_REQUIRE_HIST_SIGN=1 blocks shorts in bull markets
#             (4h MACD hist must be < 0 to allow shorts = confirmed downtrend)
# Longs DISABLED: backtest shows longs losing in current macro downtrend.
# Re-enable longs when BTC makes new ATH above Dec 2025 peak ($108k).
# Full config: configs/elder_v2_shorts_canary.env
# ============================================================
ENABLE_ELDER_V2_TRADING=1
ELDER_V2_RISK_MULT=0.60
ETS2_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT
ETS2_TREND_REQUIRE_HIST_SIGN=1
ETS2_TREND_CONSEC_BARS=1
ETS2_TREND_EMA_GATE=0
ETS2_ALLOW_LONGS=0
ETS2_ALLOW_SHORTS=1
ETS2_SL_ATR_MULT=1.5
ETS2_TP1_ATR_MULT=2.0
ETS2_TP_ATR_MULT=3.5
ETS2_ENTRY_MIN_BODY_FRAC=0.30
ETS2_COOLDOWN_BARS_5M=36
ETS2_ENTRY_RETEST_BARS=3

# ============================================================
# ATT1 — swing-pivot trendline bounce (NEW)
# REQUIRES: CODEX_TASK_att1_asm1_live_integration.md completed
# Backtest: PF=1.263, 336 trades/yr, DD=6.4% (360-day window)
# WF-22: AvgPF=1.35, PF≥1.0: 55%, PF≥1.15: 45% — VIABLE. Recent 9 windows all PF>1.0.
# Decision: 🟢 Deploy at 0.70x risk (regime-dependent — weak May-Oct, strong Nov-Apr)
# ============================================================
ENABLE_ATT1_TRADING=1
ATT1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,LTCUSDT,ADAUSDT,DOTUSDT,SUIUSDT
ATT1_RISK_MULT=0.70
ATT1_MAX_OPEN_TRADES=2
ATT1_PIVOT_LEFT=2
ATT1_PIVOT_RIGHT=2
ATT1_MIN_PIVOTS=2
ATT1_MAX_PIVOT_AGE=12
ATT1_MIN_R2=0.80
ATT1_TOUCH_ATR=0.25
ATT1_RSI_LONG_MAX=52
ATT1_RSI_SHORT_MIN=40

# ============================================================
# ASM1 — sloped channel breakout momentum
# Backtest: PF=1.531, 171 trades/yr — looked strong in isolation
# WF-22: 0 trades in 10/22 windows (goes silent in sideways); PF 0.44-0.70 Jan-Feb 2026
# Decision: ❌ DISABLED pending recovery — re-enable when 3+ consecutive WF windows PF>1.2
# ============================================================
ENABLE_ASM1_TRADING=0
ASM1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,LTCUSDT,ADAUSDT,DOTUSDT,SUIUSDT,XRPUSDT
ASM1_RISK_MULT=0.0
ASM1_MAX_OPEN_TRADES=2
ASM1_MIN_R2=0.25
ASM1_BREAKOUT_EXT_ATR=0.15
ASM1_MIN_BODY_FRAC=0.35
ASM1_VOL_MULT=2.0
ASM1_MIN_SLOPE_PCT=0.10
ASM1_USE_TREND_FILTER=0
