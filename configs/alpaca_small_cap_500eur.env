# ─────────────────────────────────────────────────────────────
# Alpaca intraday — конфиг для малого капитала €500 (~$550)
# Логика: fractional shares + tight risk + max 2 позиции
# ─────────────────────────────────────────────────────────────

# Фиксированный notional на позицию: 15% от $550 = ~$82
INTRADAY_NOTIONAL_USD=80

# Максимум 2 одновременных позиции (80 × 2 = $160 = 29% капитала)
INTRADAY_MAX_POSITIONS=2

# Дневной стоп-лосс: 2% от $550 = $11
INTRADAY_MAX_DAILY_LOSS_PCT=2.0

# SPY gate включён — не торгуем против рынка
INTRADAY_SPY_GATE=1
INTRADAY_SPY_SMA_PERIOD=50

# Equity curve gate включён (защита от просадки)
INTRADAY_EQUITY_CURVE_GATE=1
INTRADAY_EQUITY_CURVE_DAYS=10

# Акции с ценой подходящей для $80 notional (fractional shares)
# Топовые ликвидные тикеры где $80 = реальная позиция
INTRADAY_SYMBOLS=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,AMD

# Стратегии: только проверенные из walk-forward
INTRADAY_BREAKOUT_SYMBOLS=NVDA,AMD,TSLA
INTRADAY_REVERSION_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,META

# Fractional shares включить (нужно проверить поддержку в bridge)
ALPACA_FRACTIONAL_SHARES=1

# Динамический watchlist отключить — малый капитал = постоянный список
INTRADAY_DYNAMIC_BUILD=0

# ─────────────────────────────────────────────────────────────
# ОЖИДАЕМЫЕ РЕЗУЛЬТАТЫ при $550:
#   Сделок: 5-10 в неделю (2-3 breakout + 3-5 reversion)
#   Средняя прибыль на сделку при PF=1.4: ~$0.70-1.20
#   Цель: 1.5-3% в месяц = $8-17
#   Макс просадка: 6-10% = $33-55
#   Срок до удвоения: 24-48 месяцев (реалистично)
# ─────────────────────────────────────────────────────────────
