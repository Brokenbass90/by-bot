# claude_analyst.env — Claude Monthly Analyst configuration
# Copy to: configs/claude_analyst.env
# DO NOT commit the real file (it contains API keys).
# configs/claude_analyst.env is in .gitignore.
#
# Usage:
#   cp configs/claude_analyst.env.template configs/claude_analyst.env
#   nano configs/claude_analyst.env   # fill in real values
#   python3 scripts/claude_monthly_analyst.py --report

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Model selection ───────────────────────────────────────────────────────────
# claude-sonnet-4-6  → best quality/cost ratio (~$5-10/month at typical usage)
# claude-opus-4-6    → deepest analysis, use for architecture reviews (~$30-50/month)
# claude-haiku-4-5   → cheapest, use only for simple status checks
CLAUDE_MODEL=claude-sonnet-4-6

# ── Cost guard (abort if estimated cost exceeds this USD amount per run) ──────
CLAUDE_MONTHLY_BUDGET_USD=15.0

# ── Telegram (optional — for sending monthly report to chat) ─────────────────
# Leave empty to print to stdout only
TG_TOKEN=
TG_CHAT_ID=

# ── Output ────────────────────────────────────────────────────────────────────
# Directory where monthly reports are saved as .md files
CLAUDE_REPORTS_DIR=docs/monthly_reports
