## Regime overlay: bear_chop (updated 2026-04-04)
## Apply when orchestrator_state.json shows regime=bear_chop
## Activates: fade(PRIMARY), sloped shorts(ON), midterm(REDUCED), range_scalp(ON)
## Deactivates: breakout(OFF), breakdown(OFF until retune), support_bounce(OFF)

## === BREAKOUT (OFF in bear chop) ===
ENABLE_BREAKOUT_TRADING=0

## === BREAKDOWN (OFF until retune — currently losing money) ===
ENABLE_BREAKDOWN_TRADING=0

## === RESISTANCE FADE — PRIMARY (proven in chop, 13% annual) ===
## New defaults already tighter: lookback=48, min_range=4.5%, cooldown=48 bars
ENABLE_FLAT_TRADING=1
ARF1_SYMBOL_ALLOWLIST=ADAUSDT,SUIUSDT,LINKUSDT,DOTUSDT,LTCUSDT
ARF1_MIN_RSI=58.0
ARF1_SL_ATR_MULT=0.85
ARF1_TIME_STOP_BARS_5M=576

## === SUPPORT BOUNCE — OFF (don't buy dips in downtrend) ===
ENABLE_BOUNCE_TRADING=0

## === MIDTERM — REDUCED (BTC/ETH only, smaller risk mult) ===
ENABLE_MIDTERM_TRADING=1
MIDTERM_SYMBOLS=BTCUSDT,ETHUSDT

## === SLOPED CHANNEL — SHORTS ONLY ===
## Longs: completely off in bear_chop
## Shorts: require cleaner channel (R2≥0.50), short_max_pos_slope=0.0 → flat/falling only,
##         6-bar 5m confirmation, strict rejection depth
ENABLE_SLOPED_TRADING=1
ASC1_ALLOW_LONGS=0
ASC1_ALLOW_SHORTS=1
ASC1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,ATOMUSDT
ASC1_MIN_RANGE_R2=0.50
ASC1_SHORT_MAX_POS_SLOPE_PCT=0.0
ASC1_CONFIRM_5M_BARS=6
ASC1_SHORT_MIN_REJECT_DEPTH_ATR=0.75
ASC1_SHORT_MAX_NEAR_UPPER_BARS=2
ASC1_SHORT_MIN_RSI=60
ASC1_SHORT_NEAR_UPPER_ATR=0.15
ASC1_TRAIL_ATR_MULT=0.0
ASC1_TP1_FRAC=0.45
ASC1_TP2_BUFFER_PCT=0.40
ASC1_TIME_STOP_BARS_5M=480

## === RANGE SCALP — BOTH SIDES (range conditions perfect for this) ===
ARS1_ALLOW_LONGS=1
ARS1_ALLOW_SHORTS=1
ARS1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,DOTUSDT,LTCUSDT,SUIUSDT

## === ELDER TS v2 — SHORTS only in bear chop ===
ETS2_ALLOW_LONGS=0
ETS2_ALLOW_SHORTS=1

## === v7 NEW SLEEVES — bear_chop ===
## breakdown_v2: OFF (needs clear directional trend, not chop)
ENABLE_BREAKDOWN2_TRADING=0

## slope_choch: conservative CHOCH shorts — valid in bear chop
ENABLE_SLOPE_CHOCH_TRADING=1

## liq_cascade: both sides — chop has cascade risk in both directions
ENABLE_LC_TRADING=1
LC_ALLOW_LONGS=1
LC_ALLOW_SHORTS=1

## funding_rev: active in any regime
ENABLE_FR_TRADING=1

## micro_scalp: both sides in chop
ENABLE_MSCALP_TRADING=1
MSCALP_ALLOW_LONGS=1
MSCALP_ALLOW_SHORTS=1

## Risk reduction in bear chop
RISK_MULT_OVERRIDE=0.70
