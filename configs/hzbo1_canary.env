# ─────────────────────────────────────────────────────────────
# alt_horizontal_break_v1 (HZBO1) — Horizontal zone breakdown shorts canary
# WF-22 verdict: 🟢 VIABLE  AvgPF=1.647, PF>1.0: 13/22 (59%)
# Validated: 2026-04-15  Risk multiplier: 0.40× (low freq, high quality)
#
# STRATEGY: Detect clusters of swing LOWS that form a horizontal support zone.
# Enter SHORT when price breaks decisively BELOW the zone with an impulse
# bearish candle on above-average volume.
#
# COMPLEMENT TO ASB1:
#   ASB1 shorts SLOPED ascending trendlines (higher lows → momentum break)
#   HZBO1 shorts HORIZONTAL support zones (flat clusters → support failure)
#   These fire on fundamentally different price structures → low correlation.
#
# KEY INSIGHT FROM WF-22:
#   Horizontal zones exist in ALL market conditions (even flat/chop), so they
#   generate more noise signals than sloped trendlines. The fix: require
#   MIN_TOUCHES=3 (strong zones only) + VOL_MULT=1.3 (volume confirms break)
#   + tight ZONE_ATR_WIDTH=0.30 (well-defined levels, not vague clusters).
#   Together these 3 filters select only the cleanest, most decisive breaks.
#
# MACRO FILTER (critical):
#   HZBO1_MACRO_REQUIRE_BEARISH=1 — only short when 4h MACD histogram < 0.
#   Without: AvgPF=0.961 (WEAK). With: AvgPF=1.647 (VIABLE).
#   Same proven approach as Elder v2 and ASB1.
#
# TRADE FREQUENCY: ~10 trades/45-day window (low frequency, HIGH quality).
# Deploy at 0.40× risk (lower than ASB1 due to sample size).
# Enable longs when BTC exceeds Dec 2025 ATH $108k.
# ─────────────────────────────────────────────────────────────

ENABLE_HZBO1_TRADING=1
HZBO1_RISK_MULT=0.40

# Symbols
HZBO1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT

# ── Signal timeframe (1h) ─────────────────────────────────────
HZBO1_SIGNAL_TF=60
HZBO1_SIGNAL_LOOKBACK=150

# ── Pivot detection ───────────────────────────────────────────
HZBO1_PIVOT_LEFT=3
HZBO1_PIVOT_RIGHT=3

# ── Zone detection (KEY: tight clustering + min 3 touches) ───
HZBO1_MIN_TOUCHES=3
HZBO1_MAX_ZONE_AGE=20
HZBO1_ZONE_ATR_WIDTH=0.30

# ── Breakout entry confirmation ───────────────────────────────
HZBO1_BREAK_ATR=0.40
HZBO1_MIN_BODY_FRAC=0.45
HZBO1_RSI_SHORT_MAX=68.0
HZBO1_RSI_LONG_MIN=32.0

# ── Volume filter (KEY: confirms the break is real, not noise) ─
HZBO1_VOL_MULT=1.3
HZBO1_VOL_PERIOD=20

# ── CRITICAL: Macro bearish filter ───────────────────────────
# Only short when 4h MACD histogram is NEGATIVE (below zero line).
HZBO1_MACRO_TF=240
HZBO1_MACRO_REQUIRE_BEARISH=1
HZBO1_MACRO_REQUIRE_BULLISH=0
HZBO1_MACRO_MACD_FAST=12
HZBO1_MACRO_MACD_SLOW=26
HZBO1_MACRO_MACD_SIGNAL=9
HZBO1_MACRO_EMA_GATE=0

# ── Exits ─────────────────────────────────────────────────────
HZBO1_SL_ATR_MULT=0.50
HZBO1_TP1_RR=1.5
HZBO1_TP2_RR=3.0
HZBO1_TP1_FRAC=0.50
HZBO1_BE_TRIGGER_RR=1.00
HZBO1_BE_LOCK_RR=0.02
HZBO1_TIME_STOP_BARS_5M=576
HZBO1_COOLDOWN_BARS_5M=60

# ── Direction ─────────────────────────────────────────────────
HZBO1_ALLOW_LONGS=0
HZBO1_ALLOW_SHORTS=1

# ─────────────────────────────────────────────────────────────
# WF-22 SUMMARY (best config = "selective" — 22 × 45-day windows):
#   AvgPF:     1.647
#   PF>1.00:   13/22 (59%)
#   PF>1.15:   13/22 (59%)
#   AvgTrades: ~10/window (low freq — sniper trades only)
#
# STRONG windows: Jun-20, Jun-05, Jul-05, Aug-19, Sep-03,
#                 Oct-18, Nov-17, Dec-02, Feb-15, Mar-02, Apr-01
# WEAK windows:   May-21, Jul-20, Oct-03, Jan-01, Jan-16, Jan-31,
#                 Mar-17 (January 2026 BTC recovery bounce)
#
# PORTFOLIO ROLE:
#   ATT1:  trendline BOUNCE (sloped, both directions) — PF=1.35
#   Elder: MACD momentum shorts (trend following)     — PF=1.127
#   ASB1:  trendline BREAKDOWN (sloped, shorts-only)  — PF=1.228
#   HZBO1: zone BREAKDOWN (horizontal, shorts-only)   — PF=1.647
#
# HZBO1 fires on a DIFFERENT price structure than ASB1/ATT1.
# Sloped strategies need a trendline to exist (not valid in flat ranges).
# HZBO1 fires on horizontal cluster breaks — complementary signal type.
# ─────────────────────────────────────────────────────────────
