## Full-stack annual backtest snapshot for Elder-integration check.
## Purpose:
## - keep the old quiet-market pockets that improved DD in the last compare
## - keep the stronger midterm v3 PASS candidate
## - add the best passing Elder/TS132 v12 pocket as a sixth-sleeve candidate
## - test Elder both as an additive sleeve and as a possible midterm replacement

ENABLE_BREAKOUT_TRADING=1
ENABLE_MIDTERM_TRADING=1
ENABLE_SLOPED_TRADING=1
ENABLE_FLAT_TRADING=1
ENABLE_BREAKDOWN_TRADING=1

ASC1_SYMBOL_ALLOWLIST=ATOMUSDT,LINKUSDT
ARF1_SYMBOL_ALLOWLIST=LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT
BREAKDOWN_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT
MIDTERM_SYMBOLS=BTCUSDT,ETHUSDT

BT_BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_BUFFER_ATR=0.12
BREAKOUT_MAX_CHASE_PCT=0.11
BREAKOUT_MAX_DIST_ATR=1.4
BREAKOUT_RECLAIM_ATR=0.12
BREAKOUT_ALLOW_SHORTS=1

BREAKDOWN_RR=2.0
BREAKDOWN_SL_ATR=1.8
BREAKDOWN_MAX_DIST_ATR=2.0

MTPB_ALLOW_LONGS=1
MTPB_ALLOW_SHORTS=1
MTPB_TREND_MIN_GAP_PCT=0.20
MTPB_TREND_SLOPE_MIN_PCT=0.46
MTPB_LONG_RECLAIM_PCT=0.24
MTPB_SHORT_RECLAIM_PCT=0.24
MTPB_LONG_TOUCH_TOL_PCT=0.16
MTPB_SHORT_TOUCH_TOL_PCT=0.16
MTPB_RR=2.4
MTPB_COOLDOWN_BARS_5M=108
MTPB_TIME_STOP_BARS_5M=72
MTPB_LONG_MAX_PULLBACK_PCT=0.80
MTPB_SHORT_MAX_PULLBACK_PCT=0.80
MTPB_LONG_MAX_ATR_PCT_1H=1.80
MTPB_SHORT_MAX_ATR_PCT_1H=2.00
MTPB_TP1_RR=1.2
MTPB_TP2_RR=2.8
MTPB_TP1_FRAC=0.50
MTPB_USE_RUNNER_EXITS=0
MTPB_TRAIL_ATR_MULT=1.1
MTPB_MAX_SIGNALS_PER_DAY=1

TS132_ALLOW_LONGS=1
TS132_ALLOW_SHORTS=1
TS132_BE_PCT=1.0
TS132_EVAL_TF_MIN=60
TS132_EXEC_MODE=eth
TS132_MAX_SIGNALS_PER_DAY=3
TS132_OSC_OB=68
TS132_OSC_PERIOD=6
TS132_SL_ATR_MULT=2.0
TS132_TIME_STOP_BARS_5M=216
TS132_TP_ATR_MULT=6.0
TS132_TRADE_MODE=active
TS132_TRAIL_ACTIVATE_LONG_ATR=2.0
TS132_TRAIL_ACTIVATE_SHORT_ATR=3.0
TS132_TRAIL_ATR_MULT_LONG=1.2
TS132_TRAIL_ATR_MULT_SHORT=1.6
TS132_TREND_EMA_LEN=45
TS132_TREND_TF=240
TS132_USE_VOL_FILTER=0
TS132_VOL_MULT=0.5

## Union symbol set for the comparison run:
## BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT,DOTUSDT,SUIUSDT,ADAUSDT,BCHUSDT
