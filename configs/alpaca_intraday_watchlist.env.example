# Optional watchlist expansion for equities_alpaca_intraday_bridge.py
# If INTRADAY_SYMBOLS is empty and autodiscovery is on, the bridge scans all
# available *_M5.csv files under INTRADAY_DATA_DIR up to INTRADAY_MAX_SYMBOLS.

INTRADAY_AUTODISCOVER_FROM_CACHE=1
INTRADAY_MAX_SYMBOLS=24
INTRADAY_DATA_DIR=data_cache/equities_1h

# Optional explicit watchlist override.
# INTRADAY_SYMBOLS=TSLA,GOOGL,JPM,NVDA,AMD,AVGO,PLTR,META,NFLX,AAPL,MSFT

# Optional class buckets for symbols beyond the legacy TSLA/GOOGL/JPM set.
INTRADAY_BREAKOUT_SYMBOLS=TSLA,NVDA,AMD,AVGO,PLTR,META,NFLX,SHOP
INTRADAY_REVERSION_SYMBOLS=GOOGL,JPM,AAPL,MSFT,COST,UNH,XOM,JNJ

# Fallback class if a discovered symbol is not listed above.
INTRADAY_DEFAULT_CLASS=grid_reversion

# Alternative advanced form:
# INTRADAY_STRATEGY_MAP_JSON={"TSLA":"breakout_continuation","NVDA":"breakout_continuation","JPM":"grid_reversion"}
