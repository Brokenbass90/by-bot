## Full-stack annual backtest snapshot for current live 5-sleeve crypto stack + scoped Elder.
## Purpose:
## - keep the current live crypto sleeves/allowlists as close as possible to production
## - add Elder/TS132 with its best v12 parameters
## - constrain Elder to its proven narrow pocket instead of letting it trade the full union

ENABLE_BREAKOUT_TRADING=1
ENABLE_MIDTERM_TRADING=1
ENABLE_SLOPED_TRADING=1
ENABLE_FLAT_TRADING=1
ENABLE_BREAKDOWN_TRADING=1
ENABLE_TS132_TRADING=1

ASC1_SYMBOL_ALLOWLIST=ATOMUSDT,LINKUSDT,DOTUSDT
ARF1_SYMBOL_ALLOWLIST=LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT,ADAUSDT,BCHUSDT
BREAKDOWN_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT
MTPB_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT

BREAKOUT_TOP_N=10
BT_BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_BUFFER_ATR=0.12
BREAKOUT_MAX_CHASE_PCT=0.11
BREAKOUT_MAX_DIST_ATR=1.4
BREAKOUT_RECLAIM_ATR=0.12
BREAKOUT_ALLOW_SHORTS=1

TS132_SYMBOLS=BTCUSDT,ETHUSDT
TS132_ALLOW_LONGS=1
TS132_ALLOW_SHORTS=1
TS132_BE_PCT=1.0
TS132_EVAL_TF_MIN=60
TS132_EXEC_MODE=eth
TS132_MAX_SIGNALS_PER_DAY=3
TS132_OSC_OB=68
TS132_OSC_PERIOD=6
TS132_SL_ATR_MULT=2.0
TS132_TIME_STOP_BARS_5M=216
TS132_TP_ATR_MULT=6.0
TS132_TRADE_MODE=active
TS132_TRAIL_ACTIVATE_LONG_ATR=2.0
TS132_TRAIL_ACTIVATE_SHORT_ATR=3.0
TS132_TRAIL_ATR_MULT_LONG=1.2
TS132_TRAIL_ATR_MULT_SHORT=1.6
TS132_TREND_EMA_LEN=45
TS132_TREND_TF=240
TS132_USE_VOL_FILTER=0
TS132_VOL_MULT=0.5

## Union symbol set for the comparison run:
## BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT,DOTUSDT,SUIUSDT,ADAUSDT,BCHUSDT
