## Full-stack annual backtest snapshot for the next comparison cycle.
## Purpose:
## - keep the current 5-sleeve crypto stack
## - replace the earlier midterm bridge with the best PASS from
##   autoresearch_20260327_110543_midterm_pullback_v3_tiny_focus
## - compare against both:
##   * portfolio_20260327_161054_full_stack_iteration_20260327_annual
##   * portfolio_20260325_172613_new_5strat_final

ENABLE_BREAKOUT_TRADING=1
ENABLE_MIDTERM_TRADING=1
