# Broad-market dynamic intraday equities trend-focused experiment.
# Goal: move broad dynamic Alpaca beyond breakout/grid only and test the
# two raw families that currently look most alive in the broad scan:
# trend_retest and trend_pullback_rebound.

INTRADAY_CONFIG_FILE=configs/intraday_config_broad_trend.json
INTRADAY_DATA_DIR=data_cache/equities_1h
INTRADAY_DYNAMIC_SYMBOL_POOL=
INTRADAY_DYNAMIC_MAX_SYMBOLS=16
INTRADAY_DYNAMIC_BREAKOUT_TARGET=8
INTRADAY_DYNAMIC_REVERSION_TARGET=8
INTRADAY_DYNAMIC_MIN_AVG_DOLLAR_VOL=15000000
INTRADAY_DYNAMIC_BREAKOUT_CLASS=trend_retest
INTRADAY_DYNAMIC_REVERSION_CLASS=trend_pullback_rebound:quality_guard

# Research helpers used by the segmented annual runner.
EQ_WF_TOP_N=12
EQ_MIN_TRADES=12
