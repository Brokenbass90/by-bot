{
  "name": "equities_monthly_v24_focus_bridge",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "{MAX_HOLD_DAYS}",
    "--lookback-days",
    "50",
    "--min-mom-lookback-pct",
    "2.0",
    "--pullback-min-pct",
    "-18.0",
    "--pullback-max-pct",
    "-1.5",
    "--regime-min-breadth-sma-pct",
    "{REGIME_MIN_BREADTH_SMA_PCT}",
    "--regime-min-breadth-mom-pct",
    "{REGIME_MIN_BREADTH_MOM_PCT}",
    "--regime-min-avg-mom-pct",
    "{REGIME_MIN_AVG_MOM_PCT}",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ,IWM",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "{BENCH_MIN_ABOVE_SMA_COUNT}",
    "--benchmark-min-positive-mom-count",
    "{BENCH_MIN_POSITIVE_MOM_COUNT}",
    "--benchmark-min-avg-mom-pct",
    "{BENCH_MIN_AVG_MOM_PCT}",
    "--corr-lookback-days",
    "60",
    "--max-pair-corr",
    "{MAX_PAIR_CORR}",
    "--corr-penalty-mult",
    "{CORR_PENALTY_MULT}",
    "--corr-penalty-threshold",
    "0.40",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "60",
    "--position-weight-mode",
    "{POSITION_WEIGHT_MODE}",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "grid": {
    "TOP_N": [3],
    "MAX_HOLD_DAYS": [7, 8],
    "REGIME_MIN_BREADTH_SMA_PCT": [55, 60],
    "REGIME_MIN_BREADTH_MOM_PCT": [60, 62, 64],
    "REGIME_MIN_AVG_MOM_PCT": [2.0, 2.2],
    "BENCH_MIN_ABOVE_SMA_COUNT": [1],
    "BENCH_MIN_POSITIVE_MOM_COUNT": [1],
    "BENCH_MIN_AVG_MOM_PCT": [0.8, 1.0],
    "UNIVERSE_TOP_K": [7, 8],
    "POSITION_WEIGHT_MODE": ["inv_vol", "score_inv_vol"],
    "STOP_ATR_MULT": [1.25, 1.30],
    "TARGET_ATR_MULT": [3.7, 4.0],
    "MAX_PAIR_CORR": [0.65],
    "CORR_PENALTY_MULT": [4.0, 5.0]
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "constraints": {
    "min_trades": 38,
    "min_net_pnl": 60.0,
    "max_drawdown": 8.5,
    "max_negative_months": 4,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -4.6
  },
  "score_weights": {
    "net_pnl": 1.55,
    "winrate": 24.0,
    "max_drawdown": 2.2,
    "trades": 0.04,
    "trades_cap": 60,
    "negative_months": 13.0,
    "max_negative_streak": 9.0,
    "worst_month_pnl": 10.0
  }
}
