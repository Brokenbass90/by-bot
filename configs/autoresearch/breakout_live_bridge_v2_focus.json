{
  "name": "breakout_live_bridge_v2_focus",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,ATOMUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout,btc_eth_midterm_pullback",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "BT_BREAKOUT_QUALITY_ENABLE": ["1"],
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.54, 0.55, 0.56],
    "BREAKOUT_MAX_CHASE_PCT": [0.14, 0.15, 0.16],
    "BREAKOUT_MAX_LATE_VS_REF_PCT": [0.35, 0.40],
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": [0.04, 0.05, 0.06],
    "BREAKOUT_IMPULSE_ATR_MULT": [0.95, 1.00],
    "BREAKOUT_RECLAIM_ATR": [0.12, 0.15],
    "BREAKOUT_MAX_DIST_ATR": [1.30, 1.35, 1.40],
    "BREAKOUT_BUFFER_ATR": [0.10, 0.12]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0"
  },
  "constraints": {
    "min_trades": 300,
    "min_profit_factor": 1.30,
    "max_drawdown": 4.5,
    "min_net_pnl": 18.0,
    "max_negative_months": 3,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -1.5
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.7,
    "trades": 0.06,
    "trades_cap": 500,
    "negative_months": 4.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 4.0
  }
}
