{
  "name": "equities_monthly_v15_worst_month_bridge",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "2",
    "--max-hold-days",
    "{MAX_HOLD_DAYS}",
    "--lookback-days",
    "50",
    "--min-mom-lookback-pct",
    "2.0",
    "--pullback-min-pct",
    "-18.0",
    "--pullback-max-pct",
    "-1.5",
    "--regime-min-breadth-sma-pct",
    "{REGIME_MIN_BREADTH_SMA_PCT}",
    "--regime-min-breadth-mom-pct",
    "{REGIME_MIN_BREADTH_MOM_PCT}",
    "--regime-min-avg-mom-pct",
    "{REGIME_MIN_AVG_MOM_PCT}",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ,IWM",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--corr-lookback-days",
    "60",
    "--corr-penalty-mult",
    "5.0",
    "--corr-penalty-threshold",
    "0.45",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "1",
    "--benchmark-min-positive-mom-count",
    "1",
    "--benchmark-min-avg-mom-pct",
    "1.0",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "60",
    "--position-weight-mode",
    "inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "grid": {
    "MAX_HOLD_DAYS": [12, 13, 14, 15],
    "REGIME_MIN_BREADTH_SMA_PCT": [55, 60],
    "REGIME_MIN_BREADTH_MOM_PCT": [55, 60],
    "REGIME_MIN_AVG_MOM_PCT": [1.8, 2.0, 2.2],
    "UNIVERSE_TOP_K": [7, 8, 9],
    "STOP_ATR_MULT": [1.55, 1.60, 1.70, 1.80],
    "TARGET_ATR_MULT": [3.00, 3.25, 3.50]
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "constraints": {
    "min_trades": 24,
    "min_net_pnl": 55.0,
    "max_drawdown": 11.0,
    "max_negative_months": 4,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -6.0
  },
  "score_weights": {
    "net_pnl": 1.0,
    "winrate": 22.0,
    "max_drawdown": 1.3,
    "trades": 0.02,
    "trades_cap": 40,
    "negative_months": 7.0,
    "max_negative_streak": 5.0,
    "worst_month_pnl": 5.5
  }
}
