{
  "_comment": "Equities v29: test whether modestly wider diversification (TOP_N 3-4 instead of only 2) can smooth the monthly sleeve without destroying the v28 edge. This is a structural test, not another tiny stop tweak.",
  "name": "equities_monthly_v29_diversify_refine",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "20",
    "--lookback-days",
    "40",
    "--min-mom-lookback-pct",
    "2.0",
    "--pullback-min-pct",
    "-15.0",
    "--pullback-max-pct",
    "-1.0",
    "--regime-min-breadth-sma-pct",
    "50",
    "--regime-min-breadth-mom-pct",
    "50",
    "--regime-min-avg-mom-pct",
    "2.0",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "{BENCHMARK_MIN_ABOVE_SMA}",
    "--corr-lookback-days",
    "60",
    "--corr-penalty-mult",
    "2.5",
    "--corr-penalty-threshold",
    "0.5",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "80",
    "--position-weight-mode",
    "score_inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--intramonth-portfolio-stop-pct",
    "{INTRAMONTH_STOP}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "profit_factor": "profit_factor",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "grid": {
    "BENCHMARK_MIN_ABOVE_SMA": [1],
    "TOP_N": [2, 3, 4],
    "UNIVERSE_TOP_K": [7, 10, 12],
    "STOP_ATR_MULT": [1.7, 1.9],
    "TARGET_ATR_MULT": [3.5, 4.0],
    "INTRAMONTH_STOP": [0.04, 0.05]
  },
  "_combo_count": "1×3×3×2×2×2 = 72 combos",
  "constraints": {
    "min_trades": 25,
    "min_net_pnl": 55.0,
    "min_profit_factor": 1.8,
    "max_drawdown": 11.0,
    "max_negative_months": 5,
    "max_negative_streak": 3
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 3.0,
    "winrate": 20.0,
    "max_drawdown": 1.7,
    "trades": 0.02,
    "trades_cap": 70,
    "negative_months": 11.0,
    "max_negative_streak": 7.0,
    "worst_month_pnl": 8.0
  },
  "_run_command": "nohup python3 scripts/run_strategy_autoresearch.py --spec configs/autoresearch/equities_monthly_v29_diversify_refine.json > /tmp/equities_v29.log 2>&1 &",
  "_expected_runtime_minutes": 6,
  "_goal": "Test whether broader but still disciplined diversification can smooth monthly behavior better than the v28 TOP_N=2 winner."
}
