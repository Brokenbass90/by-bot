{
  "name": "midterm_pullback_v1",
  "description": "Broader repair sweep for btc_eth_midterm_pullback. Goal: improve trade density and side balance without reopening deep red months; compare simple RR exits against runner exits.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "btc_eth_midterm_pullback",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "1",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "SYMBOLS": [
      "ETHUSDT",
      "BTCUSDT,ETHUSDT"
    ],
    "MTPB_TREND_SLOPE_MIN_PCT": [0.40, 0.30, 0.50],
    "MTPB_TREND_MIN_GAP_PCT": [0.24, 0.18, 0.30],
    "MTPB_LONG_RECLAIM_PCT": [0.20, 0.16, 0.24],
    "MTPB_SHORT_RECLAIM_PCT": [0.20, 0.16, 0.24],
    "MTPB_RR": [2.4, 2.0, 2.8],
    "MTPB_USE_RUNNER_EXITS": [0, 1],
    "MTPB_TRAIL_ATR_MULT": [1.1, 0.9]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "MTPB_ALLOW_LONGS": "1",
    "MTPB_ALLOW_SHORTS": "1",
    "MTPB_LONG_TOUCH_TOL_PCT": "0.16",
    "MTPB_SHORT_TOUCH_TOL_PCT": "0.16",
    "MTPB_LONG_MAX_PULLBACK_PCT": "0.80",
    "MTPB_SHORT_MAX_PULLBACK_PCT": "0.80",
    "MTPB_LONG_MAX_ATR_PCT_1H": "1.80",
    "MTPB_SHORT_MAX_ATR_PCT_1H": "2.00",
    "MTPB_TP1_RR": "1.2",
    "MTPB_TP2_RR": "2.8",
    "MTPB_TP1_FRAC": "0.50",
    "MTPB_COOLDOWN_BARS_5M": "60",
    "MTPB_MAX_SIGNALS_PER_DAY": "2"
  },
  "constraints": {
    "min_trades": 45,
    "min_profit_factor": 1.35,
    "max_drawdown": 4.5,
    "min_net_pnl": 8.0,
    "max_negative_months": 3,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -2.5
  },
  "score_weights": {
    "net_pnl": 1.2,
    "profit_factor": 4.0,
    "winrate": 8.0,
    "max_drawdown": 1.8,
    "trades": 0.10,
    "trades_cap": 90,
    "negative_months": 4.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 2.5
  }
}
