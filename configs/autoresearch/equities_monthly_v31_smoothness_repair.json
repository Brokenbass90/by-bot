{
  "name": "equities_monthly_v31_smoothness_repair",
  "description": "Equities v31: take the strong v30 frontier and explicitly optimize for smoother monthly behavior. Keep concentration at TOP_N=2 and search stricter regime/correlation controls plus slightly tighter intramonth stop budgets.",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "2",
    "--max-hold-days",
    "20",
    "--lookback-days",
    "40",
    "--min-mom-lookback-pct",
    "2.0",
    "--pullback-min-pct",
    "-15.0",
    "--pullback-max-pct",
    "-1.0",
    "--regime-min-breadth-sma-pct",
    "{REGIME_MIN_BREADTH_SMA}",
    "--regime-min-breadth-mom-pct",
    "{REGIME_MIN_BREADTH_MOM}",
    "--regime-min-avg-mom-pct",
    "{REGIME_MIN_AVG_MOM}",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "{BENCHMARK_MIN_ABOVE_SMA}",
    "--corr-lookback-days",
    "60",
    "--max-pair-corr",
    "{MAX_PAIR_CORR}",
    "--corr-penalty-mult",
    "{CORR_PENALTY_MULT}",
    "--corr-penalty-threshold",
    "0.5",
    "--universe-top-k",
    "7",
    "--universe-score-lookback-days",
    "80",
    "--position-weight-mode",
    "score_inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "1.7",
    "--target-atr-mult",
    "4.0",
    "--intramonth-portfolio-stop-pct",
    "{INTRAMONTH_STOP}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "profit_factor": "profit_factor",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "grid": {
    "BENCHMARK_MIN_ABOVE_SMA": [1, 2],
    "REGIME_MIN_BREADTH_SMA": [50, 60],
    "REGIME_MIN_BREADTH_MOM": [50, 60],
    "REGIME_MIN_AVG_MOM": [2.0, 3.0],
    "MAX_PAIR_CORR": [0.75, 0.85],
    "CORR_PENALTY_MULT": [2.5, 3.5],
    "INTRAMONTH_STOP": [0.035, 0.04, 0.05]
  },
  "_combo_count": "192 combos",
  "constraints": {
    "min_trades": 25,
    "min_net_pnl": 60.0,
    "min_profit_factor": 1.9,
    "max_drawdown": 11.0,
    "max_negative_months": 4,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 3.0,
    "winrate": 20.0,
    "max_drawdown": 2.0,
    "trades": 0.02,
    "trades_cap": 60,
    "negative_months": 14.0,
    "max_negative_streak": 9.0,
    "worst_month_pnl": 10.0
  },
  "_expected_runtime_minutes": 12,
  "_goal": "Preserve the v30 return/PF zone while explicitly pushing worst-month profile and negative-month count lower."
}
