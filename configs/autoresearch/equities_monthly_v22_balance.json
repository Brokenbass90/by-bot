{
  "name": "equities_monthly_v22_balance",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "{MAX_HOLD_DAYS}",
    "--lookback-days",
    "{LOOKBACK_DAYS}",
    "--min-mom-lookback-pct",
    "{MIN_MOM_LOOKBACK_PCT}",
    "--pullback-min-pct",
    "{PULLBACK_MIN_PCT}",
    "--pullback-max-pct",
    "-1.0",
    "--regime-min-breadth-sma-pct",
    "50",
    "--regime-min-breadth-mom-pct",
    "{REGIME_MIN_BREADTH_MOM_PCT}",
    "--regime-min-avg-mom-pct",
    "2.0",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--corr-lookback-days",
    "60",
    "--corr-penalty-mult",
    "2.5",
    "--corr-penalty-threshold",
    "0.5",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "80",
    "--position-weight-mode",
    "score_inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "grid": {
    "TOP_N": [3],
    "MAX_HOLD_DAYS": [15, 20],
    "LOOKBACK_DAYS": [60, 70],
    "MIN_MOM_LOOKBACK_PCT": [1.5, 2.0],
    "PULLBACK_MIN_PCT": [-18.0, -12.0],
    "REGIME_MIN_BREADTH_MOM_PCT": [50, 60],
    "UNIVERSE_TOP_K": [7, 10, 0],
    "STOP_ATR_MULT": [1.3, 1.5, 1.7],
    "TARGET_ATR_MULT": [2.5, 3.0, 3.5, 4.0]
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "constraints": {
    "min_trades": 35,
    "min_net_pnl": 55.0,
    "max_drawdown": 12.0,
    "max_negative_months": 5,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.0,
    "winrate": 25.0,
    "max_drawdown": 1.5,
    "trades": 0.02,
    "trades_cap": 60,
    "negative_months": 6.0,
    "max_negative_streak": 4.0,
    "worst_month_pnl": 5.0
  }
}
