{
  "_comment": "Breakout weak-chop probe v1 — test whether slightly softer impulse gating can recover more entries in weak/choppy conditions without wrecking the annual profile. This is a bounded adaptation test, not a live rollback.",
  "name": "breakout_weak_chop_probe_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,ATOMUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout,btc_eth_midterm_pullback",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "BT_BREAKOUT_QUALITY_ENABLE": ["1"],
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.50, 0.52, 0.53],
    "BREAKOUT_IMPULSE_ATR_MULT": [0.85, 0.90, 0.95],
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": [0.03, 0.05, 0.07],
    "BREAKOUT_MAX_CHASE_PCT": [0.13, 0.15],
    "BREAKOUT_MAX_LATE_VS_REF_PCT": [0.35, 0.40],
    "BREAKOUT_RECLAIM_ATR": [0.10, 0.12],
    "BREAKOUT_MAX_DIST_ATR": [1.40, 1.50],
    "BREAKOUT_BUFFER_ATR": [0.10, 0.12]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0",
    "BREAKOUT_ALLOW_SHORTS": "0"
  },
  "constraints": {
    "min_trades": 280,
    "min_profit_factor": 1.28,
    "max_drawdown": 5.0,
    "min_net_pnl": 17.0,
    "max_negative_months": 3,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -1.8
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.7,
    "trades": 0.05,
    "trades_cap": 520,
    "negative_months": 4.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 4.0
  },
  "_combo_count": "3×3×3×2×2×2×2×2×2 = 1728 combos",
  "_goal": "Decide whether the current breakout no-entry pressure in weak impulse is fixable with a softer breakout profile, or whether the right answer is to leave breakout strict and solve it later with a regime allocator."
}
