{
  "name": "elder_canonical_rewrite_v1",
  "description": "Annual validation of a canonical Elder Triple Screen rewrite: MACD histogram tide, Force Index pullback, and third-screen trailing stop above/below the previous entry bar.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
    "--strategies",
    "elder_triple_screen_v2",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ETS2_ALLOW_LONGS": "1",
    "ETS2_ALLOW_SHORTS": "1",
    "ETS2_TREND_TF": "240",
    "ETS2_TREND_MODE": "macd_hist",
    "ETS2_MACD_FAST": "12",
    "ETS2_MACD_SLOW": "26",
    "ETS2_MACD_SIGNAL": "9",
    "ETS2_TREND_SLOPE_BARS": "2",
    "ETS2_WAVE_TF": "60",
    "ETS2_OSC_TYPE": "force",
    "ETS2_OSC_PERIOD": "2",
    "ETS2_ENTRY_TF": "15",
    "ETS2_RISK_TF": "60",
    "ETS2_SL_ATR_MULT": "1.8",
    "ETS2_TP_ATR_MULT": "2.5",
    "ETS2_TRAIL_ATR_MULT": "1.0",
    "ETS2_ENTRY_MIN_BODY_FRAC": "0.15",
    "ETS2_ENTRY_BREAK_ATR_MULT": "0.03",
    "ETS2_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT"
  },
  "grid": {
    "ETS2_WAVE_LOOKBACK": [1, 2, 3, 4],
    "ETS2_TREND_SLOPE_BARS": [1, 2, 3],
    "ETS2_ENTRY_BREAK_ATR_MULT": [0.00, 0.03, 0.06],
    "ETS2_ENTRY_MIN_BODY_FRAC": [0.10, 0.15, 0.25],
    "ETS2_SL_ATR_MULT": [1.4, 1.8, 2.2],
    "ETS2_TP_ATR_MULT": [2.0, 2.5, 3.0],
    "ETS2_TRAIL_ATR_MULT": [0.8, 1.0, 1.2]
  },
  "constraints": {
    "min_trades": 10,
    "min_profit_factor": 1.10,
    "min_net_pnl": 2.0,
    "max_negative_months": 5,
    "max_negative_streak": 3
  },
  "score_weights": {
    "net_pnl": 1.6,
    "profit_factor": 5.5,
    "winrate": 3.0,
    "max_drawdown": 1.8,
    "trades": 0.15,
    "trades_cap": 140,
    "negative_months": 1.5,
    "worst_month_pnl": 1.3
  },
  "_combo_count": "4x3x3x3x3x3x3 = 2916 combos",
  "_goal": "Validate whether the canonical Elder structure can become a real annual-grade sleeve before we consider any live promotion."
}
