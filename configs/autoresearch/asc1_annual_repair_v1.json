{
  "name": "asc1_annual_repair_v1",
  "description": "Annual repair sweep for alt_sloped_channel_v1. Goal: test whether the sloped sleeve can become a real additive yearly component instead of a regime-specific near-miss.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "ATOMUSDT,LINKUSDT,ADAUSDT,DOGEUSDT,XRPUSDT,SOLUSDT",
    "--strategies",
    "alt_sloped_channel_v1",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ASC1_ALLOW_LONGS": "0",
    "ASC1_ALLOW_SHORTS": "1",
    "ASC1_SIGNAL_TF": "60",
    "ASC1_SIGNAL_LOOKBACK": "96",
    "ASC1_MIN_CHANNEL_WIDTH_PCT": "4.0",
    "ASC1_MAX_CHANNEL_WIDTH_PCT": "22.0",
    "ASC1_MAX_ABS_SLOPE_PCT": "3.0",
    "ASC1_MIN_ABS_SLOPE_PCT": "0.05",
    "ASC1_SHORT_MAX_POS_SLOPE_PCT": "0.0",
    "ASC1_TOUCH_BUFFER_ATR": "0.35",
    "ASC1_RECLAIM_ATR": "0.12",
    "ASC1_REJECT_ATR": "0.12",
    "ASC1_SHORT_MAX_NEAR_UPPER_BARS": "3",
    "ASC1_SHORT_VOL_AVG_BARS": "20",
    "ASC1_TP1_FRAC": "0.55",
    "ASC1_TIME_STOP_BARS_5M": "480",
    "ASC1_COOLDOWN_BARS_5M": "72",
    "ASC1_SYMBOL_ALLOWLIST": "ATOMUSDT,LINKUSDT,ADAUSDT,DOGEUSDT,XRPUSDT,SOLUSDT",
    "ASC1_CONFIRM_5M_BARS": "3"
  },
  "grid": {
    "ASC1_MIN_RANGE_R2": [0.30, 0.35, 0.40],
    "ASC1_SHORT_MIN_RSI": [56, 58, 60],
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": [0.55, 0.65, 0.75],
    "ASC1_SHORT_MIN_UPPER_WICK_FRAC": [0.0, 0.15],
    "ASC1_SHORT_MIN_REJECT_VOL_MULT": [0.8, 1.05],
    "ASC1_SL_ATR_MULT": [0.8, 0.9],
    "ASC1_TP2_BUFFER_PCT": [25.0, 35.0]
  },
  "constraints": {
    "min_trades": 16,
    "min_profit_factor": 1.20,
    "max_drawdown": 6.0,
    "min_net_pnl": 4.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.8,
    "profit_factor": 5.5,
    "winrate": 6.0,
    "max_drawdown": 2.0,
    "trades": 0.12,
    "trades_cap": 90,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "3x3x3x2x2x2x2 = 432 combos",
  "_goal": "Turn sloped shorts from a contextual near-miss into an annual-robust sleeve candidate or kill the idea honestly."
}
