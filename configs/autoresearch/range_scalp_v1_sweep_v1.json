{
  "name": "range_scalp_v1_sweep_v1",
  "description": "Parameter sweep for alt_range_scalp_v1 — 15m Bollinger Band scalper for bear/chop markets. High frequency target (100-200 trades/year). Test both longs and shorts.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "ADAUSDT,LINKUSDT,DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT",
    "--strategies",
    "alt_range_scalp_v1",
    "--days",
    "180",
    "--end",
    "2026-03-27",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "4",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "grid": {
    "ARS1_BB_PERIOD": [14, 20, 28],
    "ARS1_BB_STD": [1.8, 2.0, 2.2],
    "ARS1_RSI_LONG_MAX": [32, 35, 38],
    "ARS1_RSI_SHORT_MIN": [62, 65, 68],
    "ARS1_SL_ATR_MULT": [0.6, 0.8, 1.0],
    "ARS1_MIN_BAND_WIDTH_PCT": [2.5, 3.0, 4.0]
  },
  "base_env": {
    "ARS1_ALLOW_LONGS": "1",
    "ARS1_ALLOW_SHORTS": "1",
    "ARS1_TP1_FRAC": "0.55",
    "ARS1_TIME_STOP_BARS_5M": "216",
    "ARS1_COOLDOWN_BARS_5M": "48",
    "ARS1_SYMBOL_ALLOWLIST": "ADAUSDT,LINKUSDT,DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT",
    "ARS1_MAX_BAND_WIDTH_PCT": "20.0"
  },
  "constraints": {
    "min_trades": 40,
    "min_profit_factor": 1.15,
    "max_drawdown": 8.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 2,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 6.0,
    "winrate": 6.0,
    "max_drawdown": 2.0,
    "trades": 0.10,
    "trades_cap": 200,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "3×3×3×3×3×3 = 729 combos",
  "_goal": "High-frequency bear-chop strategy on 15m bars. Target: 100-200 trades/180d, PF > 1.20. Ideal as the primary income source in current bear-chop regime."
}
