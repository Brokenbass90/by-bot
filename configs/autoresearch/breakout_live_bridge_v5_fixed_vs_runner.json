{
  "_comment": "Bounded fixed-vs-runner compare on top of the historically strongest breakout live bridge pocket (v3_density r26). Keep entry geometry frozen; only test whether managed exits hold impulse moves better than fixed RR without wrecking PF/DD.",
  "name": "breakout_live_bridge_v5_fixed_vs_runner",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,ATOMUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout,btc_eth_midterm_pullback",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "BREAKOUT_EXIT_MODE": ["fixed", "runner"],
    "BREAKOUT_RR": [1.20, 1.35],
    "BREAKOUT_TIME_STOP_BARS": [0, 96],
    "BREAKOUT_PARTIAL_RS": ["1,2,3.5", "1,2,5"],
    "BREAKOUT_TRAIL_ATR_MULT": [1.8, 2.2, 2.6]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0",
    "BREAKOUT_ALLOW_SHORTS": "0",
    "BT_BREAKOUT_QUALITY_ENABLE": "1",
    "BT_BREAKOUT_QUALITY_MIN_SCORE": "0.53",
    "BREAKOUT_IMPULSE_ATR_MULT": "1.00",
    "BREAKOUT_MAX_CHASE_PCT": "0.13",
    "BREAKOUT_MAX_LATE_VS_REF_PCT": "0.35",
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": "0.07",
    "BREAKOUT_RECLAIM_ATR": "0.12",
    "BREAKOUT_MAX_DIST_ATR": "1.40",
    "BREAKOUT_BUFFER_ATR": "0.12",
    "BREAKOUT_PARTIAL_FRACS": "0.50,0.25,0.25",
    "BREAKOUT_TRAIL_ATR_PERIOD": "14"
  },
  "constraints": {
    "min_trades": 320,
    "min_profit_factor": 1.30,
    "max_drawdown": 4.5,
    "min_net_pnl": 18.0,
    "max_negative_months": 3,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -2.0
  },
  "score_weights": {
    "net_pnl": 1.2,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.9,
    "trades": 0.07,
    "trades_cap": 520,
    "negative_months": 5.0,
    "max_negative_streak": 4.0,
    "worst_month_pnl": 5.0
  },
  "_combo_count": "2x2x2x2x3 = 48 combos",
  "_goal": "Answer one practical question: does runner/managed exit add real value on the exact breakout entry profile that already worked, or is fixed RR still the better live bridge."
}
