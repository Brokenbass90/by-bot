{
  "_comment": "Recent-window breakout rehab without cache-only. Focus on entry quality and retest strictness, but let the server fetch missing candles instead of silently zero-trading.",
  "name": "breakout_live_bridge_v8_nocache",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,AVAXUSDT,DOGEUSDT,XRPUSDT,ADAUSDT,DOTUSDT,LTCUSDT",
    "--strategies",
    "inplay_breakout",
    "--days",
    "90",
    "--end",
    "2026-04-18",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "2",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "base_env": {
    "BYBIT_DATA_POLITE_SLEEP_SEC": "1.5",
    "BREAKOUT_ALLOW_SHORTS": "0",
    "BREAKOUT_CHOP_ER_MIN": "0.20",
    "BREAKOUT_IMPULSE_ATR_MULT": "1.00",
    "BREAKOUT_IMPULSE_BODY_MIN_FRAC": "0.35",
    "BREAKOUT_IMPULSE_VOL_MULT": "0.0",
    "BREAKOUT_MAX_CHASE_PCT": "0.13",
    "BREAKOUT_MAX_LATE_VS_REF_PCT": "0.35",
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": "0.07",
    "BREAKOUT_RECLAIM_ATR": "0.12",
    "BREAKOUT_BUFFER_ATR": "0.12",
    "BREAKOUT_REGIME_TF": "240",
    "BREAKOUT_REGIME_EMA_FAST": "21",
    "BREAKOUT_REGIME_EMA_SLOW": "55",
    "BREAKOUT_REGIME_STRICT": "1",
    "BT_BREAKOUT_QUALITY_ENABLE": "1",
    "BT_BREAKOUT_QUALITY_MIN_SCORE": "0.53"
  },
  "grid": {
    "BREAKOUT_REGIME_MODE": ["off", "ema"],
    "BREAKOUT_MAX_RETEST_BARS": [12, 15],
    "BREAKOUT_MIN_HOLD_BARS": [0, 2],
    "BREAKOUT_ENTRY_BODY_MIN_FRAC": [0.25, 0.35],
    "BREAKOUT_MAX_DIST_ATR": [1.0, 1.4]
  },
  "constraints": {
    "min_trades": 12,
    "min_profit_factor": 1.05,
    "max_drawdown": 8.0,
    "min_net_pnl": 0.0
  },
  "score_weights": {
    "net_pnl": 1.8,
    "profit_factor": 5.0,
    "winrate": 6.0,
    "max_drawdown": 2.0,
    "trades": 0.2,
    "trades_cap": 80
  }
}
