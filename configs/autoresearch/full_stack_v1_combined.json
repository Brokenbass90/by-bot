{
  "name": "full_stack_v1_combined",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols", "ATOMUSDT,LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT,BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,DOGEUSDT,BCHUSDT,AVAXUSDT",
    "--strategies", "alt_sloped_channel_v1,alt_resistance_fade_v1,inplay_breakout,btc_eth_midterm_pullback",
    "--days", "360",
    "--end", "2026-03-01",
    "--tag", "{tag}",
    "--starting_equity", "100",
    "--risk_pct", "0.005",
    "--leverage", "3",
    "--max_positions", "3",
    "--fee_bps", "10",
    "--slippage_bps", "10"
  ],
  "grid": {
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.50, 0.52, 0.54, 0.56],
    "BREAKOUT_MAX_CHASE_PCT": [0.12, 0.14, 0.16],
    "BREAKOUT_ALLOW_SHORTS": [0, 1],
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": [0.60, 0.75, 0.90],
    "ARF1_SYMBOL_ALLOWLIST": [
      "LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT",
      "LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT,ADAUSDT,BCHUSDT"
    ]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "0",
    "BT_BREAKOUT_QUALITY_ENABLE": "1",
    "BREAKOUT_BUFFER_ATR": "0.12",
    "BREAKOUT_RECLAIM_ATR": "0.12",
    "BREAKOUT_MAX_DIST_ATR": "1.4",
    "ASC1_ALLOW_SHORTS": "1",
    "ASC1_ALLOW_LONGS": "0",
    "ASC1_SHORT_MAX_NEAR_UPPER_BARS": "2",
    "ASC1_SHORT_MIN_RSI": "60",
    "ASC1_SHORT_NEAR_UPPER_ATR": "0.15",
    "ASC1_SYMBOL_ALLOWLIST": "ATOMUSDT,LINKUSDT",
    "ASC1_CONFIRM_5M_BARS": "6"
