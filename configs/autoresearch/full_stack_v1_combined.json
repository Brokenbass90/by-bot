  "constraints": {
    "min_trades": 350,
    "min_profit_factor": 1.45,
    "max_drawdown": 5.0,
    "min_net_pnl": 25.0,
    "max_negative_months": 2,
    "max_negative_streak": 1,
    "min_worst_month_pnl": -1.5
  },
  "score_weights": {
    "net_pnl": 1.2,
    "profit_factor": 6.0,
    "winrate": 12.0,
    "max_drawdown": 2.0,
    "trades": 0.05,
    "trades_cap": 700,
    "negative_months": 5.0,
    "max_negative_streak": 4.0,
    "worst_month_pnl": 5.0
  }
}
