{
  "name": "flat_slope_symbol_singletons_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "alt_sloped_channel_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--tag",
    "{tag}"
  ],
  "grid": {
    "SYMBOLS": [
      "LINKUSDT",
      "ATOMUSDT",
      "SOLUSDT",
      "AVAXUSDT",
      "ETHUSDT",
      "SUIUSDT",
      "BCHUSDT",
      "ADAUSDT",
      "DOTUSDT",
      "ETCUSDT",
      "BNBUSDT",
      "DOGEUSDT",
      "LTCUSDT",
      "XRPUSDT",
      "NEARUSDT",
      "SEIUSDT"
    ]
  },
  "base_env": {
    "ASC1_ALLOW_LONGS": "0",
    "ASC1_ALLOW_SHORTS": "1",
    "ASC1_MAX_ABS_SLOPE_PCT": "2.0",
    "ASC1_MIN_RANGE_R2": "0.25",
    "ASC1_SHORT_MAX_NEAR_UPPER_BARS": "2",
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": "0.75",
    "ASC1_SHORT_MIN_RSI": "60",
    "ASC1_SHORT_NEAR_UPPER_ATR": "0.15",
    "ASC1_SHORT_MIN_REJECT_VOL_MULT": "0.0",
    "ASC1_TP1_FRAC": "0.45",
    "ASC1_TP2_BUFFER_PCT": "0.4",
    "ASC1_TIME_STOP_BARS_5M": "480"
  },
  "constraints": {
    "min_trades": 4,
    "min_profit_factor": 1.1,
    "max_drawdown": 4.0,
    "min_net_pnl": 0.5,
    "max_negative_months": 2,
    "max_negative_streak": 1,
    "min_worst_month_pnl": -1.5
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 3.0,
    "winrate": 12.0,
    "max_drawdown": 1.0,
    "trades": 0.03,
    "trades_cap": 30,
    "negative_months": 2.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 1.5
  }
}
