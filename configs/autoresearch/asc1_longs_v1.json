{
  "_comment": "ASC1 longs test v1 — alt_sloped_channel_v1 already has long logic (buy at lower channel boundary). Currently disabled (ASC1_ALLOW_LONGS=0). Test longs-only and both-directions on same coin families. Relevant for market reversal / bull phase.",
  "name": "asc1_longs_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "alt_sloped_channel_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "2",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "SYMBOLS": [
      "ATOMUSDT,LINKUSDT",
      "ATOMUSDT,LINKUSDT,DOTUSDT",
      "SOLUSDT,LINKUSDT,ATOMUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT",
      "SOLUSDT,LINKUSDT,ATOMUSDT,DOTUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT"
    ],
    "ASC1_ALLOW_LONGS": ["1", "0"],
    "ASC1_ALLOW_SHORTS": ["1"],
    "ASC1_CONFIRM_5M_BARS": [4, 6],
    "SLOPED_RISK_MULT": ["0.10"]
  },
  "base_env": {
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": "0.75",
    "ASC1_SHORT_MAX_NEAR_UPPER_BARS": "2",
    "ASC1_SHORT_MIN_RSI": "60",
    "ASC1_SHORT_NEAR_UPPER_ATR": "0.15",
    "BACKTEST_CACHE_ONLY": "1"
  },
  "constraints": {
    "min_trades": 10,
    "min_profit_factor": 1.5,
    "max_drawdown": 4.0,
    "min_net_pnl": 8.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 6.0,
    "winrate": 10.0,
    "max_drawdown": 2.0,
    "trades": 0.05,
    "trades_cap": 60,
    "negative_months": 3.0,
    "max_negative_streak": 3.0
  }
}
