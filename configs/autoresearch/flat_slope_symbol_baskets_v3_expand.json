{
  "name": "flat_slope_symbol_baskets_v3_expand",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "alt_sloped_channel_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--tag",
    "{tag}"
  ],
  "grid": {
    "SYMBOLS": [
      "LINKUSDT,ATOMUSDT",
      "LINKUSDT,ATOMUSDT,SOLUSDT",
      "LINKUSDT,ATOMUSDT,AVAXUSDT",
      "LINKUSDT,ATOMUSDT,ETHUSDT",
      "LINKUSDT,ATOMUSDT,BCHUSDT",
      "LINKUSDT,ATOMUSDT,SUIUSDT",
      "LINKUSDT,ATOMUSDT,SOLUSDT,AVAXUSDT",
      "LINKUSDT,ATOMUSDT,SOLUSDT,ETHUSDT",
      "LINKUSDT,ATOMUSDT,AVAXUSDT,ETHUSDT",
      "LINKUSDT,ATOMUSDT,SOLUSDT,BCHUSDT",
      "LINKUSDT,ATOMUSDT,ETHUSDT,BCHUSDT",
      "LINKUSDT,ATOMUSDT,SOLUSDT,AVAXUSDT,ETHUSDT"
    ],
    "ASC1_MIN_RANGE_R2": [0.25, 0.30],
    "ASC1_SHORT_MIN_RSI": [58, 60],
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": [0.75, 0.85]
  },
  "base_env": {
    "ASC1_ALLOW_LONGS": "0",
    "ASC1_ALLOW_SHORTS": "1",
    "ASC1_MAX_ABS_SLOPE_PCT": "2.0",
    "ASC1_SHORT_MAX_NEAR_UPPER_BARS": "2",
    "ASC1_SHORT_NEAR_UPPER_ATR": "0.15",
    "ASC1_SHORT_MIN_REJECT_VOL_MULT": "0.0"
  },
  "constraints": {
    "min_trades": 18,
    "min_profit_factor": 1.9,
    "max_drawdown": 3.5,
    "min_net_pnl": 8.5,
    "max_negative_months": 1,
    "max_negative_streak": 1,
    "min_worst_month_pnl": -0.75
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 3.0,
    "winrate": 12.0,
    "max_drawdown": 1.0,
    "trades": 0.03,
    "trades_cap": 50,
    "negative_months": 1.5,
    "max_negative_streak": 2.0,
    "worst_month_pnl": 1.5
  }
}
