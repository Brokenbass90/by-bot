{
  "name": "impulse_volume_breakout_v1_recent180_sweep_v1",
  "description": "Mixed-regime validation for the new impulse-volume breakout sleeve over recent180. Same logic family as the current90 search, but on a wider recent history.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,SUIUSDT,DOGEUSDT,1000PEPEUSDT,TAOUSDT,HYPEUSDT",
    "--strategies",
    "impulse_volume_breakout_v1",
    "--days",
    "180",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "IVB1_ALLOW_LONGS": "1",
    "IVB1_REGIME_MODE": "off",
    "IVB1_BREAKOUT_LOOKBACK_BARS": "24",
    "IVB1_IMPULSE_LOOKBACK_BARS": "18",
    "IVB1_VOL_PERIOD": "20",
    "IVB1_MIN_BODY_FRAC": "0.45",
    "IVB1_MIN_BAR_RANGE_ATR": "1.2",
    "IVB1_RECLAIM_ATR": "0.08",
    "IVB1_ENTRY_BODY_MIN_FRAC": "0.25",
    "IVB1_TOUCH_BELOW_BREAKOUT_ATR": "0.20",
    "IVB1_INVALIDATION_CLOSE_ATR": "0.35",
    "IVB1_TP1_RR": "0.9",
    "IVB1_TRAIL_ATR_MULT": "1.4",
    "IVB1_TRAIL_ACTIVATE_RR": "0.9",
    "IVB1_MIN_STOP_PCT": "0.008",
    "IVB1_MAX_STOP_PCT": "0.060",
    "IVB1_TIME_STOP_BARS_5M": "72",
    "IVB1_COOLDOWN_BARS_5M": "12",
    "IVB1_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,SUIUSDT,DOGEUSDT,1000PEPEUSDT,TAOUSDT,HYPEUSDT"
  },
  "grid": {
    "IVB1_MIN_IMPULSE_PCT": [0.03, 0.05],
    "IVB1_MIN_VOL_MULT": [1.5, 2.0],
    "IVB1_RETRACE_MIN_FRAC": [0.20, 0.30],
    "IVB1_RETRACE_MAX_FRAC": [0.50, 0.65],
    "IVB1_SL_ATR": [0.8, 1.2],
    "IVB1_RR": [1.6, 2.2]
  },
  "constraints": {
    "min_trades": 16,
    "min_profit_factor": 1.10,
    "max_drawdown": 10.0,
    "min_net_pnl": 5.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 6.0,
    "winrate": 3.0,
    "max_drawdown": 2.0,
    "trades": 0.12,
    "trades_cap": 140,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "2x2x2x2x2x2 = 64 combos",
  "_goal": "Check whether the new impulse breakout family survives outside the very recent window before we consider any package integration."
}
