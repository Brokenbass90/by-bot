{
  "name": "equities_monthly_v19_dd_frontier",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "{MAX_HOLD_DAYS}",
    "--lookback-days",
    "50",
    "--min-mom-lookback-pct",
    "2.0",
    "--pullback-min-pct",
    "-18.0",
    "--pullback-max-pct",
    "-1.5",
    "--regime-min-breadth-sma-pct",
    "{REGIME_MIN_BREADTH_SMA_PCT}",
    "--regime-min-breadth-mom-pct",
    "{REGIME_MIN_BREADTH_MOM_PCT}",
    "--regime-min-avg-mom-pct",
    "{REGIME_MIN_AVG_MOM_PCT}",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ,IWM",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--corr-lookback-days",
    "60",
    "--corr-penalty-mult",
    "5.0",
    "--corr-penalty-threshold",
    "0.45",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "1",
    "--benchmark-min-positive-mom-count",
    "1",
    "--benchmark-min-avg-mom-pct",
    "{BENCH_MIN_AVG_MOM_PCT}",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "60",
    "--position-weight-mode",
    "inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "grid": {
    "TOP_N": [3],
    "MAX_HOLD_DAYS": [8, 9, 10],
    "REGIME_MIN_BREADTH_SMA_PCT": [55],
    "REGIME_MIN_BREADTH_MOM_PCT": [60],
    "REGIME_MIN_AVG_MOM_PCT": [2.0, 2.3],
    "BENCH_MIN_AVG_MOM_PCT": [1.0],
    "UNIVERSE_TOP_K": [8, 10],
    "STOP_ATR_MULT": [1.20, 1.25, 1.30, 1.35],
    "TARGET_ATR_MULT": [2.75, 3.00, 3.25]
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "constraints": {
    "min_trades": 40,
    "min_net_pnl": 52.0,
    "max_drawdown": 10.0,
    "max_negative_months": 4,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -5.2
  },
  "score_weights": {
    "net_pnl": 1.0,
    "winrate": 22.0,
    "max_drawdown": 2.1,
    "trades": 0.05,
    "trades_cap": 60,
    "negative_months": 9.0,
    "max_negative_streak": 6.0,
    "worst_month_pnl": 7.0
  }
}
