{
  "name": "att1_focused_pivot_sweep_v2_nocache",
  "description": "Recent 360d ATT1 rehab without cache-only. Focus on cleaner pivots and touch quality while keeping the grid compact enough for a durable server batch.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,LTCUSDT,ADAUSDT,DOTUSDT,SUIUSDT",
    "--strategies",
    "alt_trendline_touch_v1",
    "--days",
    "360",
    "--end",
    "2026-04-18",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.01",
    "--leverage",
    "1",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ATT1_PIVOT_RIGHT": "3",
    "ATT1_MAX_PIVOT_AGE": "20",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "1.5"
  },
  "grid": {
    "ATT1_PIVOT_LEFT": [3, 4],
    "ATT1_MIN_PIVOTS": [2, 3],
    "ATT1_MIN_R2": [0.80, 0.90],
    "ATT1_TOUCH_ATR": [0.25, 0.35],
    "ATT1_RSI_LONG_MAX": [52, 55],
    "ATT1_RSI_SHORT_MIN": [40, 45]
  },
  "constraints": {
    "min_trades": 20,
    "min_profit_factor": 1.15,
    "max_drawdown": 15.0,
    "min_net_pnl": 0.0
  },
  "score_weights": {
    "net_pnl": 2.0,
    "profit_factor": 5.0,
    "winrate": 7.0,
    "max_drawdown": 2.0,
    "trades": 0.15,
    "trades_cap": 80
  }
}
