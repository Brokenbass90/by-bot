{
  "name": "range_scalp_v1_annual_focus_v2",
  "description": "Focused annual standalone validation for alt_range_scalp_v1 using only the strongest 180d parameter pocket. Goal: verify whether the range scalper can survive a full year as a real frequency sleeve instead of just looking good in recent windows.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "ADAUSDT,LINKUSDT,DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT",
    "--strategies",
    "alt_range_scalp_v1",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "{MAX_POSITIONS}",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ARS1_ALLOW_LONGS": "1",
    "ARS1_ALLOW_SHORTS": "1",
    "ARS1_BB_PERIOD": "20",
    "ARS1_BB_STD": "2.0",
    "ARS1_SL_ATR_MULT": "0.8",
    "ARS1_TP1_FRAC": "0.55",
    "ARS1_TIME_STOP_BARS_5M": "216",
    "ARS1_COOLDOWN_BARS_5M": "48",
    "ARS1_SYMBOL_ALLOWLIST": "ADAUSDT,LINKUSDT,DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT",
    "ARS1_MAX_BAND_WIDTH_PCT": "20.0"
  },
  "grid": {
    "ARS1_MIN_BAND_WIDTH_PCT": [3.0, 4.0],
    "ARS1_RSI_LONG_MAX": [32, 35, 38],
    "ARS1_RSI_SHORT_MIN": [62, 65, 68],
    "MAX_POSITIONS": [3, 4]
  },
  "constraints": {
    "min_trades": 70,
    "min_profit_factor": 1.20,
    "max_drawdown": 10.0,
    "min_net_pnl": 6.0,
    "max_negative_months": 4,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.2,
    "profit_factor": 6.0,
    "winrate": 5.0,
    "max_drawdown": 1.8,
    "trades": 0.12,
    "trades_cap": 220,
    "negative_months": 2.0,
    "worst_month_pnl": 1.4
  },
  "_combo_count": "2x3x3x2 = 36 combos",
  "_goal": "Decide whether range_scalp deserves promotion as a high-frequency annual sleeve after isolating it to the best 180d parameter neighborhood."
}
