{
  "name": "micro_scalper_breakout_v1_grid",
  "description": "First autoresearch pass for MicroScalperBreakoutV1 — N-bar high breakout with trend filter. Fixed RR≥1.4, time_stop≥16.",
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,XRPUSDT",
    "--strategies",
    "micro_scalper_breakout_v1",
    "--days",
    "90",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "1",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10",
    "--base_interval_min",
    "5"
  ],
  "grid": {
    "MSBRK_TREND_TF": ["15", "30"],
    "MSBRK_TREND_EMA": [20, 34],
    "MSBRK_TREND_MIN_SLOPE_PCT": [0.04, 0.07, 0.10],
    "MSBRK_BREAKOUT_LOOKBACK": [4, 6, 10],
    "MSBRK_BREAKOUT_BUFFER_ATR": [0.04, 0.07, 0.10],
    "MSBRK_MIN_BODY_ATR": [0.18, 0.25],
    "MSBRK_MIN_CLOSE_FRAC": [0.55, 0.65, 0.75],
    "MSBRK_RR": [1.4, 1.6, 2.0],
    "MSBRK_SL_BUFFER_ATR": [0.08, 0.12],
    "MSBRK_COOLDOWN_BARS": [3, 5],
    "MSBRK_TIME_STOP_BARS": [16, 24, 36],
    "MSBRK_MAX_SIGNALS_PER_DAY": [4, 6]
  },
  "base_env": {
    "MSBRK_ALLOW_LONGS": "1",
    "MSBRK_ALLOW_SHORTS": "1",
    "MSBRK_SESSION_START_UTC": "7",
    "MSBRK_SESSION_END_UTC": "22",
    "MSBRK_MIN_SL_ATR": "0.10",
    "MSBRK_MAX_SL_ATR": "1.0",
    "MSBRK_MIN_TP_ATR": "0.30",
    "MSBRK_VOL_MULT": "0.0",
    "MSBRK_USE_VWAP_BIAS": "1"
  },
  "constraints": {
    "min_trades": 25,
    "min_profit_factor": 1.15,
    "max_drawdown": 8.0,
    "min_net_pnl": 2.5,
    "max_negative_months": 2,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -2.5
  },
  "score_weights": {
    "net_pnl": 1.4,
    "profit_factor": 2.5,
    "winrate": 10.0,
    "max_drawdown": 1.8,
    "trades": 0.15,
    "trades_cap": 200,
    "negative_months": 3.5,
    "max_negative_streak": 2.5,
    "worst_month_pnl": 2.5
  },
  "_combo_count": "~3888 combos",
  "_goal": "First proper backtest of MicroScalperBreakoutV1. Fixes: RR≥1.4 (was 1.10), time_stop≥16 (was 8), cooldown≥3 (was 1). Probes breakout lookback and buffer sensitivity."
}
