{
  "name": "breakdown_v1_bear_failed_reclaim_sweep_v1",
  "description": "Fresh sweep for rewritten alt_inplay_breakdown_v1. The short side is no longer a mirrored inplay wrapper; it now tests real 1h support breaks with 5m failed reclaim or bearish continuation confirmation.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,DOTUSDT,LTCUSDT,ATOMUSDT",
    "--strategies",
    "alt_inplay_breakdown_v1",
    "--days",
    "360",
    "--end",
    "2026-03-27",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.01",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "grid": {
    "BREAKDOWN_SYMBOL_ALLOWLIST": [
      "BTCUSDT,ETHUSDT,SOLUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,DOTUSDT,LTCUSDT"
    ],
    "BREAKDOWN_LOOKBACK_H": [24, 48, 72],
    "BREAKDOWN_MIN_BREAK_ATR": [0.15, 0.25, 0.35],
