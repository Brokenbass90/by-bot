{
  "name": "micro_scalper_bounce_v1_grid",
  "description": "First autoresearch pass for MicroScalperBounceV1 — EMA bounce on 15m trend, entry on 5m reclaim. Fixed cooldown≥3, RR≥1.4.",
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,XRPUSDT",
    "--strategies",
    "micro_scalper_bounce_v1",
    "--days",
    "90",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "1",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10",
    "--base_interval_min",
    "5"
  ],
  "grid": {
    "MSBNC_TREND_TF": ["15", "30"],
    "MSBNC_TREND_EMA": [20, 34],
    "MSBNC_TREND_MIN_SLOPE_PCT": [0.04, 0.06, 0.08],
    "MSBNC_TOUCH_ATR": [0.08, 0.12, 0.18],
    "MSBNC_RECLAIM_ATR": [0.03, 0.05],
    "MSBNC_MIN_BODY_ATR": [0.12, 0.18, 0.25],
    "MSBNC_RR": [1.4, 1.6, 1.9],
    "MSBNC_SL_BUFFER_ATR": [0.08, 0.12],
    "MSBNC_COOLDOWN_BARS": [3, 5],
    "MSBNC_TIME_STOP_BARS": [12, 20, 30],
    "MSBNC_MAX_SIGNALS_PER_DAY": [4, 6],
    "MSBNC_USE_VWAP_BIAS": ["1"]
  },
  "base_env": {
    "MSBNC_ALLOW_LONGS": "1",
    "MSBNC_ALLOW_SHORTS": "1",
    "MSBNC_SESSION_START_UTC": "7",
    "MSBNC_SESSION_END_UTC": "22",
    "MSBNC_MIN_SL_ATR": "0.10",
    "MSBNC_MAX_SL_ATR": "1.2",
    "MSBNC_MIN_TP_ATR": "0.30",
    "MSBNC_VOL_MULT": "0.0"
  },
  "constraints": {
    "min_trades": 25,
    "min_profit_factor": 1.15,
    "max_drawdown": 8.0,
    "min_net_pnl": 2.5,
    "max_negative_months": 2,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -2.5
  },
  "score_weights": {
    "net_pnl": 1.4,
    "profit_factor": 2.5,
    "winrate": 10.0,
    "max_drawdown": 1.8,
    "trades": 0.15,
    "trades_cap": 200,
    "negative_months": 3.5,
    "max_negative_streak": 2.5,
    "worst_month_pnl": 2.5
  },
  "_combo_count": "~2592 combos",
  "_goal": "First proper backtest of MicroScalperBounceV1. Fixes: RR≥1.4 (was 1.25), cooldown≥3 (was 1). Probes trend slope, touch threshold, and hold duration sensitivity."
}
