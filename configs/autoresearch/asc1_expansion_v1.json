{
  "_comment": "ASC1 sloped channel shorts expansion: currently ATOM+LINK only. Test SOL, LTC, BNB, DOT additions.",
  "name": "asc1_expansion_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "ATOMUSDT,LINKUSDT,SOLUSDT,LTCUSDT,BNBUSDT,DOTUSDT",
    "--strategies",
    "alt_sloped_channel_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--starting_equity", "100",
    "--risk_pct", "0.005",
    "--tag",
    "{tag}"
  ],
  "base_env": {
    "ASC1_ALLOW_SHORTS": "1",
    "ASC1_ALLOW_LONGS": "0",
    "ASC1_SHORT_MIN_RSI": "60",
    "ASC1_CONFIRM_5M_BARS": "6",
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": "0.75",
    "ASC1_TRAIL_ATR_MULT": "0.0"
  },
  "grid": {
    "ASC1_SYMBOL_ALLOWLIST": [
      "ATOMUSDT,LINKUSDT",
      "SOLUSDT",
      "LTCUSDT",
      "BNBUSDT",
      "DOTUSDT",
      "ATOMUSDT,LINKUSDT,SOLUSDT",
      "ATOMUSDT,LINKUSDT,LTCUSDT",
      "ATOMUSDT,LINKUSDT,BNBUSDT",
      "ATOMUSDT,LINKUSDT,DOTUSDT",
      "ATOMUSDT,LINKUSDT,SOLUSDT,LTCUSDT",
      "ATOMUSDT,LINKUSDT,SOLUSDT,BNBUSDT",
      "SOLUSDT,LTCUSDT",
      "LINKUSDT,SOLUSDT,LTCUSDT",
      "ATOMUSDT,SOLUSDT,LTCUSDT"
    ]
  },
  "constraints": {
    "min_trades": 10,
    "min_net_pnl_pct": 5.0,
    "min_profit_factor": 1.5,
    "max_drawdown_pct": 5.0
  },
  "score_weights": {
    "net_pnl_pct": 0.30,
    "profit_factor": 0.40,
    "winrate": 0.15,
    "max_drawdown": 0.15
  }
}
