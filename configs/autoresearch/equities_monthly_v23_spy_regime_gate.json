{
    "_comment": "Equities v23: adds SPY/QQQ benchmark-min-above-sma-count gate to prevent entries in risk-off months. Previous v22 best didn't use this gate — March 2026 XOM entry (-3.79%) happened because SPY was below SMA. Grid tests count=0 (off), count=1 (SPY OR QQQ above SMA), count=2 (both above SMA). Also narrows to best-performing v22 param ranges.",
    "name": "equities_monthly_v23_spy_regime_gate",
    "cache_only": true,
    "command": [
        "{python}",
        "scripts/equities_monthly_research_sim.py",
        "--tickers",
        "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
        "--data-dir",
        "data_cache/equities_1h",
        "--top-n",
        "{TOP_N}",
        "--max-hold-days",
        "20",
        "--lookback-days",
        "40",
        "--min-mom-lookback-pct",
        "2.0",
        "--pullback-min-pct",
        "-15.0",
        "--pullback-max-pct",
        "-1.0",
        "--regime-min-breadth-sma-pct",
        "50",
        "--regime-min-breadth-mom-pct",
        "50",
        "--regime-min-avg-mom-pct",
        "2.0",
        "--earnings-csv",
        "data_cache/equities/earnings_dates.csv",
        "--earnings-blackout-days-before",
        "5",
        "--earnings-blackout-days-after",
        "2",
        "--benchmark-tickers",
        "SPY,QQQ",
        "--benchmark-data-dir",
        "data_cache/equities_1h",
        "--benchmark-lookback-days",
        "60",
        "--benchmark-min-above-sma-count",
        "{BENCHMARK_MIN_ABOVE_SMA}",
        "--corr-lookback-days",
        "60",
        "--corr-penalty-mult",
        "2.5",
        "--corr-penalty-threshold",
        "0.5",
        "--universe-top-k",
        "{UNIVERSE_TOP_K}",
        "--universe-score-lookback-days",
        "80",
        "--position-weight-mode",
        "score_inv_vol",
        "--cluster-groups",
        "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
        "--max-per-cluster",
        "1",
        "--forbid-pairs",
        "NVDA:AMD;CRWD:PANW;META:NFLX",
        "--stop-atr-mult",
        "{STOP_ATR_MULT}",
        "--target-atr-mult",
        "{TARGET_ATR_MULT}",
        "--tag",
        "{tag}"
    ],
    "field_map": {
        "trades": "trades",
        "net_pnl": "compounded_return_pct",
        "winrate": "winrate_pct",
        "max_drawdown": "max_monthly_dd_pct"
    },
    "field_scales": {
        "winrate": 0.01
    },
    "base_env": {
        "PYTHONDONTWRITEBYTECODE": "1"
    },
    "grid": {
        "BENCHMARK_MIN_ABOVE_SMA": [0, 1, 2],
        "TOP_N": [2, 3],
        "UNIVERSE_TOP_K": [7, 10],
        "STOP_ATR_MULT": [1.3, 1.5, 1.7],
        "TARGET_ATR_MULT": [2.5, 3.0, 3.5]
    },
    "constraints": {
        "min_trades": 30,
        "min_net_pnl": 45.0,
        "max_drawdown": 12.0,
        "max_negative_months": 4,
        "max_negative_streak": 2
    },
    "score_weights": {
        "net_pnl": 1.0,
        "winrate": 25.0,
        "max_drawdown": 1.5,
        "trades": 0.02,
        "trades_cap": 60,
        "negative_months": 8.0,
        "max_negative_streak": 5.0,
        "worst_month_pnl": 5.0
    }
}
