{
  "name": "impulse_volume_breakout_v1_current90_strict_v1",
  "description": "Stricter current90 search for the new impulse-volume breakout sleeve. This trims the loose/noisy part of the grid and tests whether regime-aligned, higher-quality pumps carry a cleaner long edge.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,SUIUSDT,DOGEUSDT,1000PEPEUSDT,TAOUSDT,HYPEUSDT",
    "--strategies",
    "impulse_volume_breakout_v1",
    "--days",
    "90",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "IVB1_ALLOW_LONGS": "1",
    "IVB1_REGIME_MODE": "ema",
    "IVB1_REGIME_TF": "60",
    "IVB1_BREAKOUT_LOOKBACK_BARS": "24",
    "IVB1_IMPULSE_LOOKBACK_BARS": "18",
    "IVB1_VOL_PERIOD": "20",
    "IVB1_MIN_BODY_FRAC": "0.50",
    "IVB1_MIN_BAR_RANGE_ATR": "1.4",
    "IVB1_RECLAIM_ATR": "0.10",
    "IVB1_ENTRY_BODY_MIN_FRAC": "0.30",
    "IVB1_TOUCH_BELOW_BREAKOUT_ATR": "0.15",
    "IVB1_INVALIDATION_CLOSE_ATR": "0.30",
    "IVB1_TP1_RR": "1.0",
    "IVB1_TRAIL_ATR_MULT": "1.3",
    "IVB1_TRAIL_ACTIVATE_RR": "1.0",
    "IVB1_MIN_STOP_PCT": "0.010",
    "IVB1_MAX_STOP_PCT": "0.055",
    "IVB1_TIME_STOP_BARS_5M": "60",
    "IVB1_COOLDOWN_BARS_5M": "12",
    "IVB1_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,SUIUSDT,DOGEUSDT,1000PEPEUSDT,TAOUSDT,HYPEUSDT"
  },
  "grid": {
    "IVB1_MIN_IMPULSE_PCT": [0.05, 0.07],
    "IVB1_MIN_VOL_MULT": [2.0, 2.5],
    "IVB1_BREAKOUT_BUFFER_ATR": [0.10, 0.20],
    "IVB1_RETRACE_MIN_FRAC": [0.25, 0.35],
    "IVB1_RETRACE_MAX_FRAC": [0.50, 0.60],
    "IVB1_SL_ATR": [1.0, 1.4]
  },
  "constraints": {
    "min_trades": 6,
    "min_profit_factor": 1.15,
    "max_drawdown": 7.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 2,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 6.0,
    "winrate": 3.0,
    "max_drawdown": 2.0,
    "trades": 0.12,
    "trades_cap": 80,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "2x2x2x2x2x2 = 64 combos",
  "_goal": "Search the cleaner, higher-quality end of the new long-family space instead of waiting for the loose grid to fail row by row."
}
