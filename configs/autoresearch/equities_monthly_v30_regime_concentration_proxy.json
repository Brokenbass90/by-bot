{
  "_comment": "Equities v30: regime-adaptive concentration proxy. The simulator cannot yet change TOP_N dynamically inside a month, so this spec approximates that idea by searching stricter benchmark/breadth gates together with concentration/correlation controls.",
  "name": "equities_monthly_v30_regime_concentration_proxy",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "20",
    "--lookback-days",
    "40",
    "--min-mom-lookback-pct",
    "2.0",
    "--pullback-min-pct",
    "-15.0",
    "--pullback-max-pct",
    "-1.0",
    "--regime-min-breadth-sma-pct",
    "{REGIME_MIN_BREADTH_SMA}",
    "--regime-min-breadth-mom-pct",
    "{REGIME_MIN_BREADTH_MOM}",
    "--regime-min-avg-mom-pct",
    "{REGIME_MIN_AVG_MOM}",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "{BENCHMARK_MIN_ABOVE_SMA}",
    "--corr-lookback-days",
    "60",
    "--max-pair-corr",
    "{MAX_PAIR_CORR}",
    "--corr-penalty-mult",
    "{CORR_PENALTY_MULT}",
    "--corr-penalty-threshold",
    "0.5",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "80",
    "--position-weight-mode",
    "score_inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--intramonth-portfolio-stop-pct",
    "{INTRAMONTH_STOP}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "profit_factor": "profit_factor",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "grid": {
    "BENCHMARK_MIN_ABOVE_SMA": [1, 2],
    "REGIME_MIN_BREADTH_SMA": [50, 60],
    "REGIME_MIN_BREADTH_MOM": [50, 60],
    "REGIME_MIN_AVG_MOM": [2.0, 3.0],
    "TOP_N": [2, 3],
    "UNIVERSE_TOP_K": [7, 10],
    "MAX_PAIR_CORR": [0.75, 0.85],
    "CORR_PENALTY_MULT": [2.5, 3.5],
    "STOP_ATR_MULT": [1.7],
    "TARGET_ATR_MULT": [3.5, 4.0],
    "INTRAMONTH_STOP": [0.04, 0.05]
  },
  "_combo_count": "2×2×2×2×2×2×2×2×1×2×2 = 1024 combos",
  "constraints": {
    "min_trades": 25,
    "min_net_pnl": 55.0,
    "min_profit_factor": 1.8,
    "max_drawdown": 11.0,
    "max_negative_months": 5,
    "max_negative_streak": 3
  },
  "score_weights": {
    "net_pnl": 1.6,
    "profit_factor": 3.0,
    "winrate": 20.0,
    "max_drawdown": 1.9,
    "trades": 0.02,
    "trades_cap": 70,
    "negative_months": 12.0,
    "max_negative_streak": 7.0,
    "worst_month_pnl": 8.5
  },
  "_run_command": "nohup python3 scripts/run_strategy_autoresearch.py --spec configs/autoresearch/equities_monthly_v30_regime_concentration_proxy.json > /tmp/equities_v30.log 2>&1 &",
  "_expected_runtime_minutes": 35,
  "_goal": "Approximate regime-adaptive concentration using the simulator's existing levers: stronger benchmark/breadth gating, stricter correlation controls, and tighter concentration choices."
}
