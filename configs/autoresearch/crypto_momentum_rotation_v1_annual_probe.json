{
  "name": "crypto_momentum_rotation_v1_annual_probe",
  "description": "Annual crypto medium-term momentum rotation inspired by Alpaca monthly rotation, adapted for Bybit perps with bull-regime gating and ATR trailing.",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/crypto_momentum_rotation_research.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,DOGEUSDT,XRPUSDT,BNBUSDT,AVAXUSDT,APTUSDT,NEARUSDT,AAVEUSDT,ATOMUSDT,INJUSDT,TAOUSDT,SUIUSDT",
    "--start",
    "2025-04-01",
    "--end",
    "2026-04-01",
    "--cache-dir",
    ".cache/klines",
    "--cache-only",
    "--cycle-days",
    "{CYCLE_DAYS}",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "{MAX_HOLD_DAYS}",
    "--lookback-fast",
    "{LOOKBACK_FAST}",
    "--lookback-slow",
    "{LOOKBACK_SLOW}",
    "--pullback-lookback",
    "{PULLBACK_LOOKBACK}",
    "--min-mom-fast-pct",
    "{MIN_MOM_FAST_PCT}",
    "--min-mom-slow-pct",
    "{MIN_MOM_SLOW_PCT}",
    "--pullback-min-pct",
    "{PULLBACK_MIN_PCT}",
    "--pullback-max-pct",
    "{PULLBACK_MAX_PCT}",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--trail-atr-mult",
    "{TRAIL_ATR_MULT}",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--corr-lookback-days",
    "30",
    "--max-pair-corr",
    "{MAX_PAIR_CORR}",
    "--corr-penalty-mult",
    "1.5",
    "--corr-penalty-threshold",
    "0.55",
    "--position-weight-mode",
    "score_inv_vol",
    "--require-bull-regime",
    "1",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "profit_factor": "profit_factor",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "grid": {
    "CYCLE_DAYS": [7, 10],
    "TOP_N": [3],
    "MAX_HOLD_DAYS": [8, 10],
    "LOOKBACK_FAST": [10, 14],
    "LOOKBACK_SLOW": [24, 30],
    "PULLBACK_LOOKBACK": [5],
    "MIN_MOM_FAST_PCT": [1.5, 3.0],
    "MIN_MOM_SLOW_PCT": [3.0, 6.0],
    "PULLBACK_MIN_PCT": [-15.0, -10.0],
    "PULLBACK_MAX_PCT": [-2.5, -1.0],
    "STOP_ATR_MULT": [1.8],
    "TRAIL_ATR_MULT": [2.0, 2.4],
    "UNIVERSE_TOP_K": [0, 8],
    "MAX_PAIR_CORR": [0.9]
  },
  "_combo_count": "1024 combos",
  "constraints": {
    "min_trades": 20,
    "min_net_pnl": 20.0,
    "min_profit_factor": 1.25,
    "max_drawdown": 18.0,
    "max_negative_months": 4,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 3.0,
    "winrate": 20.0,
    "max_drawdown": 1.5,
    "trades": 0.05,
    "trades_cap": 80,
    "negative_months": 12.0,
    "max_negative_streak": 8.0,
    "worst_month_pnl": 8.0
  }
}
