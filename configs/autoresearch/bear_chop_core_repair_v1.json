{
  "name": "bear_chop_core_repair_v1",
  "description": "Annual repair sweep focused on the weak bear_chop quadrant of the current core. Goal: reduce whipsaw losses from breakdown in messy down-chop while preserving the stabilizing role of flat.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,LTCUSDT,SUIUSDT,DOTUSDT",
    "--strategies",
    "alt_inplay_breakdown_v1,alt_resistance_fade_v1",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.01",
    "--leverage",
    "1",
    "--max_positions",
    "{MAX_POSITIONS}",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "BREAKDOWN_ALLOW_SHORTS": "1",
    "BREAKDOWN_ALLOW_FAILED_RECLAIM": "1",
    "BREAKDOWN_TF_BREAK": "60",
    "BREAKDOWN_TF_ENTRY": "5",
    "BREAKDOWN_LOOKBACK_H": "60",
    "BREAKDOWN_RSI_MAX": "60",
    "BREAKDOWN_BUFFER_ATR": "0.10",
    "BREAKDOWN_IMPULSE_BODY_MIN_FRAC": "0.35",
    "BREAKDOWN_RETEST_TOUCH_ATR": "0.35",
    "BREAKDOWN_RECLAIM_ATR": "0.12",
    "BREAKDOWN_ENTRY_BODY_MIN_FRAC": "0.18",
    "BREAKDOWN_MAX_DIST_ATR": "2.0",
    "BREAKDOWN_SL_ATR": "1.8",
    "BREAKDOWN_RR": "2.4",
    "BREAKDOWN_TP1_FRAC": "0.50",
    "BREAKDOWN_TIME_STOP_BARS_5M": "288",
    "BREAKDOWN_COOLDOWN_BARS_5M": "48",
    "BREAKDOWN_REGIME_MODE": "off",
    "BREAKDOWN_FLAT_FILTER_BARS_5M": "6",
    "BREAKDOWN_FLAT_FILTER_LEVEL_BAND_ATR": "0.4",
    "ARF1_SYMBOL_ALLOWLIST": "LINKUSDT,LTCUSDT,SUIUSDT",
    "ARF1_MIN_RSI": "58.0",
    "ARF1_SL_ATR_MULT": "0.85",
    "ARF1_TP1_FRAC": "0.60",
    "ARF1_TP2_BUFFER_PCT": "0.45",
    "ARF1_TRAIL_ATR_MULT": "0.0",
    "ARF1_TIME_STOP_BARS_5M": "576",
    "ARF1_REJECT_BELOW_RES_ATR": "0.12",
    "ARF1_MAX_CLOSE_VS_EMA_PCT": "1.2"
  },
  "grid": {
    "MAX_POSITIONS": [3, 4],
    "BREAKDOWN_SYMBOL_ALLOWLIST": [
      "BTCUSDT,SOLUSDT,LINKUSDT,LTCUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,LTCUSDT",
      "BTCUSDT,SOLUSDT,LINKUSDT,ADAUSDT,LTCUSDT"
    ],
    "BREAKDOWN_ALLOW_CONTINUATION": [0, 1],
    "BREAKDOWN_MIN_BREAK_ATR": [0.25, 0.35, 0.45],
    "BREAKDOWN_FRESH_BREAK_BARS_5M": [8, 12, 18],
    "BREAKDOWN_FLAT_FILTER_MAX_RANGE_ATR": [0.9, 1.1, 1.3],
    "ARF1_SYMBOL_ALLOWLIST": [
      "LINKUSDT,LTCUSDT,SUIUSDT",
      "ADAUSDT,LINKUSDT,LTCUSDT,SUIUSDT",
      "LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT"
    ],
    "ARF1_MIN_RSI": [56, 58],
    "ARF1_REJECT_BELOW_RES_ATR": [0.08, 0.10]
  },
  "constraints": {
    "min_trades": 70,
    "min_profit_factor": 1.15,
    "max_drawdown": 10.0,
    "min_net_pnl": 6.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.4,
    "profit_factor": 6.5,
    "winrate": 3.0,
    "max_drawdown": 2.8,
    "trades": 0.08,
    "trades_cap": 180,
    "negative_months": 3.5,
    "worst_month_pnl": 2.5
  },
  "_combo_count": "2x3x2x3x3x3x2x2 = 1296 combos",
  "_goal": "Repair the exact quadrant that is hurting the current core: messy bear_chop where breakdown overfires and flat does not fully offset the noise."
}
