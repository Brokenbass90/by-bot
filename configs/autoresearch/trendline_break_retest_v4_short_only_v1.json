{
  "name": "trendline_break_retest_v4_short_only_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "trendline_break_retest_v4",
    "--days",
    "360",
    "--end",
    "2026-03-15",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "2",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "grid": {
    "SYMBOLS": [
      "LTCUSDT",
      "SUIUSDT",
      "ATOMUSDT",
      "LINKUSDT",
      "LTCUSDT,SUIUSDT",
      "LINKUSDT,ATOMUSDT"
    ],
    "TLB4_MIN_TOUCHES": [2, 3],
    "TLB4_BREAKOUT_ATR_MULT": [0.20, 0.25, 0.30],
    "TLB4_MIN_BREAKOUT_EXT_ATR": [0.15, 0.20],
    "TLB4_RETEST_PULLBACK_ATR": [0.35, 0.45],
    "TLB4_RETEST_MIN_BODY_FRAC": [0.18, 0.22],
    "TLB4_VOL_BREAKOUT_MULT": [1.0, 1.1],
    "TLB4_TREND_MIN_GAP_PCT": [0.10, 0.14]
  },
  "base_env": {
    "TLB4_ALLOW_LONGS": "0",
    "TLB4_ALLOW_SHORTS": "1",
    "TLB4_MAX_CONS_RANGE_ATR": "2.6",
    "TLB4_RETEST_WINDOW_BARS": "14",
    "TLB4_TREND_MIN_SLOPE_PCT": "0.04",
    "TLB4_SL_ATR_MULT": "1.00",
    "TLB4_RR": "1.9",
    "BACKTEST_CACHE_ONLY": "1"
  },
  "constraints": {
    "min_trades": 4,
    "min_profit_factor": 1.10,
    "max_drawdown": 4.8,
    "min_net_pnl": 1.0,
    "max_negative_months": 3,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -1.4
  },
  "score_weights": {
    "net_pnl": 2.0,
    "profit_factor": 2.5,
    "winrate": 8.0,
    "max_drawdown": 1.4,
    "trades": 0.08,
    "trades_cap": 40,
    "negative_months": 2.0,
    "max_negative_streak": 2.0,
    "worst_month_pnl": 2.0
  }
}
