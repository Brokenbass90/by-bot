{
    "name": "ivb1_wider_universe_v1",
    "description": "Expand IVB1 symbol universe to increase trade frequency. Current best: PF=1.48 WR=57% but only 14 trades/year on 3 symbols. Target: 40+ trades/year while preserving quality.",
    "cache_only": true,
    "command": [
        "{python}",
        "backtest/run_portfolio.py",
        "--symbols",
        "{SYMBOLS}",
        "--strategies",
        "impulse_volume_breakout_v1",
        "--days",
        "360",
        "--end",
        "2026-04-01",
        "--tag",
        "{tag}",
        "--starting_equity",
        "100",
        "--risk_pct",
        "0.0075",
        "--leverage",
        "1",
        "--max_positions",
        "3",
        "--fee_bps",
        "6",
        "--slippage_bps",
        "2"
    ],
    "base_env": {
        "IVB1_REGIME_MODE": "off",
        "IVB1_SL_ATR": "0.8",
        "IVB1_RETRACE_MIN_FRAC": "0.10"
    },
    "grid": {
        "SYMBOLS": [
            "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT",
            "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
            "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,ADAUSDT",
            "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,LTCUSDT",
            "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,ADAUSDT,LTCUSDT"
        ],
        "IVB1_MIN_VOL_MULT": [1.2, 1.3, 1.4],
        "IVB1_RETRACE_MAX_FRAC": [0.35, 0.40, 0.45],
        "IVB1_BREAKOUT_BUFFER_ATR": [0.0, 0.05],
        "IVB1_RR": [1.4, 1.6, 2.0]
    },
    "constraints": {
        "min_trades": 20,
        "min_profit_factor": 1.2,
        "min_net_pnl": 3.0,
        "max_neg_months": 5,
        "max_neg_streak": 3
    }
}
