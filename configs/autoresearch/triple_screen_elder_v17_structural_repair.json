    "TS132_OSC_PERIOD": [6],
    "TS132_OSC_OB": [64, 68],
    "TS132_SL_ATR_MULT": [1.8, 2.0],
    "TS132_TP_ATR_MULT": [3.5, 4.5],
    "TS132_BE_PCT": [0.8],
    "TS132_TIME_STOP_BARS_5M": [288],
    "TS132_MAX_SIGNALS_PER_DAY": [3, 4],
    "TS132_TRAIL_ATR_MULT_SHORT": [1.2, 1.4],
    "TS132_TRAIL_ACTIVATE_SHORT_ATR": [2.0, 2.5],
    "TS132_USE_VOL_FILTER": ["0"],
    "TS132_VOL_MULT": [0.5],
    "TS132_EXEC_MODE": ["eth"]
