  "_combo_count": "2×2×2×2×2×2×2×2 = 256 combos",
  "_run_command": "nohup python3 scripts/run_strategy_autoresearch.py --spec configs/autoresearch/triple_screen_elder_v17_structural_repair.json > /tmp/elder_v17.log 2>&1 &",
  "_expected_runtime_minutes": 8,
  "_goal": "Use a more canonical multi-timeframe Elder structure to see if the strategy can keep v15's smoother month profile while recovering net and trade density."
}
