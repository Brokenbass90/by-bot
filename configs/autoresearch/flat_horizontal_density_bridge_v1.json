{
  "name": "flat_horizontal_density_bridge_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "alt_resistance_fade_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--tag",
    "{tag}"
  ],
  "grid": {
    "SYMBOLS": [
      "LINKUSDT,SUIUSDT",
      "LTCUSDT,SUIUSDT",
      "LINKUSDT,LTCUSDT,SUIUSDT"
    ],
    "ARF1_MAX_CLOSE_VS_EMA_PCT": [1.0, 1.1, 1.2],
    "ARF1_MIN_RSI": [54, 56, 58, 60],
    "ARF1_REJECT_BELOW_RES_ATR": [0.06, 0.08, 0.10],
    "ARF1_SL_ATR_MULT": [0.75, 0.85, 0.95],
    "ARF1_TIME_STOP_BARS_5M": [360, 432, 576, 720]
  },
  "base_env": {
    "ARF1_SYMBOL_ALLOWLIST": "LINKUSDT,LTCUSDT,SUIUSDT"
  },
  "constraints": {
    "min_trades": 5,
    "min_profit_factor": 1.15,
    "max_drawdown": 4.0,
    "min_net_pnl": 2.0,
    "max_negative_months": 2,
    "max_negative_streak": 1,
    "min_worst_month_pnl": -1.5
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 3.0,
    "winrate": 12.0,
    "max_drawdown": 1.0,
    "trades": 0.08,
    "trades_cap": 40,
    "negative_months": 2.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 1.5
  }
}
