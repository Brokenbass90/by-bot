{
  "name": "inplay_scalper_minute_probe_v3_relaxed",
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,DOGEUSDT,XRPUSDT,ADAUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout",
    "--days",
    "90",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "1",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10",
    "--base_interval_min",
    "1"
  ],
  "grid": {
    "BREAKOUT_TF_BREAK": [5],
    "BREAKOUT_TF_ENTRY": [1, 3],
    "BREAKOUT_LOOKBACK_H": [1, 2, 4],
    "BREAKOUT_IMPULSE_ATR_MULT": [0.30, 0.45, 0.60],
    "BREAKOUT_IMPULSE_BODY_MIN_FRAC": [0.10, 0.20],
    "BREAKOUT_RETEST_TOUCH_ATR": [0.16, 0.24],
    "BREAKOUT_RECLAIM_ATR": [0.02, 0.04],
    "BREAKOUT_MAX_DIST_ATR": [1.2, 1.8],
    "BREAKOUT_RR": [1.2, 1.5]
  },
  "base_env": {
    "BREAKOUT_ALLOW_LONGS": "1",
    "BREAKOUT_ALLOW_SHORTS": "1",
    "BREAKOUT_BUFFER_ATR": "0.02",
    "BREAKOUT_SL_ATR": "0.36",
    "BREAKOUT_MIN_HOLD_BARS": "0",
    "BREAKOUT_MAX_RETEST_BARS": "36",
    "BREAKOUT_MIN_BREAK_BARS": "0",
    "BREAKOUT_RANGE_ATR_MAX": "10.0",
    "BREAKOUT_REGIME_MODE": "off",
    "BREAKOUT_MAX_LATE_VS_REF_PCT": "0.35",
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": "0.00",
    "BREAKOUT_REF_LOOKBACK_BARS": "24"
  },
  "constraints": {
    "min_trades": 25,
    "min_profit_factor": 1.05,
    "max_drawdown": 10.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 4,
    "max_negative_streak": 3,
    "min_worst_month_pnl": -3.0
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 2.6,
    "winrate": 9.0,
    "max_drawdown": 1.5,
    "trades": 0.2,
    "trades_cap": 180,
    "negative_months": 3.0,
    "max_negative_streak": 2.2,
    "worst_month_pnl": 2.2
  }
}
