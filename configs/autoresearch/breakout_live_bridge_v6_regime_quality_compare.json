{
  "_comment": "Bounded recent-window repair for live InPlay breakout. Keep the proven live-like geometry, but test whether regime filter + HTF volume confirmation + fresher retests improve recent 90d behavior in the current choppy/bearish market.",
  "name": "breakout_live_bridge_v6_regime_quality_compare",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,AVAXUSDT,DOGEUSDT,XRPUSDT,ADAUSDT,DOTUSDT,LTCUSDT",
    "--strategies",
    "inplay_breakout",
    "--days",
    "90",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "2",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "1.5",
    "BREAKOUT_ALLOW_SHORTS": "0",
    "BREAKOUT_CHOP_ER_MIN": "0.20",
    "BREAKOUT_IMPULSE_ATR_MULT": "1.00",
    "BREAKOUT_IMPULSE_BODY_MIN_FRAC": "0.35",
    "BREAKOUT_MAX_CHASE_PCT": "0.13",
    "BREAKOUT_MAX_LATE_VS_REF_PCT": "0.35",
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": "0.07",
    "BREAKOUT_RECLAIM_ATR": "0.12",
    "BREAKOUT_MAX_DIST_ATR": "1.40",
    "BREAKOUT_BUFFER_ATR": "0.12",
    "BREAKOUT_REGIME_TF": "240",
    "BREAKOUT_REGIME_EMA_FAST": "21",
    "BREAKOUT_REGIME_EMA_SLOW": "55",
    "BREAKOUT_REGIME_STRICT": "1",
    "BT_BREAKOUT_QUALITY_ENABLE": "1",
    "BT_BREAKOUT_QUALITY_MIN_SCORE": "0.53"
  },
  "grid": {
    "BREAKOUT_REGIME_MODE": ["off", "ema"],
    "BREAKOUT_IMPULSE_VOL_MULT": [0.0, 1.2],
    "BREAKOUT_MAX_RETEST_BARS": [30, 15],
    "BREAKOUT_MIN_HOLD_BARS": [0, 2]
  },
  "constraints": {
    "min_trades": 15,
    "min_profit_factor": 1.05,
    "max_drawdown": 10.0,
    "min_net_pnl": 0.0
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 4.5,
    "winrate": 6.0,
    "max_drawdown": 2.0,
    "trades": 0.2,
    "trades_cap": 90
  },
  "_combo_count": "2x2x2x2 = 16 combos",
  "_goal": "Answer one practical question for the current market: does stricter regime/volume/retest quality materially improve recent InPlay breakout behavior versus the current permissive live profile?"
}
