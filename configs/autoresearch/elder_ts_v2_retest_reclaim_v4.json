{
  "name": "elder_ts_v2_retest_reclaim_v4",
  "description": "Elder Triple Screen v2 rebuilt around entry-TF retest/reclaim instead of raw breakout. Focused recent180 rescue run for crypto trend continuation.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
    "--strategies",
    "elder_triple_screen_v2",
    "--days",
    "180",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ETS2_ALLOW_LONGS": "1",
    "ETS2_ALLOW_SHORTS": "1",
    "ETS2_TREND_TF": "240",
    "ETS2_TREND_EMA": "21",
    "ETS2_TREND_SLOPE_BARS": "2",
    "ETS2_WAVE_TF": "60",
    "ETS2_OSC_TYPE": "stoch",
    "ETS2_OSC_PERIOD": "14",
    "ETS2_ENTRY_TF": "60",
    "ETS2_ENTRY_LOOKBACK": "4",
    "ETS2_RISK_TF": "60",
    "ETS2_ENTRY_RETEST_BARS": "2",
    "ETS2_TRAIL_ATR_MULT": "1.8",
    "ETS2_TIME_STOP_BARS_5M": "864",
    "ETS2_COOLDOWN_BARS_5M": "48",
    "ETS2_MAX_SIGNALS_PER_DAY": "2",
    "ETS2_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT"
  },
  "grid": {
    "ETS2_OSC_OB": [60, 65],
    "ETS2_OSC_OS": [35, 40],
    "ETS2_ENTRY_TOUCH_ATR_MULT": [0.1, 0.25, 0.4],
    "ETS2_ENTRY_MIN_BODY_FRAC": [0.2, 0.3, 0.4],
    "ETS2_SL_ATR_MULT": [2.0, 3.0],
    "ETS2_TP_ATR_MULT": [3.0, 5.0]
  },
  "constraints": {
    "min_trades": 10,
    "min_profit_factor": 1.10,
    "max_drawdown": 10.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 2,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.6,
    "profit_factor": 5.0,
    "winrate": 4.0,
    "max_drawdown": 2.0,
    "trades": 0.10,
    "trades_cap": 80,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  }
}
