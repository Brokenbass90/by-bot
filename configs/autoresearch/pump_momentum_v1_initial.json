{
  "name": "pump_momentum_v1_initial",
  "description": "Initial parameter search for pump_momentum_v1 (long-only pump rider). Tests across a broad 360-day window to find combinations where riding pump impulses with trailing stop produces a positive edge. Focus: is there a stable long-side edge on alt-coin pumps across different market regimes?",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,AVAXUSDT,DOGEUSDT,XRPUSDT,ADAUSDT,DOTUSDT,LTCUSDT",
    "--strategies",
    "pump_momentum_v1",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "15"
  ],
  "grid": {
    "PM_MIN_PUMP_PCT": [0.06, 0.08, 0.12],
    "PM_VOL_MULT": [2.0, 3.0],
    "PM_SL_ATR_MULT": [1.5, 2.0, 2.5],
    "PM_RR": [1.5, 2.0],
    "PM_TRAIL_ATR_MULT": [1.5, 2.5],
    "PM_TIME_STOP_BARS": [48, 96, 192]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0",
    "PM_INTERVAL_MIN": "5",
    "PM_LOOKBACK_BARS": "12",
    "PM_MAX_PUMP_PCT": "0.60",
    "PM_VOL_PERIOD": "20",
    "PM_REQUIRE_BULLISH": "1",
    "PM_MIN_BODY_FRAC": "0.30",
    "PM_ATR_PERIOD": "14",
    "PM_MIN_STOP_PCT": "0.02",
    "PM_MAX_STOP_PCT": "0.15",
    "PM_TRAIL_ACTIVATE_RR": "1.0",
    "PM_COOLDOWN_BARS": "24"
  },
  "constraints": {
    "min_trades": 20,
    "min_profit_factor": 1.2,
    "max_drawdown": 12.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 4,
    "max_negative_streak": 3
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 4.0,
    "winrate": 8.0,
    "max_drawdown": 1.5,
    "trades": 0.05,
    "trades_cap": 120,
    "negative_months": 2.0,
    "max_negative_streak": 1.5,
    "worst_month_pnl": 2.0
  },
  "_combo_count": "3×2×3×2×2×3 = 216 combos",
  "_goal": "Discover whether catching the pump on the long side (before reversal) has a positive risk-adjusted edge. Key question: does volume-confirmed momentum entry + ATR trailing stop outperform random entry? If PF>1.2 found on 360d, proceed to bear-window split test to check regime sensitivity."
}
