    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "IVB1_ALLOW_LONGS": "1",
    "IVB1_REGIME_MODE": "off",
    "IVB1_BREAKOUT_LOOKBACK_BARS": "24",
