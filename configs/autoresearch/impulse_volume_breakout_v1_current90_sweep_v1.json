  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 6.0,
    "winrate": 3.0,
    "max_drawdown": 2.0,
    "trades": 0.15,
    "trades_cap": 100,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "2x2x2x2x2x2x2 = 128 combos",
  "_goal": "Find a new long sleeve that trades explosive continuation better than the old breakout reclaim family."
