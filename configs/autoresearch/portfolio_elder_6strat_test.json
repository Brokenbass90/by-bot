  "_combo_count_estimate": "2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 = 128 combos",
  "_run_command": "python3 scripts/run_strategy_autoresearch.py --spec configs/autoresearch/portfolio_elder_6strat_test.json",
  "_expected_runtime_minutes": 15,
  "_baseline": "golden 5-strat: PnL=+100.93%, PF=2.078, DD=3.65%, trades=446",
