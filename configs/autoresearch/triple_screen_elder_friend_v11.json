  "grid": {
    "SYMBOLS": [
      "ETHUSDT,AVAXUSDT,SOLUSDT",
      "ETHUSDT,AVAXUSDT,SOLUSDT,LINKUSDT",
      "BTCUSDT,ETHUSDT,AVAXUSDT",
      "ETHUSDT,AVAXUSDT"
