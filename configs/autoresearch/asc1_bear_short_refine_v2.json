{
  "name": "asc1_bear_short_refine_v2",
  "description": "Focused short-only sloped-channel research for bear/chop. Treat ASC1 as a real descending/flat channel short sleeve with better slope-direction guards, upper-band rejection quality and earlier exits.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "ATOMUSDT,LINKUSDT,ADAUSDT,DOGEUSDT,XRPUSDT,SOLUSDT",
    "--strategies",
    "alt_sloped_channel_v1",
    "--days",
    "180",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ASC1_ALLOW_LONGS": "0",
    "ASC1_ALLOW_SHORTS": "1",
    "ASC1_SIGNAL_TF": "60",
    "ASC1_SIGNAL_LOOKBACK": "96",
    "ASC1_MIN_CHANNEL_WIDTH_PCT": "4.0",
    "ASC1_MAX_CHANNEL_WIDTH_PCT": "22.0",
    "ASC1_MAX_ABS_SLOPE_PCT": "3.0",
    "ASC1_MIN_ABS_SLOPE_PCT": "0.05",
    "ASC1_SHORT_MAX_POS_SLOPE_PCT": "0.0",
    "ASC1_TOUCH_BUFFER_ATR": "0.35",
    "ASC1_RECLAIM_ATR": "0.12",
    "ASC1_REJECT_ATR": "0.12",
    "ASC1_SHORT_MAX_NEAR_UPPER_BARS": "3",
    "ASC1_SHORT_VOL_AVG_BARS": "20",
    "ASC1_TP1_FRAC": "0.55",
    "ASC1_TIME_STOP_BARS_5M": "480",
    "ASC1_COOLDOWN_BARS_5M": "72",
    "ASC1_SYMBOL_ALLOWLIST": "ATOMUSDT,LINKUSDT,ADAUSDT,DOGEUSDT,XRPUSDT,SOLUSDT"
  },
  "grid": {
    "ASC1_MIN_RANGE_R2": [0.35, 0.45],
    "ASC1_CONFIRM_5M_BARS": [3, 6],
    "ASC1_SHORT_MIN_RSI": [58, 62],
    "ASC1_SHORT_MIN_REJECT_DEPTH_ATR": [0.65, 0.85],
    "ASC1_SHORT_MIN_UPPER_WICK_FRAC": [0.0, 0.25],
    "ASC1_SHORT_MIN_REJECT_VOL_MULT": [0.0, 1.05],
    "ASC1_SL_ATR_MULT": [0.9, 1.2],
    "ASC1_TP2_BUFFER_PCT": [15.0, 35.0],
    "ASC1_TRAIL_ATR_MULT": [0.0, 1.2]
  },
  "constraints": {
    "min_trades": 12,
    "min_profit_factor": 1.15,
    "max_drawdown": 7.0,
    "min_net_pnl": 4.0,
    "max_negative_months": 2,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.6,
    "profit_factor": 5.0,
    "winrate": 6.0,
    "max_drawdown": 2.0,
    "trades": 0.12,
    "trades_cap": 100,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "2x2x2x2x2x2x2x2x2 = 512 combos",
  "_goal": "Answer whether sloped short channels are truly weak, or whether the current sleeve just needs stricter slope-direction and rejection-quality logic."
}
