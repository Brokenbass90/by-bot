{
  "name": "breakout_side_split_probe_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,ATOMUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "BREAKOUT_ALLOW_LONGS": ["1", "1", "0"],
    "BREAKOUT_ALLOW_SHORTS": ["1", "0", "1"],
    "BT_BREAKOUT_QUALITY_ENABLE": ["1"],
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.54],
    "BREAKOUT_MAX_CHASE_PCT": [0.14],
    "BREAKOUT_MAX_LATE_VS_REF_PCT": [0.35],
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": [0.04],
    "BREAKOUT_IMPULSE_ATR_MULT": [1.0],
    "BREAKOUT_RECLAIM_ATR": [0.12],
    "BREAKOUT_MAX_DIST_ATR": [1.30],
    "BREAKOUT_BUFFER_ATR": [0.12]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0"
  },
  "constraints": {
    "min_trades": 60,
    "min_profit_factor": 1.10,
    "max_drawdown": 6.0,
    "min_net_pnl": 8.0,
    "max_negative_months": 4,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -2.0
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.4,
    "trades": 0.05,
    "trades_cap": 400,
    "negative_months": 4.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 3.0
  }
}
