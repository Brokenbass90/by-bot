{
  "_comment": "Bounded compare for the live InPlay breakout sleeve. Focus on the already-proven weak-chop profile and compare only the regime/chop/time-stop/RR layer instead of running another blind sweep.",
  "name": "breakout_live_bridge_v4_regime_exit_compare",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,ATOMUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout,btc_eth_midterm_pullback",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "BT_BREAKOUT_QUALITY_ENABLE": ["1"],
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.53],
    "BREAKOUT_IMPULSE_ATR_MULT": [0.95, 1.00],
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": [0.05, 0.07],
    "BREAKOUT_RECLAIM_ATR": [0.10, 0.12],
    "BREAKOUT_BUFFER_ATR": [0.10, 0.12],
    "BREAKOUT_CHOP_ER_MIN": [0.18, 0.22],
    "BREAKOUT_RR": [1.20, 1.35, 1.50]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0",
    "BREAKOUT_ALLOW_SHORTS": "0",
    "BREAKOUT_REGIME_MODE": "ema",
    "BREAKOUT_TIME_STOP_BARS": "96",
    "BREAKOUT_MAX_CHASE_PCT": "0.13",
    "BREAKOUT_MAX_LATE_VS_REF_PCT": "0.35",
    "BREAKOUT_MAX_DIST_ATR": "1.40"
  },
  "constraints": {
    "min_trades": 320,
    "min_profit_factor": 1.34,
    "max_drawdown": 4.0,
    "min_net_pnl": 20.5,
    "max_negative_months": 2,
    "max_negative_streak": 1,
    "min_worst_month_pnl": -1.5
  },
  "score_weights": {
    "net_pnl": 1.1,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.9,
    "trades": 0.07,
    "trades_cap": 520,
    "negative_months": 5.0,
    "max_negative_streak": 4.0,
    "worst_month_pnl": 5.0
  },
  "_combo_count": "2x2x2x2x2x3 = 96 combos",
  "_goal": "Decide whether the live breakout sleeve improves more from stronger regime/chop gating and a cleaner RR/time-stop profile than from further shrinking entry timeframe."
}
