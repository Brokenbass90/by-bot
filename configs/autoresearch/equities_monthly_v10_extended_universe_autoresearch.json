{
  "name": "equities_monthly_v10_extended_universe_autoresearch",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AAPL,ADBE,AMD,AMZN,AVGO,CRWD,GOOGL,JPM,META,MSFT,NFLX,NVDA,ORCL,PANW,PLTR,TSLA,UBER,XOM",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "{MAX_HOLD_DAYS}",
    "--lookback-days",
    "{LOOKBACK_DAYS}",
    "--min-mom-lookback-pct",
    "{MIN_MOM_LOOKBACK_PCT}",
    "--pullback-min-pct",
    "{PULLBACK_MIN_PCT}",
    "--pullback-max-pct",
    "{PULLBACK_MAX_PCT}",
    "--regime-min-breadth-sma-pct",
    "55",
    "--regime-min-breadth-mom-pct",
    "55",
    "--regime-min-avg-mom-pct",
    "2",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ,IWM",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--corr-lookback-days",
    "{CORR_LOOKBACK_DAYS}",
    "--corr-penalty-mult",
    "{CORR_PENALTY_MULT}",
    "--corr-penalty-threshold",
    "0.45",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "1",
    "--benchmark-min-positive-mom-count",
    "{BENCHMARK_MIN_POSITIVE_MOM_COUNT}",
    "--benchmark-min-avg-mom-pct",
    "{BENCHMARK_MIN_AVG_MOM_PCT}",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "{UNIVERSE_SCORE_LOOKBACK_DAYS}",
    "--position-weight-mode",
    "inv_vol",
    "--cluster-groups",
    "AAPL,MSFT,GOOGL,AMZN;NVDA,AMD,AVGO;META,NFLX;CRWD,PANW;JPM,XOM;PLTR,UBER",
    "--max-per-cluster",
    "1",
    "--forbid-pairs",
    "NVDA:AMD;CRWD:PANW;META:NFLX",
    "--stop-atr-mult",
    "{STOP_ATR_MULT}",
    "--target-atr-mult",
    "{TARGET_ATR_MULT}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "grid": {
    "TOP_N": [2, 3],
    "MAX_HOLD_DAYS": [12, 15],
    "LOOKBACK_DAYS": [50, 70],
    "MIN_MOM_LOOKBACK_PCT": [1.0, 2.0],
    "PULLBACK_MIN_PCT": [-18.0, -12.0],
    "PULLBACK_MAX_PCT": [-1.5, -0.5],
    "STOP_ATR_MULT": [1.5, 2.0],
    "TARGET_ATR_MULT": [2.5, 3.5],
    "CORR_LOOKBACK_DAYS": [40, 60],
    "CORR_PENALTY_MULT": [4.0, 5.5],
    "BENCHMARK_MIN_POSITIVE_MOM_COUNT": [1, 2],
    "BENCHMARK_MIN_AVG_MOM_PCT": [0.75, 1.25],
    "UNIVERSE_TOP_K": [4, 6, 8],
    "UNIVERSE_SCORE_LOOKBACK_DAYS": [40, 60]
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "constraints": {
    "min_trades": 24,
    "min_net_pnl": 55.0,
    "max_drawdown": 12.0,
    "max_negative_months": 4,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -6.0
  },
  "score_weights": {
    "net_pnl": 1.0,
    "winrate": 22.0,
    "max_drawdown": 1.2,
    "trades": 0.02,
    "trades_cap": 40,
    "negative_months": 5.0,
    "max_negative_streak": 5.0,
    "worst_month_pnl": 3.0
  }
}
