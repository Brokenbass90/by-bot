{
  "name": "triple_screen_elder_friend_v12_focus",
  "description": "TS132 Elder v12 — bounded smoothness repair around the trade-rich v11 pockets. Keep the profitable 4H trend structure from the best ETH/AVAX(+BTC) variants, then test whether long-only bias, shorter time-stop, gentler BE/trail, and lower daily signal caps can reduce negative months without collapsing net.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "triple_screen_v132",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--tag",
    "{tag}"
  ],
  "grid": {
    "SYMBOLS": [
      "BTCUSDT,ETHUSDT,AVAXUSDT",
      "ETHUSDT,AVAXUSDT"
    ],
    "TS132_ALLOW_LONGS": ["1"],
    "TS132_ALLOW_SHORTS": ["0", "1"],
    "TS132_TRADE_MODE": ["active"],
    "TS132_TREND_TF": ["240"],
    "TS132_EVAL_TF_MIN": [60],
    "TS132_TREND_EMA_LEN": [45],
    "TS132_OSC_OB": [68],
    "TS132_OSC_PERIOD": [6],
    "TS132_SL_ATR_MULT": [2.0],
    "TS132_TP_ATR_MULT": [6.0, 9.0],
    "TS132_BE_PCT": [0.6, 1.0],
    "TS132_TIME_STOP_BARS_5M": [216, 288, 432],
    "TS132_MAX_SIGNALS_PER_DAY": [2, 3],
    "TS132_TRAIL_ATR_MULT_LONG": [1.2, 1.5],
    "TS132_TRAIL_ATR_MULT_SHORT": [1.6, 2.0],
    "TS132_TRAIL_ACTIVATE_LONG_ATR": [2.0, 3.0],
    "TS132_TRAIL_ACTIVATE_SHORT_ATR": [3.0],
    "TS132_USE_VOL_FILTER": ["0"],
    "TS132_VOL_MULT": [0.5],
    "TS132_EXEC_MODE": ["optimistic", "eth"]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1"
  },
  "constraints": {
    "min_trades": 24,
    "min_profit_factor": 1.5,
    "max_drawdown": 5.0,
    "min_net_pnl": 10.0,
    "max_negative_months": 4,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -2.5
  },
  "score_weights": {
    "net_pnl": 1.2,
    "profit_factor": 4.0,
    "winrate": 8.0,
    "max_drawdown": 1.8,
    "trades": 0.08,
    "trades_cap": 80,
    "negative_months": 4.0,
    "max_negative_streak": 3.0,
    "worst_month_pnl": 3.0
  }
}
