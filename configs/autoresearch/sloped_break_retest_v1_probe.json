{
  "_comment": "Probe a new sloped-channel breakout->retest family built from ASC1 slope logic plus explicit retest confirmation.",
  "name": "sloped_break_retest_v1_probe",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "sloped_break_retest_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--tag",
    "{tag}"
  ],
  "base_env": {
    "SBR1_SIGNAL_TF": "60",
    "SBR1_SIGNAL_LOOKBACK": "96",
    "SBR1_ATR_PERIOD": "14",
    "SBR1_VOL_PERIOD": "20",
    "SBR1_MAX_CHANNEL_WIDTH_PCT": "22.0",
    "SBR1_MAX_ABS_SLOPE_PCT": "2.8",
    "SBR1_MIN_BREAKOUT_EXT_ATR": "0.12",
    "SBR1_MIN_BREAKOUT_BODY_FRAC": "0.34",
    "SBR1_BREAKOUT_VOL_MULT": "1.00",
    "SBR1_RECLAIM_HOLD_ATR": "0.05",
    "SBR1_RETEST_MIN_BODY_FRAC": "0.24",
    "SBR1_RETEST_VOL_MULT": "0.80",
    "SBR1_INVALIDATION_ATR": "0.35",
    "SBR1_TREND_EMA_FAST": "20",
    "SBR1_TREND_EMA_SLOW": "50",
    "SBR1_TREND_MIN_GAP_PCT": "0.08",
    "SBR1_TP1_RR": "1.10",
    "SBR1_TP1_FRAC": "0.50",
    "SBR1_TP2_FRAC": "0.30",
    "SBR1_BE_TRIGGER_RR": "1.0",
    "SBR1_BE_LOCK_RR": "0.05",
    "SBR1_TRAIL_ATR_PERIOD": "14",
    "SBR1_TIME_STOP_BARS_5M": "216",
    "SBR1_COOLDOWN_TF_BARS": "4",
    "SBR1_MAX_SIGNALS_PER_DAY": "2",
    "SBR1_ALLOW_LONGS": "1",
    "SBR1_ALLOW_SHORTS": "1",
    "BACKTEST_CACHE_ONLY": "1"
  },
  "grid": {
    "SYMBOLS": [
      "BTCUSDT,ETHUSDT,SOLUSDT,AVAXUSDT",
      "LINKUSDT,ATOMUSDT,LTCUSDT,BCHUSDT",
      "ADAUSDT,DOTUSDT,SUIUSDT,LINKUSDT",
      "SOLUSDT,AVAXUSDT,LINKUSDT,SUIUSDT"
    ],
    "SBR1_MIN_CHANNEL_WIDTH_PCT": ["3.5", "5.0"],
    "SBR1_MIN_R2": ["0.18", "0.26"],
    "SBR1_BREAKOUT_ATR_MULT": ["0.10", "0.18", "0.26"],
    "SBR1_RETEST_WINDOW_BARS": ["4", "8"],
    "SBR1_RETEST_TOUCH_ATR": ["0.15", "0.25"],
    "SBR1_SL_ATR_MULT": ["1.00", "1.25"],
    "SBR1_TP2_RR": ["2.2", "3.0"],
    "SBR1_TRAIL_ATR_MULT": ["1.4", "1.8"]
  },
  "constraints": {
    "min_trades": 12,
    "min_profit_factor": 1.25,
    "max_drawdown_pct": 7.0,
    "min_net_pnl": 4.0,
    "max_negative_months": 4,
    "max_negative_streak": 3,
    "min_worst_month_pnl": -3.0
  },
  "score_weights": {
    "net_pnl": 2.0,
    "profit_factor": 2.4,
    "winrate": 5.0,
    "max_drawdown": 1.7,
    "trades": 0.10,
    "trades_cap": 60,
    "negative_months": 2.0,
    "max_negative_streak": 1.8,
    "worst_month_pnl": 1.6
  }
}
