{
  "name": "micro_scalper_bounce_v1_probe",
  "description": "Research-only bounce scalper probe: 5m reclaim from EMA zone in the direction of a 15m trend, tuned to survive weak-chop better than the old hybrid micro scalper.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols", "{SYMBOLS}",
    "--strategies", "micro_scalper_bounce_v1",
    "--days", "360",
    "--end", "2026-02-24",
    "--starting_equity", "100",
    "--risk_pct", "0.005",
    "--tag", "{tag}"
  ],
  "base_env": {
    "MSBNC_TREND_TF": "15",
    "MSBNC_TREND_EMA": "20",
    "MSBNC_TREND_LOOKBACK": "30",
    "MSBNC_TREND_MIN_SLOPE_PCT": "0.05",
    "MSBNC_ENTRY_LOOKBACK": "50",
    "MSBNC_ENTRY_EMA": "9",
    "MSBNC_ATR_PERIOD": "14",
    "MSBNC_VOL_MULT": "0.0",
    "MSBNC_MAX_SIGNALS_PER_DAY": "6",
    "MSBNC_COOLDOWN_BARS": "3",
    "MSBNC_SESSION_START_UTC": "7",
    "MSBNC_SESSION_END_UTC": "22",
    "MSBNC_MIN_SL_ATR": "0.12",
    "MSBNC_MAX_SL_ATR": "1.2",
    "MSBNC_TIME_STOP_BARS": "12",
    "MSBNC_ALLOW_LONGS": "1",
    "MSBNC_ALLOW_SHORTS": "1"
  },
  "grid": {
    "SYMBOLS": [
      "BTCUSDT,ETHUSDT,SOLUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT"
    ],
    "MSBNC_TOUCH_ATR": ["0.08", "0.12", "0.16"],
    "MSBNC_RECLAIM_ATR": ["0.02", "0.05"],
    "MSBNC_MIN_BODY_ATR": ["0.14", "0.18"],
    "MSBNC_MIN_WICK_ATR": ["0.06", "0.10"],
    "MSBNC_RR": ["1.25", "1.40", "1.50"],
    "MSBNC_SL_BUFFER_ATR": ["0.08", "0.12"],
    "MSBNC_COOLDOWN_BARS": ["2", "3"]
  },
  "_combo_count": "288 combos",
  "constraints": {
    "min_trades": 120,
    "min_profit_factor": 1.25,
    "max_drawdown": 8.0,
    "min_net_pnl": 8.0,
    "max_negative_months": 4
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 4.0,
    "winrate": 8.0,
    "max_drawdown": 1.5
  },
  "_expected_runtime_minutes": 12,
  "_goal": "Find out whether a reclaim-style bounce scalper can keep frequency high enough while filtering out noise and wick-driven losses better than the old hybrid micro scalper."
}
