    "SRV1_RETEST_TOUCH_ATR": ["0.15", "0.25"],
    "SRV1_RECLAIM_HOLD_ATR": ["0.03", "0.08"],
    "SRV1_RETEST_VOL_MULT": ["0.70", "0.85"],
    "SRV1_SL_ATR_MULT": ["1.10", "1.30"],
    "SRV1_TP2_RR": ["2.2", "2.8"],
    "SRV1_TRAIL_ATR_MULT": ["1.4", "1.8"]
  },
  "base_env": {
    "SRV1_TREND_EMA_FAST": "20",
    "SRV1_TREND_EMA_SLOW": "50",
    "SRV1_SR_LOOKBACK_BARS": "48",
    "SRV1_ATR_PERIOD": "14",
    "SRV1_VOL_PERIOD": "20",
    "SRV1_INVALIDATION_ATR": "0.35",
    "SRV1_TP1_RR": "1.1",
    "SRV1_TP1_FRAC": "0.50",
    "SRV1_TP2_FRAC": "0.30",
    "SRV1_BE_TRIGGER_RR": "1.0",
    "SRV1_BE_LOCK_RR": "0.05",
    "SRV1_TRAIL_ATR_PERIOD": "14",
    "SRV1_TIME_STOP_BARS_5M": "216",
    "SRV1_COOLDOWN_BARS": "10",
    "SRV1_MAX_SIGNALS_PER_DAY": "2",
    "SRV1_ALLOW_LONGS": "1",
    "SRV1_ALLOW_SHORTS": "1",
    "BACKTEST_CACHE_ONLY": "1"
  },
  "constraints": {
    "min_trades": 14,
    "min_profit_factor": 1.25,
    "max_drawdown": 6.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 4,
    "max_negative_streak": 3,
    "min_worst_month_pnl": -2.5
  },
  "score_weights": {
    "net_pnl": 2.0,
    "profit_factor": 2.5,
    "winrate": 6.0,
    "max_drawdown": 1.6,
    "trades": 0.12,
    "trades_cap": 60,
    "negative_months": 2.2,
    "max_negative_streak": 2.0,
    "worst_month_pnl": 1.6
  }
