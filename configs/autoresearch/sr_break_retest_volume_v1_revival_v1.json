{
  "name": "sr_break_retest_volume_v1_revival_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "sr_break_retest_volume_v1",
    "--days",
    "360",
    "--end",
    "2026-03-27",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "2",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "grid": {
    "SYMBOLS": [
      "BTCUSDT,ETHUSDT,SOLUSDT",
      "BTCUSDT,ETHUSDT,AVAXUSDT",
      "SOLUSDT,AVAXUSDT,LINKUSDT",
      "SOLUSDT,LINKUSDT,SUIUSDT"
    ],
    "SRV1_TREND_TF": ["60", "240"],
    "SRV1_TREND_MIN_GAP_PCT": ["0.12", "0.20"],
