{
  "name": "breakout_live_bridge_v3_density",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,ATOMUSDT,AVAXUSDT",
    "--strategies",
    "inplay_breakout,btc_eth_midterm_pullback",
    "--days",
    "360",
    "--end",
    "2026-03-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "BT_BREAKOUT_QUALITY_ENABLE": ["1"],
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.53, 0.54, 0.55],
    "BREAKOUT_MAX_CHASE_PCT": [0.13, 0.14, 0.15],
    "BREAKOUT_MAX_LATE_VS_REF_PCT": [0.35, 0.40],
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": [0.05, 0.06, 0.07],
    "BREAKOUT_IMPULSE_ATR_MULT": [1.00, 1.05],
    "BREAKOUT_RECLAIM_ATR": [0.12, 0.15],
    "BREAKOUT_MAX_DIST_ATR": [1.35, 1.40, 1.45],
    "BREAKOUT_BUFFER_ATR": [0.12]
  },
  "base_env": {
    "BACKTEST_CACHE_ONLY": "1",
    "BYBIT_DATA_POLITE_SLEEP_SEC": "2.0"
  },
  "constraints": {
    "min_trades": 320,
    "min_profit_factor": 1.34,
    "max_drawdown": 4.0,
    "min_net_pnl": 19.5,
    "max_negative_months": 2,
    "max_negative_streak": 1,
    "min_worst_month_pnl": -1.0
  },
  "score_weights": {
    "net_pnl": 1.1,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.9,
    "trades": 0.07,
    "trades_cap": 520,
    "negative_months": 5.0,
    "max_negative_streak": 4.0,
    "worst_month_pnl": 5.0
  }
}
