{
  "name": "equities_monthly_v9_red_month_push",
  "cache_only": true,
  "command": [
    "{python}",
    "scripts/equities_monthly_research_sim.py",
    "--tickers",
    "AMD,GOOGL,META,NVDA,TSLA",
    "--data-dir",
    "data_cache/equities_1h",
    "--top-n",
    "{TOP_N}",
    "--max-hold-days",
    "15",
    "--lookback-days",
    "70",
    "--min-mom-lookback-pct",
    "1.5",
    "--pullback-min-pct",
    "-16.0",
    "--pullback-max-pct",
    "-1.0",
    "--regime-min-breadth-sma-pct",
    "55",
    "--regime-min-breadth-mom-pct",
    "55",
    "--regime-min-avg-mom-pct",
    "2",
    "--earnings-csv",
    "data_cache/equities/earnings_dates.csv",
    "--earnings-blackout-days-before",
    "5",
    "--earnings-blackout-days-after",
    "2",
    "--benchmark-tickers",
    "SPY,QQQ",
    "--benchmark-data-dir",
    "data_cache/equities_1h",
    "--corr-lookback-days",
    "{CORR_LOOKBACK_DAYS}",
    "--corr-penalty-mult",
    "{CORR_PENALTY_MULT}",
    "--corr-penalty-threshold",
    "0.45",
    "--benchmark-lookback-days",
    "60",
    "--benchmark-min-above-sma-count",
    "1",
    "--benchmark-min-positive-mom-count",
    "{BENCHMARK_MIN_POSITIVE_MOM_COUNT}",
    "--benchmark-min-avg-mom-pct",
    "{BENCHMARK_MIN_AVG_MOM_PCT}",
    "--universe-top-k",
    "{UNIVERSE_TOP_K}",
    "--universe-score-lookback-days",
    "20",
    "--position-weight-mode",
    "inv_vol",
    "--stop-atr-mult",
    "1.5",
    "--target-atr-mult",
    "2.5",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "grid": {
    "TOP_N": [1, 2],
    "CORR_LOOKBACK_DAYS": [40, 60],
    "CORR_PENALTY_MULT": [3.5, 4.5, 5.5],
    "BENCHMARK_MIN_POSITIVE_MOM_COUNT": [1, 2],
    "BENCHMARK_MIN_AVG_MOM_PCT": [0.75, 1.0, 1.25],
    "UNIVERSE_TOP_K": [2, 3, 4]
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "constraints": {
    "min_trades": 24,
    "min_net_pnl": 65.0,
    "max_drawdown": 10.0,
    "max_negative_months": 3,
    "max_negative_streak": 2,
    "min_worst_month_pnl": -5.5
  },
  "score_weights": {
    "net_pnl": 1.0,
    "winrate": 22.0,
    "max_drawdown": 1.0,
    "trades": 0.02,
    "trades_cap": 40,
    "negative_months": 5.0,
    "max_negative_streak": 5.0,
    "worst_month_pnl": 3.0
  }
}
