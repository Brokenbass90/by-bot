    "--intramonth-portfolio-stop-pct",
    "{INTRAMONTH_STOP}",
    "--tag",
    "{tag}"
  ],
  "field_map": {
    "trades": "trades",
    "net_pnl": "compounded_return_pct",
    "profit_factor": "profit_factor",
    "winrate": "winrate_pct",
    "max_drawdown": "max_monthly_dd_pct"
  },
  "field_scales": {
    "winrate": 0.01
  },
  "base_env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "grid": {
    "BENCHMARK_MIN_ABOVE_SMA": [1, 2],
    "REGIME_MIN_BREADTH_MOM": [60, 70],
    "REGIME_MIN_AVG_MOM": [2.0, 3.0],
    "MAX_PAIR_CORR": [0.75],
    "CORR_PENALTY_MULT": [2.5, 3.5],
    "INTRAMONTH_STOP": [0.04, 0.05],
    "MAX_HOLD_DAYS": [15, 20],
    "LOOKBACK_DAYS": [30, 40],
    "MIN_MOM_LOOKBACK_PCT": [3.0, 5.0],
    "PULLBACK_MIN_PCT": [-12.0],
    "PULLBACK_MAX_PCT": [-3.0, -1.0]
  },
  "_combo_count": "256 combos",
  "constraints": {
    "min_trades": 25,
    "min_net_pnl": 60.0,
    "min_profit_factor": 1.9,
    "max_drawdown": 11.0,
    "max_negative_months": 4,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.5,
    "profit_factor": 3.0,
    "winrate": 20.0,
    "max_drawdown": 2.0,
    "trades": 0.02,
    "trades_cap": 60,
    "negative_months": 14.0,
    "max_negative_streak": 9.0,
    "worst_month_pnl": 10.0
  },
  "_expected_runtime_minutes": 15,
  "_goal": "Reduce frequent red months by avoiding late, exhausted momentum entries rather than just tightening stops again."
}
