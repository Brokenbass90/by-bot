{
  "name": "elder_ts_v2_recent180_focus_v3",
  "description": "Focused recent180 rescue attempt for Elder Triple Screen v2. Tests the core hypothesis that Elder in crypto needs slower entry/risk timeframes and less absurd TP distance, instead of micro-ATR stops against a 4H trend.",
  "cache_only": false,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
    "--strategies",
    "elder_triple_screen_v2",
    "--days",
    "180",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ETS2_ALLOW_LONGS": "1",
    "ETS2_ALLOW_SHORTS": "1",
    "ETS2_TREND_TF": "240",
    "ETS2_TREND_EMA": "21",
    "ETS2_TREND_SLOPE_BARS": "2",
    "ETS2_WAVE_TF": "60",
    "ETS2_OSC_TYPE": "stoch",
    "ETS2_OSC_PERIOD": "14",
    "ETS2_ENTRY_TF": "60",
    "ETS2_ENTRY_LOOKBACK": "3",
    "ETS2_TRAIL_ATR_MULT": "1.8",
    "ETS2_TIME_STOP_BARS_5M": "864",
    "ETS2_COOLDOWN_BARS_5M": "48",
    "ETS2_MAX_SIGNALS_PER_DAY": "2",
    "ETS2_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT"
  },
  "grid": {
    "ETS2_RISK_TF": ["60", "240"],
    "ETS2_OSC_OB": [60, 65, 70],
    "ETS2_OSC_OS": [30, 35, 40],
    "ETS2_SL_ATR_MULT": [2.0, 3.0, 4.0],
    "ETS2_TP_ATR_MULT": [3.0, 5.0, 7.0]
  },
  "constraints": {
    "min_trades": 12,
    "min_profit_factor": 1.10,
    "max_drawdown": 10.0,
    "min_net_pnl": 3.0,
    "max_negative_months": 2,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.6,
    "profit_factor": 5.0,
    "winrate": 4.0,
    "max_drawdown": 2.0,
    "trades": 0.10,
    "trades_cap": 80,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "2x3x3x3x3 = 162 combos",
  "_goal": "Give Elder one honest rescue pass on slower crypto-relevant timing before we decide whether it needs logic surgery, not just parameter tuning."
}
