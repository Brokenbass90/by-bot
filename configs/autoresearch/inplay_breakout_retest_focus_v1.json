{
  "_comment": "Retest-focused inplay breakout frontier. Goal: test ARIA-like cascade breakouts with strict late-entry control and real pullback/reclaim instead of blind breakout chasing.",
  "name": "inplay_breakout_retest_focus_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "inplay_breakout",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "3",
    "--max_positions",
    "3",
    "--fee_bps",
    "10",
    "--slippage_bps",
    "10"
  ],
  "grid": {
    "SYMBOLS": [
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,DOGEUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT,DOGEUSDT,XRPUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT,DOTUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,AVAXUSDT,ATOMUSDT,DOTUSDT"
    ],
    "BT_BREAKOUT_QUALITY_MIN_SCORE": [0.48, 0.54],
    "BREAKOUT_RETEST_TOUCH_ATR": [0.20, 0.30, 0.35],
    "BREAKOUT_RECLAIM_ATR": [0.08, 0.12, 0.15],
    "BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT": [0.08, 0.12, 0.18],
    "BREAKOUT_MAX_LATE_VS_REF_PCT": [0.15, 0.25],
    "BREAKOUT_ENTRY_BODY_MIN_FRAC": [0.15, 0.30]
  },
  "base_env": {
    "BT_BREAKOUT_QUALITY_ENABLE": "1",
    "BREAKOUT_ALLOW_SHORTS": "0",
    "BREAKOUT_BUFFER_ATR": "0.12",
    "BREAKOUT_IMPULSE_ATR_MULT": "1.0",
    "BREAKOUT_MAX_DIST_ATR": "1.2",
    "BACKTEST_CACHE_ONLY": "1"
  },
  "constraints": {
    "min_trades": 40,
    "min_profit_factor": 1.25,
    "max_drawdown": 6.0,
    "min_net_pnl": 10.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.0,
    "profit_factor": 5.0,
    "winrate": 15.0,
    "max_drawdown": 1.5,
    "trades": 0.04,
    "trades_cap": 300,
    "negative_months": 3.0,
    "max_negative_streak": 2.5
  }
}
