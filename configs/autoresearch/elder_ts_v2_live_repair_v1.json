{
  "name": "elder_ts_v2_live_repair_v1",
  "description": "Focused rescue run for Elder Triple Screen v2 after live wiring and more realistic crypto defaults. Goal: verify that Elder can generate a usable flow of signals before any deeper rewrite.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
    "--strategies",
    "elder_triple_screen_v2",
    "--days",
    "180",
    "--end",
    "2026-04-08",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "ETS2_ALLOW_LONGS": "1",
    "ETS2_ALLOW_SHORTS": "1",
    "ETS2_TREND_TF": "240",
    "ETS2_TREND_EMA": "13",
    "ETS2_TREND_SLOPE_BARS": "3",
    "ETS2_WAVE_TF": "60",
    "ETS2_OSC_TYPE": "rsi",
    "ETS2_OSC_PERIOD": "8",
    "ETS2_ENTRY_TF": "15",
    "ETS2_ENTRY_LOOKBACK": "5",
    "ETS2_RISK_TF": "60",
    "ETS2_ENTRY_TOUCH_ATR_MULT": "0.25",
    "ETS2_ENTRY_MIN_BODY_FRAC": "0.30",
    "ETS2_SL_ATR_MULT": "2.0",
    "ETS2_TRAIL_ATR_MULT": "1.0",
    "ETS2_TIME_STOP_BARS_5M": "576",
    "ETS2_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT"
  },
  "grid": {
    "ETS2_OSC_OB": [56, 58, 60],
    "ETS2_OSC_OS": [40, 42, 45],
    "ETS2_ENTRY_RETEST_BARS": [4, 5, 6],
    "ETS2_TP_ATR_MULT": [2.2, 2.5, 3.0],
    "ETS2_COOLDOWN_BARS_5M": [12, 18],
    "ETS2_MAX_SIGNALS_PER_DAY": [10, 20]
  },
  "constraints": {
    "min_trades": 8,
    "min_profit_factor": 1.05,
    "max_drawdown": 12.0,
    "min_net_pnl": 2.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.4,
    "profit_factor": 5.5,
    "winrate": 4.0,
    "max_drawdown": 2.0,
    "trades": 0.10,
    "trades_cap": 80,
    "negative_months": 1.6,
    "worst_month_pnl": 1.6
  },
  "_combo_count": "3x3x3x3x2x2 = 324 combos",
  "_goal": "Check whether live-ready Elder defaults can generate a sane signal flow on crypto before we spend more time on structural rewrites."
}
