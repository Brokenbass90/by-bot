{
  "_comment": "Breakdown shorts expansion: test adding LINK+ATOM to BTC+ETH+SOL universe. Also test RR/SL variants.",
  "name": "breakdown_expansion_v1",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT,BNBUSDT",
    "--strategies",
    "alt_inplay_breakdown_v1",
    "--days",
    "360",
    "--end",
    "2026-02-24",
    "--starting_equity", "100",
    "--risk_pct", "0.005",
    "--tag",
    "{tag}"
  ],
  "base_env": {
    "ENABLE_BREAKDOWN_TRADING": "1",
    "BREAKDOWN_ALLOW_LONGS": "0",
    "BREAKDOWN_ALLOW_SHORTS": "1",
    "BREAKDOWN_REGIME_MODE": "off",
    "BREAKDOWN_LOOKBACK_H": "48",
    "BREAKDOWN_RR": "2.0",
    "BREAKDOWN_SL_ATR": "1.8",
    "BREAKDOWN_MAX_DIST_ATR": "2.0",
    "BREAKDOWN_MAX_OPEN_TRADES": "1"
  },
  "grid": {
    "BREAKDOWN_SYMBOL_ALLOWLIST": [
      "BTCUSDT,ETHUSDT,SOLUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,ATOMUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT",
      "ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT",
      "BTCUSDT,ETHUSDT",
      "BTCUSDT",
      "SOLUSDT,LINKUSDT,ATOMUSDT"
    ]
  },
  "constraints": {
    "min_trades": 20,
    "min_net_pnl_pct": 5.0,
    "min_profit_factor": 1.3,
    "max_drawdown_pct": 8.0
  },
  "score_weights": {
    "net_pnl_pct": 0.35,
    "profit_factor": 0.35,
    "winrate": 0.15,
    "max_drawdown": 0.15
  }
}
