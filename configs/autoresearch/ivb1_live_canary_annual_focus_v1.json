{
  "name": "ivb1_live_canary_annual_focus_v1",
  "description": "Focused annual validation for IVB1 around the strongest annual cluster and the current live-canary neighborhood. Goal: verify a higher-frequency breakout/retrace configuration before the next live retune.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "impulse_volume_breakout_v1",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.0075",
    "--leverage",
    "1",
    "--max_positions",
    "3",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "IVB1_REGIME_MODE": "off",
    "IVB1_SL_ATR": "0.8",
    "IVB1_RETRACE_MIN_FRAC": "0.10"
  },
  "grid": {
    "SYMBOLS": [
      "BTCUSDT,ETHUSDT,SOLUSDT",
      "DOGEUSDT,LINKUSDT,SOLUSDT",
      "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT"
    ],
    "IVB1_MIN_VOL_MULT": [1.3, 1.4, 1.5],
    "IVB1_BREAKOUT_BUFFER_ATR": [0.0, 0.05],
    "IVB1_RETRACE_MAX_FRAC": [0.35, 0.40],
    "IVB1_RR": [1.4, 1.6]
  },
  "constraints": {
    "min_trades": 72,
    "min_profit_factor": 1.45,
    "max_drawdown": 5.0,
    "min_net_pnl": 8.0,
    "max_negative_months": 3,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.3,
    "profit_factor": 6.0,
    "winrate": 4.5,
    "max_drawdown": 2.0,
    "trades": 0.10,
    "trades_cap": 120,
    "negative_months": 2.0,
    "worst_month_pnl": 1.5
  },
  "_combo_count": "3x3x2x2x2 = 72 combos",
  "_goal": "Promote a more active IVB1 annual-safe cluster by validating the strongest breakout/retrace settings on the most relevant live universes."
}
