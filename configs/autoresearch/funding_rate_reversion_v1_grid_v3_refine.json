    "FR_EXT_PCT":              [0.002, 0.003, 0.005],
    "FR_RSI_OB":               [62.0, 65.0, 68.0],
    "FR_SL_ATR_MULT":          [0.8, 1.0],
    "FR_TP_ATR_MULT":          [2.0, 2.5, 3.0],
    "FR_TIME_STOP_BARS_5M":    [72, 96],
    "FR_COOLDOWN_BARS":        [24],
    "FR_MIN_VOLUME_USDT":      [500000]
