{
  "name": "core3_range_additivity_annual_v1",
  "description": "Full-year truth test for core2 + alt_range_scalp_v1. Same additive idea as the recent180 package, but forced through a 360d window so we can see whether range_scalp survives outside the lucky recent pocket.",
  "cache_only": true,
  "command": [
    "{python}",
    "backtest/run_portfolio.py",
    "--symbols",
    "BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT,ATOMUSDT",
    "--strategies",
    "alt_inplay_breakdown_v1,alt_resistance_fade_v1,alt_range_scalp_v1",
    "--days",
    "360",
    "--end",
    "2026-04-01",
    "--tag",
    "{tag}",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.01",
    "--leverage",
    "1",
    "--max_positions",
    "{MAX_POSITIONS}",
    "--fee_bps",
    "6",
    "--slippage_bps",
    "2"
  ],
  "base_env": {
    "BREAKDOWN_SYMBOL_ALLOWLIST": "BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT",
    "BREAKDOWN_ALLOW_SHORTS": "1",
    "BREAKDOWN_ALLOW_FAILED_RECLAIM": "1",
    "BREAKDOWN_ALLOW_CONTINUATION": "1",
    "BREAKDOWN_TF_BREAK": "60",
    "BREAKDOWN_TF_ENTRY": "5",
    "BREAKDOWN_LOOKBACK_H": "60",
    "BREAKDOWN_RSI_MAX": "60",
    "BREAKDOWN_BUFFER_ATR": "0.10",
    "BREAKDOWN_MIN_BREAK_ATR": "0.25",
    "BREAKDOWN_IMPULSE_BODY_MIN_FRAC": "0.35",
    "BREAKDOWN_RETEST_TOUCH_ATR": "0.35",
    "BREAKDOWN_RECLAIM_ATR": "0.12",
    "BREAKDOWN_ENTRY_BODY_MIN_FRAC": "0.18",
    "BREAKDOWN_MAX_DIST_ATR": "2.0",
    "BREAKDOWN_SL_ATR": "1.8",
    "BREAKDOWN_RR": "2.4",
    "BREAKDOWN_TP1_FRAC": "0.50",
    "BREAKDOWN_TIME_STOP_BARS_5M": "288",
    "BREAKDOWN_COOLDOWN_BARS_5M": "48",
    "BREAKDOWN_REGIME_MODE": "off",
    "BREAKDOWN_FRESH_BREAK_BARS_5M": "12",
    "BREAKDOWN_FLAT_FILTER_BARS_5M": "6",
    "BREAKDOWN_FLAT_FILTER_MAX_RANGE_ATR": "1.2",
    "BREAKDOWN_FLAT_FILTER_LEVEL_BAND_ATR": "0.4",
    "ARF1_SYMBOL_ALLOWLIST": "ADAUSDT,LINKUSDT,LTCUSDT,DOTUSDT,SUIUSDT",
    "ARF1_MIN_RSI": "58.0",
    "ARF1_SL_ATR_MULT": "0.85",
    "ARF1_TP1_FRAC": "0.60",
    "ARF1_TP2_BUFFER_PCT": "0.45",
    "ARF1_TRAIL_ATR_MULT": "0.0",
    "ARF1_TIME_STOP_BARS_5M": "576",
    "ARF1_REJECT_BELOW_RES_ATR": "0.12",
    "ARF1_MAX_CLOSE_VS_EMA_PCT": "1.2",
    "ARS1_BB_PERIOD": "20",
    "ARS1_BB_STD": "2.0",
    "ARS1_MIN_BAND_WIDTH_PCT": "2.5",
    "ARS1_RSI_LONG_MAX": "35",
    "ARS1_RSI_SHORT_MIN": "65",
    "ARS1_SL_ATR_MULT": "0.8",
    "ARS1_ALLOW_LONGS": "1",
    "ARS1_ALLOW_SHORTS": "1",
    "ARS1_MAX_BAND_WIDTH_PCT": "20.0",
    "ARS1_TP1_FRAC": "0.55"
  },
  "grid": {
    "MAX_POSITIONS": [4, 5, 6],
    "ARS1_SYMBOL_ALLOWLIST": [
      "DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT",
      "DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT,ADAUSDT",
      "DOTUSDT,LTCUSDT,SUIUSDT,ATOMUSDT,LINKUSDT"
    ],
    "ARS1_TIME_STOP_BARS_5M": [144, 216]
  },
  "constraints": {
    "min_trades": 150,
    "min_profit_factor": 1.25,
    "max_drawdown": 16.0,
    "min_net_pnl": 10.0,
    "max_negative_months": 4,
    "max_negative_streak": 2
  },
  "score_weights": {
    "net_pnl": 1.1,
    "profit_factor": 6.0,
    "winrate": 3.0,
    "max_drawdown": 2.0,
    "trades": 0.10,
    "trades_cap": 260,
    "negative_months": 2.5,
    "worst_month_pnl": 2.0
  },
  "_combo_count": "3x3x2 = 18 combos",
  "_goal": "Force the range_scalp package through a full-year reality check before any promotion discussion."
}
