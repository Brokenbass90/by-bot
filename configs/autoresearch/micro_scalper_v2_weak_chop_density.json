    "backtest/run_portfolio.py",
    "--symbols",
    "{SYMBOLS}",
    "--strategies",
    "micro_scalper_v1",
    "--days",
    "180",
    "--end",
    "2026-02-24",
    "--starting_equity",
    "100",
    "--risk_pct",
    "0.005",
    "--tag",
    "{tag}"
