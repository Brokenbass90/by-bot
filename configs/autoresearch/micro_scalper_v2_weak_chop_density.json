  "_combo_count": "2×3×3×3×2×2×2×2×2 = 1728 combos",
  "_run_command": "nohup python3 scripts/run_strategy_autoresearch.py --spec configs/autoresearch/micro_scalper_v2_weak_chop_density.json > /tmp/micro_scalper_v2.log 2>&1 &",
  "_expected_runtime_minutes": 30,
  "_goal": "Test whether a more active 5m EMA pullback sleeve can add trade density and monetization in weak-chop / tradable-impulse conditions without becoming pure fee-burning noise."
}
