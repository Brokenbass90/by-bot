## Regime overlay: bull_trend
## Apply when orchestrator_state.json shows regime=bull_trend
## Activates: breakout(OFF until retune), support_bounce(ON), midterm(ON), sloped longs+shorts(ON)
## Deactivates: fade(REDUCED), breakdown(OFF)

## === BREAKOUT (OFF until retune) ===
ENABLE_BREAKOUT_TRADING=0

## === BREAKDOWN (OFF in bull trend) ===
ENABLE_BREAKDOWN_TRADING=0

## === RESISTANCE FADE — REDUCED (fades don't work as well in strong bull) ===
ENABLE_FLAT_TRADING=1
ARF1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,DOTUSDT
ARF1_TIME_STOP_BARS_5M=288

## === SUPPORT BOUNCE — PRIMARY in bull trend ===
ENABLE_BOUNCE_TRADING=1
ASB1_SYMBOL_ALLOWLIST=ADAUSDT,SUIUSDT,LINKUSDT,DOTUSDT,LTCUSDT,SOLUSDT
ASB1_MAX_RSI=42.0
ASB1_SIGNAL_LOOKBACK=72
ASB1_SL_ATR_MULT=0.85

## === MIDTERM — FULL (BTC/ETH pullbacks work well in bull) ===
ENABLE_MIDTERM_TRADING=1
MIDTERM_SYMBOLS=BTCUSDT,ETHUSDT

## === SLOPED CHANNEL — BOTH SIDES in bull ===
## Longs: require rising/flat channel (LONG_MAX_NEG_SLOPE_PCT=0.0 = no decline allowed).
## Shorts: allow up to 0.8%/day positive slope (default permissive).
## Lower R2 than bear_chop — accept slightly noisier channels in bull.
ENABLE_SLOPED_TRADING=1
ASC1_ALLOW_LONGS=1
ASC1_ALLOW_SHORTS=1
ASC1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,ATOMUSDT,SUIUSDT
ASC1_MIN_RANGE_R2=0.40
ASC1_LONG_MAX_NEG_SLOPE_PCT=0.0
ASC1_SHORT_MAX_POS_SLOPE_PCT=0.80
ASC1_CONFIRM_5M_BARS=2

## === RANGE SCALP — ON (still works in bull chop pockets) ===
ARS1_ALLOW_LONGS=1
ARS1_ALLOW_SHORTS=1

## === ELDER TS v2 — LONGS only in bull ===
ETS2_ALLOW_LONGS=1
ETS2_ALLOW_SHORTS=0

## === v7 NEW SLEEVES — bull_trend ===
## breakdown_v2: OFF (short-only strategy, wrong side in bull)
ENABLE_BREAKDOWN2_TRADING=0

## slope_choch: OFF (bearish CHOCH signals unreliable in bull trend)
ENABLE_SLOPE_CHOCH_TRADING=0

## liq_cascade: longs only — panic dip buys work well in bull
ENABLE_LC_TRADING=1
LC_ALLOW_LONGS=1
LC_ALLOW_SHORTS=0

## funding_rev: active in any regime
ENABLE_FR_TRADING=1

## micro_scalp: longs only in bull trend
ENABLE_MSCALP_TRADING=1
MSCALP_ALLOW_LONGS=1
MSCALP_ALLOW_SHORTS=0
