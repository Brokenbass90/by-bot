# Broad-market dynamic intraday equities experiment.
# Intentionally leaves INTRADAY_DYNAMIC_SYMBOL_POOL empty so the builder
# discovers every cached equity symbol and ranks the full cache.

INTRADAY_CONFIG_FILE=configs/intraday_config_broad.json
INTRADAY_DATA_DIR=data_cache/equities_1h
INTRADAY_DYNAMIC_SYMBOL_POOL=
INTRADAY_DYNAMIC_MAX_SYMBOLS=14
INTRADAY_DYNAMIC_BREAKOUT_TARGET=7
INTRADAY_DYNAMIC_REVERSION_TARGET=7
INTRADAY_DYNAMIC_MIN_AVG_DOLLAR_VOL=15000000
INTRADAY_DYNAMIC_BREAKOUT_CLASS=breakout_continuation:quality_guard
INTRADAY_DYNAMIC_REVERSION_CLASS=grid_reversion:safe_winrate

# Research helpers used by the segmented annual runner.
EQ_WF_TOP_N=10
EQ_MIN_TRADES=15
