# ─────────────────────────────────────────────────────────────
# Alpaca intraday — конфиг для $1000 капитала
# Логика: fractional shares + 3 позиции + умеренный риск
# ─────────────────────────────────────────────────────────────

# Notional на позицию: ~15% капитала = $150
# 3 позиции × $150 = $450 = 45% капитала (безопасно)
INTRADAY_NOTIONAL_USD=150

# Максимум 3 одновременных позиции
INTRADAY_MAX_POSITIONS=3

# Дневной стоп-лосс: 2.5% от $1000 = $25
INTRADAY_MAX_DAILY_LOSS_PCT=2.5

# SPY gate — не торгуем против общего рынка
INTRADAY_SPY_GATE=1
INTRADAY_SPY_SMA_PERIOD=50

# Equity curve gate — защита от затяжных просадок
INTRADAY_EQUITY_CURVE_GATE=1
INTRADAY_EQUITY_CURVE_DAYS=10

# Символы: топ-8 ликвидных акций
INTRADAY_SYMBOLS=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,AMD

# Разделение по стратегиям
INTRADAY_BREAKOUT_SYMBOLS=NVDA,AMD,TSLA
INTRADAY_REVERSION_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,META

# Fractional shares — обязательно для NVDA ($800+)
ALPACA_FRACTIONAL_SHARES=1

# Динамический watchlist — выключить для малого счёта
INTRADAY_DYNAMIC_BUILD=0

# ─────────────────────────────────────────────────────────────
# ОЖИДАЕМЫЕ РЕЗУЛЬТАТЫ при $1000:
#   Сделок: 8-15 в неделю (3-5 breakout + 5-10 reversion)
#   Средняя прибыль на сделку при PF=1.4: ~$1.20-2.00
#   Цель: 2-4% в месяц = $20-40
#   Макс просадка: 6-10% = $60-100
#   Срок до удвоения: 18-36 месяцев (реалистично)
#
# ПОЧЕМУ $150 notional, а не $333:
#   При $333 notional и tight SL ($5-8 на акцию) qty_raw >> cap =>
#   MIN_NOTIONAL_FILL_FRAC отсекает сделки (тот же баг что у VSM1).
#   $150 = разумный баланс: хватает на fractional qty без отсечения.
# ─────────────────────────────────────────────────────────────
