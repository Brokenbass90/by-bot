    {
      "name": "flat_frequency",
      "spec": "configs/autoresearch/flat_frequency_repair_v1.json",
      "enabled": true,
      "min_interval_hours": 24
    },
    {
      "name": "impulse_annual_repair",
      "spec": "configs/autoresearch/impulse_volume_breakout_v1_annual_repair_v1.json",
      "enabled": true,
      "min_interval_hours": 24
    }
