## Reconstructed baseline snapshot v3.
## Purpose:
## - keep v2 as the current reproducible golden candidate
## - replace only breakout execution with the stronger bounded density frontier
## - reduce v2 breakout overtrading while preserving the exact historical symbol union

ENABLE_BREAKOUT_TRADING=1
ENABLE_MIDTERM_TRADING=1
ENABLE_SLOPED_TRADING=1
ENABLE_FLAT_TRADING=1
ENABLE_BREAKDOWN_TRADING=1
ENABLE_TS132_TRADING=0

ASC1_ALLOW_LONGS=0
