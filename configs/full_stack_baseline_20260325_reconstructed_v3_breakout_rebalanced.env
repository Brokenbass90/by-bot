ARF1_REJECT_BELOW_RES_ATR=0.12
ARF1_MIN_RSI=58
ARF1_MAX_CLOSE_VS_EMA_PCT=1.2
ARF1_TIME_STOP_BARS_5M=576
ARF1_SL_ATR_MULT=0.85
ARF1_TP1_FRAC=0.60
ARF1_TP2_BUFFER_PCT=0.45
ARF1_TRAIL_ATR_MULT=0.0

BREAKDOWN_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT
BREAKDOWN_ALLOW_LONGS=0
BREAKDOWN_ALLOW_SHORTS=1
BREAKDOWN_REGIME_MODE=off
BREAKDOWN_LOOKBACK_H=48
BREAKDOWN_RR=2.0
BREAKDOWN_SL_ATR=1.8
