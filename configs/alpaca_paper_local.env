ALPACA_API_SECRET_KEY=8XRpaZcwwENV5uAGiN1a441Hr8kubj7h7FeTGaz5Qc7h
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Trading mode ──────────────────────────────────────────────────
# PAPER trading (safe - no real money)
# Step 1: SEND_ORDERS=0 = dry-run (just log, no orders) → check picks + API
# Step 2: SEND_ORDERS=1 = paper orders (real API calls, fake money)
ALPACA_SEND_ORDERS=1
ALPACA_CLOSE_STALE_POSITIONS=1   # sell positions NOT in current month picks

# ── Position sizing ────────────────────────────────────────────────
ALPACA_MAX_POSITIONS=2
ALPACA_TARGET_ALLOC_PCT=0.45
ALPACA_MIN_DOLLAR_ORDER=50
ALPACA_CAPITAL_OVERRIDE_USD=500
ALPACA_MAX_PICK_AGE_DAYS=45
ALPACA_ALLOW_STALE_PICKS=0

# ── Auto-picks: autopilot refreshes this automatically ────────────
# ALPACA_PICKS_CSV=...   ← set by autopilot script, don't hardcode
# ALPACA_PICKS_MONTH=2026-03   ← auto-detected from picks CSV

# ── Monthly cron (set on server via: crontab -e) ──────────────────
# Run refresh + paper bridge on 1st of each month at 09:30 UTC (US market open)
# 30 9 1 * * cd /root/by-bot && bash scripts/run_equities_alpaca_monthly_autopilot.sh >> logs/alpaca_monthly.log 2>&1

ALPACA_AUTOPILOT_REFRESH=1