## Breakout allowlist v2 canary for LIVE
## Goal: replace weak/unproven symbols with year-validated leaders from the
## breakout frequency branch while keeping the validated signal profile.
## Use with: set -a; source configs/breakout_allowv2_canary.env; set +a

ENABLE_INPLAY_TRADING=0
ENABLE_BREAKOUT_TRADING=1
ENABLE_RETEST_TRADING=0
ENABLE_PUMP_FADE_TRADING=0
ENABLE_MIDTERM_TRADING=0
ENABLE_RANGE_TRADING=0

# Keep the breakout universe fixed to the validated 16-symbol set.
BREAKOUT_TOP_N=16
BREAKOUT_TRY_EVERY_SEC=30

# Route breakout through a proven allowlist instead of hot/new names.
SYMBOL_FILTERS_PATH=/tmp/bybot_symbol_filters.json
SYMBOL_ALLOWLIST=RIVERUSDT,FARTCOINUSDT,HYPEUSDT,OPUSDT,VIRTUALUSDT,AVAXUSDT,DOTUSDT,SNXUSDT,BCHUSDT,ENAUSDT,JTOUSDT,1000PEPEUSDT,ARBUSDT,DOGEUSDT,ADAUSDT,TAOUSDT
SYMBOL_DENYLIST=

# Risk unchanged.
RISK_PER_TRADE_PCT=0.5

# Same validated breakout profile used in the fixed-window replays.
BREAKOUT_IMPULSE_ATR_MULT=0.75
BREAKOUT_IMPULSE_BODY_MIN_FRAC=0.40
BREAKOUT_QUALITY_MIN_SCORE=0.52
BREAKOUT_MAX_CHASE_PCT=0.22
BREAKOUT_MAX_LATE_VS_REF_PCT=0.55
BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT=0.03
BREAKOUT_RECLAIM_ATR=0.10
BREAKOUT_MAX_DIST_ATR=1.50
BREAKOUT_BUFFER_ATR=0.06
BREAKOUT_ALLOW_SHORTS=1
BREAKOUT_REGIME_STRICT=0

# Keep execution guards intact.
BREAKOUT_MIN_QUOTE_5M_USD=70000
BREAKOUT_MAX_SPREAD_PCT=0.20
