## Local-only cTrader Open API credentials. Keep this file out of git.
## Fill these after the Spotware app is approved.

CTRADER_CLIENT_ID=replace_me
CTRADER_CLIENT_SECRET=replace_me
CTRADER_REDIRECT_URI=http://localhost:8080/callback

## Demo vs live environment.
CTRADER_ENV=demo

## FxPro cTrader demo account details.
CTRADER_ACCOUNT_ID=replace_me
CTRADER_ACCESS_TOKEN=replace_me
CTRADER_REFRESH_TOKEN=replace_me

## Optional runtime toggles for future adapter.
CTRADER_SEND_ORDERS=0
CTRADER_MAX_OPEN_PER_SYMBOL=1
