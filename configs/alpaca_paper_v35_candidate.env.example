ALPACA_API_KEY_ID=replace_me
ALPACA_API_SECRET_KEY=replace_me
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Dry-run first. Flip to 1 only after a few clean monthly cycles.
ALPACA_SEND_ORDERS=0
ALPACA_CLOSE_STALE_POSITIONS=0

# v35 candidate currently wins with TOP_N=3.
ALPACA_MAX_POSITIONS=3
ALPACA_TARGET_ALLOC_PCT=0.30
ALPACA_MIN_DOLLAR_ORDER=50
ALPACA_MAX_PICK_AGE_DAYS=45
ALPACA_ALLOW_STALE_PICKS=0

# Keep the pilot sleeve small at first even if paper buying power is much larger.
ALPACA_CAPITAL_OVERRIDE_USD=500

# Use the v35 monthly refresh/autopilot instead of the old baseline refresh.
ALPACA_AUTOPILOT_REFRESH=1
ALPACA_AUTOPILOT_REFRESH_SCRIPT=scripts/run_equities_monthly_v35_refresh.sh
ALPACA_AUTOPILOT_RUNTIME_DIR=runtime/equities_monthly_v35

# Optional dedicated runtime dir for the v35 candidate.
EQ_V35_RUNTIME_DIR=runtime/equities_monthly_v35

# Keep the first pilot pinned to the validated v35 universe.
# Turn this on only when we explicitly want a broader rotating radar.
EQ_V35_DYNAMIC_UNIVERSE=0
# Example when enabled:
# EQ_V35_DYNAMIC_TOP_K=18
# EQ_V35_DYNAMIC_LOOKBACK_DAYS=80

# Optional advisor/reporting layer.
ALPACA_DEEPSEEK_NOTE_ENABLE=1
ALPACA_DEEPSEEK_NOTE_MAX_CHARS=420
