## Local-only MT5 demo credentials. Keep this file out of git or store as a separate local copy.
MT5_LOGIN=12345678
MT5_PASSWORD=replace_me
MT5_SERVER="YourBroker-Demo"
# Optional path to terminal if auto-discovery does not work.
# MT5_TERMINAL_PATH=/Applications/MetaTrader 5.app/Contents/MacOS/terminal64.exe
# Optional Telegram override. If omitted, launcher will use TG_TOKEN/TG_CHAT from project .env.
# TG_TOKEN=123456:replace_me
# TG_CHAT=123456789

## Operator toggles
FOREX_BRIDGE_SEND_ORDERS=0
FOREX_BRIDGE_MAX_OPEN_PER_PAIR=1
FOREX_BRIDGE_MT5_DEVIATION_POINTS=20
FOREX_BRIDGE_MT5_MAGIC=260308
