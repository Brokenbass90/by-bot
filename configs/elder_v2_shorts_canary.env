# ─────────────────────────────────────────────────────────────
# Elder Triple Screen v2 — SHORTS-ONLY canary deployment config
# WF-22 verdict: 🟢 VIABLE  (AvgPF=1.127, PF>1.0 13/22 windows)
# Validated: 2026-04-15  Risk multiplier: 0.40× live
#
# KEY INSIGHT: Elder v2 works as a confirmed-downtrend SHORT
# strategy. The hist-sign filter (ETS2_TREND_REQUIRE_HIST_SIGN=1)
# blocks shorts when 4h MACD histogram is ABOVE ZERO (bull market),
# preventing shorts into strength. Re-enable longs only after BTC
# establishes a new bull trend above the Dec 2025 high ($108k).
# ─────────────────────────────────────────────────────────────

ENABLE_ELDER_TRADING=1
ELDER_RISK_MULT=0.40

# Symbols: 4 liquid crypto pairs
ETS2_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT

# ── Screen 1: Trend (4h MACD) ────────────────────────────────
ETS2_TREND_TF=240
ETS2_TREND_MODE=macd_hist
ETS2_MACD_FAST=12
ETS2_MACD_SLOW=26
ETS2_MACD_SIGNAL=9
ETS2_TREND_SLOPE_BARS=2

# CRITICAL FILTER: require 4h MACD histogram to be BELOW zero for shorts.
# Without this, Elder shorts into bull markets (hist declining but still positive)
# → high false-signal rate. With this filter: WF-22 AvgPF improves from 0.964→1.127
ETS2_TREND_REQUIRE_HIST_SIGN=1
ETS2_TREND_CONSEC_BARS=1
ETS2_TREND_EMA_GATE=0

# ── Screen 2: Wave (1h Force Index) ──────────────────────────
ETS2_WAVE_TF=60
ETS2_OSC_TYPE=force
ETS2_OSC_PERIOD=2
ETS2_WAVE_LOOKBACK=1

# ── Screen 3: Entry (15m breakout) ───────────────────────────
ETS2_ENTRY_TF=15
ETS2_ENTRY_RETEST_BARS=3
ETS2_ENTRY_MIN_BODY_FRAC=0.30
ETS2_ENTRY_BREAK_ATR_MULT=0.05
ETS2_RISK_TF=60

# ── Exits ─────────────────────────────────────────────────────
ETS2_SL_ATR_MULT=1.5
ETS2_TP1_ATR_MULT=2.0
ETS2_TP_ATR_MULT=3.5
ETS2_TP1_FRAC=0.50
ETS2_TRAIL_ATR_MULT=0.0
ETS2_TRAIL_ACTIVATE_RR=0.0
ETS2_TIME_STOP_BARS_5M=288
ETS2_COOLDOWN_BARS_5M=36
ETS2_MAX_SIGNALS_PER_DAY=6

# ── Direction: SHORTS ONLY ───────────────────────────────────
# Longs re-enable when BTC makes new ATH above Dec 2025 peak ($108k)
# and MACD hist is consistently positive on 4h for 5+ days
ETS2_ALLOW_LONGS=0
ETS2_ALLOW_SHORTS=1

# ─────────────────────────────────────────────────────────────
# WF-22 RESULTS SUMMARY (45-day windows, 22 windows):
#   AvgPF:     1.127
#   PF>1.00:   13/22 (59%)
#   PF>1.15:   9/22  (41%)
#   AvgTrades: 77/window (~1.7/day/symbol)
#
# STRONG windows: Jul-05, Sep-03, Oct-03, Nov-17, Dec-02,
#                 Jan-31, Feb-15, Mar-02, Apr-01
# WEAK windows:   May-Jun 2025 (bull market), Jan 2026 (bounce)
#
# BOTTOM LINE: Deploy at 0.40× live risk. Monitor Jan-Feb windows closely.
# If 2 consecutive losing months → disable and investigate.
# ─────────────────────────────────────────────────────────────
