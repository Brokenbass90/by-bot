# ================================================================
# PRODUCTION SERVER .env — REDACTED EXAMPLE
# Copy real secrets only into:
#   - local repo .env   (gitignored)
#   - server /root/by-bot/.env
# Do NOT keep live credentials in tracked files.
# ================================================================

# ----------------------------------------------------------------
# CREDENTIALS
# ----------------------------------------------------------------
TG_TOKEN=<telegram_bot_token>
TG_CHAT=<telegram_chat_id>
TG_ADMIN_USER_ID=<telegram_admin_user_id>

BYBIT_BASE=https://api.bybit.com
TRADE_ACCOUNT_NAME=main

BYBIT_ACCOUNTS_JSON=<json_with_live_accounts>

# ----------------------------------------------------------------
# CORE TRADING SETTINGS
# ----------------------------------------------------------------
DRY_RUN=false
BYBIT_LEVERAGE=3
RISK_PER_TRADE_PCT=1.0

# ----------------------------------------------------------------
# STRATEGY ON/OFF
# ----------------------------------------------------------------
ENABLE_SLOPED_TRADING=1
ENABLE_FLAT_TRADING=1
ENABLE_BREAKOUT_TRADING=1
ENABLE_MIDTERM_TRADING=1

ENABLE_INPLAY_TRADING=0
ENABLE_RETEST_TRADING=0
ENABLE_RANGE_TRADING=0
ENABLE_PUMP_FADE_TRADING=0
ENABLE_TS132_TRADING=0

# ----------------------------------------------------------------
# SLOPED CHANNEL (ASC1)
# ----------------------------------------------------------------
ASC1_SYMBOL_ALLOWLIST=ATOMUSDT,LINKUSDT,DOTUSDT
ASC1_ALLOW_SHORTS=1
ASC1_ALLOW_LONGS=0
ASC1_SHORT_MIN_REJECT_DEPTH_ATR=0.75
ASC1_SHORT_MAX_NEAR_UPPER_BARS=2
ASC1_SHORT_MIN_RSI=60
ASC1_SHORT_NEAR_UPPER_ATR=0.15
ASC1_CONFIRM_5M_BARS=6
SLOPED_RISK_MULT=0.10
SLOPED_MAX_OPEN_TRADES=1
SLOPED_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# FLAT RESISTANCE FADE (ARF1)
# ----------------------------------------------------------------
ARF1_SYMBOL_ALLOWLIST=LINKUSDT,LTCUSDT,SUIUSDT,DOTUSDT,ADAUSDT,BCHUSDT
FLAT_RISK_MULT=0.10
FLAT_MAX_OPEN_TRADES=1
FLAT_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# INPLAY BREAKOUT
# ----------------------------------------------------------------
BREAKOUT_TOP_N=10
BREAKOUT_TRY_EVERY_SEC=30
BREAKOUT_ALLOW_SHORTS=0

BT_BREAKOUT_QUALITY_ENABLE=1
BT_BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_QUALITY_MIN_SCORE=0.48

BREAKOUT_BUFFER_ATR=0.12
BREAKOUT_IMPULSE_ATR_MULT=1.0
BREAKOUT_MAX_CHASE_PCT=0.11
BREAKOUT_MAX_DIST_ATR=1.4
BREAKOUT_MAX_LATE_VS_REF_PCT=0.35
BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT=0.06
BREAKOUT_RECLAIM_ATR=0.12

# ----------------------------------------------------------------
# ETH MIDTERM PULLBACK
# ----------------------------------------------------------------
MIDTERM_SYMBOLS=BTCUSDT,ETHUSDT

# ----------------------------------------------------------------
# DEEPSEEK AI CONTROLLER
# ----------------------------------------------------------------
DEEPSEEK_ENABLE=1
DEEPSEEK_API_KEY=<deepseek_api_key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SEC=20
DEEPSEEK_DAILY_REQUEST_CAP=80
DEEPSEEK_HISTORY_MAX_MESSAGES=16
DEEPSEEK_SHADOW_ENABLE=1

# ----------------------------------------------------------------
# BREAKDOWN SHORTS ENGINE
# ----------------------------------------------------------------
ENABLE_BREAKDOWN_TRADING=1
BREAKDOWN_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ATOMUSDT,LTCUSDT
BREAKDOWN_ALLOW_LONGS=0
BREAKDOWN_ALLOW_SHORTS=1
BREAKDOWN_REGIME_MODE=off
BREAKDOWN_LOOKBACK_H=48
BREAKDOWN_RR=2.0
BREAKDOWN_SL_ATR=1.8
BREAKDOWN_MAX_DIST_ATR=2.0
BREAKDOWN_RISK_MULT=0.10
BREAKDOWN_MAX_OPEN_TRADES=1
BREAKDOWN_TRY_EVERY_SEC=60

# ----------------------------------------------------------------
# DIAGNOSTICS & MISC
# ----------------------------------------------------------------
STRATEGY_STATS_TG_EVERY_SEC=86400
KILLER_GUARD_LOG_EVERY_SEC=3600
BOUNCE_DEBUG=0
BOUNCE_TG_LOGS=0
