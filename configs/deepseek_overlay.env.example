# Advisory-only DeepSeek overlay for the main Telegram bot.
# Safe default: disabled until API key is provided.

DEEPSEEK_ENABLE=0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SEC=8
DEEPSEEK_HISTORY_MAX_MESSAGES=8
DEEPSEEK_MAX_ANSWER_CHARS=3500
DEEPSEEK_CHAT_STATE_PATH=/tmp/bybot_deepseek_chat.json
DEEPSEEK_AUDIT_LOG_PATH=/tmp/bybot_deepseek_audit.jsonl
DEEPSEEK_APPROVAL_QUEUE_PATH=/tmp/bybot_deepseek_approval_queue.json
DEEPSEEK_DAILY_REQUEST_CAP=60
DEEPSEEK_SHADOW_ENABLE=1
DEEPSEEK_SHADOW_LOG_PATH=/tmp/bybot_deepseek_shadow.json
DEEPSEEK_SHADOW_MAX_ITEMS=200
