## Proven breakout core + tiny-risk ETH-only midterm canary.
ENABLE_INPLAY_TRADING=0
ENABLE_BREAKOUT_TRADING=1
ENABLE_RETEST_TRADING=0
ENABLE_PUMP_FADE_TRADING=0
ENABLE_MIDTERM_TRADING=1
ENABLE_RANGE_TRADING=0

BREAKOUT_TOP_N=16
BREAKOUT_TRY_EVERY_SEC=30
SYMBOL_FILTERS_PATH=/tmp/bybot_symbol_filters.json
SYMBOL_ALLOWLIST=RIVERUSDT,FARTCOINUSDT,HYPEUSDT,OPUSDT,VIRTUALUSDT,AVAXUSDT,DOTUSDT,SNXUSDT,BCHUSDT,ENAUSDT,JTOUSDT,1000PEPEUSDT,ARBUSDT,DOGEUSDT,ADAUSDT,TAOUSDT,ETHUSDT
SYMBOL_DENYLIST=

# Live WS stability: the strategy only trades a narrow universe, so do not
# subscribe to the full 120-symbol Bybit top list on the small server.
TOP_N_BYBIT=60
BYBIT_WS_SHARD_SIZE=30
BYBIT_WS_BATCH_SIZE=5
BYBIT_WS_BATCH_DELAY=2.2
BYBIT_WS_START_STAGGER=2.5
BYBIT_WS_PING_INTERVAL=25
BYBIT_WS_PING_TIMEOUT=75
BYBIT_WS_OPEN_TIMEOUT=75
BYBIT_WS_CLOSE_TIMEOUT=15
BYBIT_WS_RECONNECT_MIN_SEC=8
BYBIT_WS_RECONNECT_MAX_SEC=90
BYBIT_WS_RECONNECT_JITTER_SEC=3.0

RISK_PER_TRADE_PCT=0.5
MAX_POSITIONS=2

# Recovery step 1: soften execution-quality and impulse shape slightly, but
# keep liquidity guard and proven breakout basket unchanged.
BREAKOUT_IMPULSE_ATR_MULT=0.70
BREAKOUT_IMPULSE_BODY_MIN_FRAC=0.35
BREAKOUT_QUALITY_MIN_SCORE=0.48
BREAKOUT_MAX_CHASE_PCT=0.22
BREAKOUT_MAX_LATE_VS_REF_PCT=0.55
BREAKOUT_MIN_PULLBACK_FROM_EXTREME_PCT=0.03
BREAKOUT_RECLAIM_ATR=0.10
BREAKOUT_MAX_DIST_ATR=1.50
BREAKOUT_BUFFER_ATR=0.06
BREAKOUT_ALLOW_SHORTS=1
BREAKOUT_REGIME_STRICT=0
BREAKOUT_MIN_QUOTE_5M_USD=70000
BREAKOUT_MAX_SPREAD_PCT=0.20

MIDTERM_SYMBOLS=ETHUSDT
MTPB_SYMBOL_ALLOWLIST=ETHUSDT
MTPB_LONG_RECLAIM_PCT=0.20
MTPB_LONG_TOUCH_TOL_PCT=0.15
MTPB_LONG_MAX_PULLBACK_PCT=0.75
MIDTERM_NOTIONAL_MULT=0.15
MIDTERM_TRY_EVERY_SEC=120
