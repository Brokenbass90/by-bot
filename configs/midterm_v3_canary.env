## Midterm V3 — canary config for backtesting and live.
## BTC/ETH medium-term pullback with MACD macro filter + RSI + fresh touch logic.
## Strategy: btc_eth_midterm_v3.BTCETHMidtermV3Strategy
##
## Key improvements vs v1:
##  - MACD 4H macro filter: longs only when MACD hist > 0 (bullish macro)
##                          shorts only when MACD hist < 0 (bearish macro)
##  - RSI 1H filter: longs when RSI < 62, shorts when RSI > 38
##  - Fresh touch: touch must be in last 3 bars (not 10 bars ago)
##  - Stricter reclaim: prev_c must be strictly below/above EMA
##  - Per-direction cooldown: long_cooldown and short_cooldown are separate
##  - Regime env vars: MTPB3_ALLOW_LONGS / MTPB3_ALLOW_SHORTS for orchestrator
##
## WF-22 target: AvgPF >= 1.10, PF > 1.0 in 55%+ windows
## Backtest command:
##   python3 backtest/run_portfolio.py \
##     --config configs/midterm_v3_canary.env \
##     --days 365 --end 2026-03-31

ENABLE_MIDTERM_TRADING=1
MTPB_VERSION=3

## Symbol universe — BTC and ETH only (both directions)
MTPB3_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT
MTPB3_ALLOW_LONGS=1
MTPB3_ALLOW_SHORTS=1

## Trend filter (4H EMA50/200)
MTPB3_TREND_EMA_FAST=50
MTPB3_TREND_EMA_SLOW=200
MTPB3_TREND_SLOPE_MIN_PCT=0.40
MTPB3_TREND_MIN_GAP_PCT=0.20
MTPB3_TREND_SLOPE_BARS=10

## MACD 4H macro filter (NEW — most important)
MTPB3_REQUIRE_HIST_SIGN=1
MTPB3_MACD_FAST=12
MTPB3_MACD_SLOW=26
MTPB3_MACD_SIGNAL=9
MTPB3_MACD_CONSEC_BARS=1

## 1H entry signals
MTPB3_SIGNAL_EMA_PERIOD=20
MTPB3_SWING_LOOKBACK_BARS=10
MTPB3_FRESH_TOUCH_BARS=3
MTPB3_LONG_TOUCH_TOL_PCT=0.25
MTPB3_SHORT_TOUCH_TOL_PCT=0.25
MTPB3_LONG_RECLAIM_PCT=0.20
MTPB3_SHORT_RECLAIM_PCT=0.20
MTPB3_LONG_MAX_PULLBACK_PCT=1.00
MTPB3_SHORT_MAX_PULLBACK_PCT=1.00
MTPB3_LONG_MAX_ATR_PCT_1H=2.50
MTPB3_SHORT_MAX_ATR_PCT_1H=2.50

## RSI filter (NEW)
MTPB3_USE_RSI_FILTER=1
MTPB3_RSI_PERIOD=14
MTPB3_RSI_LONG_MAX=62
MTPB3_RSI_SHORT_MIN=38

## Volume confirm (NEW)
MTPB3_USE_VOL_FILTER=1
MTPB3_VOL_PERIOD=20
MTPB3_VOL_MULT=1.20

## Weekly gate (off by default — enable for stricter long filter)
MTPB3_USE_WEEKLY_GATE=0

## Exits — runner exits on, RR=2.5
MTPB3_RR=2.5
MTPB3_SL_ATR_MULT=1.20
MTPB3_SWING_SL_BUFFER_ATR=0.10
MTPB3_USE_RUNNER_EXITS=1
MTPB3_TP1_RR=1.2
MTPB3_TP1_FRAC=0.50
MTPB3_TRAIL_ATR_MULT=1.1
MTPB3_TIME_STOP_BARS_5M=108

## Flow control — per-direction cooldowns (NEW)
MTPB3_LONG_COOLDOWN_BARS=72
MTPB3_SHORT_COOLDOWN_BARS=72
MTPB3_MAX_SIGNALS_PER_DAY=2
MTPB3_EVAL_TF_MIN=15
