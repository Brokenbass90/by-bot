## Regime overlay: bear_trend
## Apply when orchestrator_state.json shows regime=bear_trend
## Activates: breakdown_v2(ON), fade(REDUCED), elder shorts(ON)
## Deactivates: all long strategies

## === BREAKOUT (OFF in bear trend) ===
ENABLE_BREAKOUT_TRADING=0

## === BREAKDOWN v2 — ACTIVE (primary in bear trend) ===
ENABLE_BREAKDOWN_TRADING=1
BREAKDOWN2_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT,ADAUSDT
BREAKDOWN2_REGIME_MODE=ema
BREAKDOWN2_RR=2.0
BREAKDOWN2_SL_ATR=1.5
BREAKDOWN2_LOOKBACK_H=24
BREAKDOWN2_RSI_MAX=52

## === RESISTANCE FADE — REDUCED (still valid but high vol hurts) ===
ENABLE_FLAT_TRADING=1
ARF1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,DOTUSDT
ARF1_TIME_STOP_BARS_5M=288

## === SUPPORT BOUNCE — OFF ===
ENABLE_BOUNCE_TRADING=0

## === MIDTERM — MINIMAL (BTC shorts only) ===
ENABLE_MIDTERM_TRADING=1
MIDTERM_SYMBOLS=BTCUSDT,ETHUSDT

## === SLOPED CHANNEL — SHORTS ONLY ===
## Shorts: must be flat/falling channel (SHORT_MAX_POS_SLOPE_PCT=0.0), high R2.
ENABLE_SLOPED_TRADING=1
ASC1_ALLOW_LONGS=0
ASC1_ALLOW_SHORTS=1
ASC1_SYMBOL_ALLOWLIST=ADAUSDT,LINKUSDT,ATOMUSDT
ASC1_MIN_RANGE_R2=0.55
ASC1_SHORT_MAX_POS_SLOPE_PCT=0.0
ASC1_CONFIRM_5M_BARS=6
ASC1_SHORT_MIN_REJECT_DEPTH_ATR=0.90
ASC1_SHORT_MIN_RSI=62

## === RANGE SCALP — SHORTS ONLY in bear trend ===
ARS1_ALLOW_LONGS=0
ARS1_ALLOW_SHORTS=1

## === ELDER TS v2 — SHORTS only in bear trend ===
ETS2_ALLOW_LONGS=0
ETS2_ALLOW_SHORTS=1

## Strong risk reduction in bear trend
RISK_MULT_OVERRIDE=0.50
