ALPACA_SEND_ORDERS=1
ALPACA_CLOSE_STALE_POSITIONS=1

ALPACA_MAX_POSITIONS=2
ALPACA_TARGET_ALLOC_PCT=0.40
ALPACA_MIN_DOLLAR_ORDER=25
ALPACA_MAX_PICK_AGE_DAYS=45
ALPACA_ALLOW_STALE_PICKS=0
