ALPACA_CAPITAL_OVERRIDE_USD=1000

ALPACA_AUTOPILOT_REFRESH=1
ALPACA_AUTOPILOT_REFRESH_SCRIPT=scripts/run_equities_monthly_v36_refresh.sh
ALPACA_AUTOPILOT_RUNTIME_DIR=runtime/equities_monthly_v36
EQ_V36_RUNTIME_DIR=runtime/equities_monthly_v36
EQ_V36_CURRENT_RELAXED_MIN_MOM_LOOKBACK_PCT=0.0
EQ_V36_CURRENT_RELAXED_PULLBACK_MIN_PCT=-20.0
EQ_V36_CURRENT_RELAXED_PULLBACK_MAX_PCT=1.0
EQ_V36_CURRENT_RELAXED_MAX_PAIR_CORR=0.90
EQ_V36_CURRENT_RELAXED_UNIVERSE_TOP_K=30

ALPACA_DEEPSEEK_NOTE_ENABLE=1
ALPACA_DEEPSEEK_NOTE_MAX_CHARS=420
ALPACA_DEEPSEEK_ADVISORY_ENABLE=1
