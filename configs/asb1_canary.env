# ─────────────────────────────────────────────────────────────
# alt_slope_break_v1 (ASB1) — Trendline Breakdown shorts canary
# WF-22 verdict: 🟢 VIABLE  AvgPF=1.228, PF>1.0: 13/22 (59%)
# Validated: 2026-04-15  Risk multiplier: 0.50× (new strategy)
#
# STRATEGY: Find ascending support trendlines (higher lows on 1h).
# Enter SHORT when price breaks BELOW with a strong impulsive candle.
# The broken support becomes new resistance for SL placement.
#
# MACRO FILTER (critical): Only short when 4h MACD histogram < 0.
# This blocks shorts in bull markets (Nov-Dec 2025: histogram positive,
# shorts fail badly). Naturally fires in confirmed downtrends.
#
# COMPLEMENT TO ATT1: ATT1 bounces off trendlines (touch → rejection).
# ASB1 trades the FAILURE of the trendline (breakdown with impulse).
# Together they cover both scenarios on the same trendline structure.
# ─────────────────────────────────────────────────────────────

ENABLE_ASB1_TRADING=1
ASB1_RISK_MULT=0.50

# Symbols
ASB1_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,LINKUSDT

# ── Signal timeframe (1h) ─────────────────────────────────────
ASB1_SIGNAL_TF=60
ASB1_SIGNAL_LOOKBACK=120

# ── Pivot detection ───────────────────────────────────────────
ASB1_PIVOT_LEFT=3
ASB1_PIVOT_RIGHT=3
ASB1_MIN_PIVOTS=2
ASB1_MAX_PIVOT_AGE=20

# ── Trendline quality ─────────────────────────────────────────
ASB1_MIN_SLOPE_PCT=0.05
ASB1_MAX_SLOPE_PCT=5.0
ASB1_MIN_R2=0.70

# ── Breakout entry confirmation ───────────────────────────────
ASB1_BREAK_ATR=0.30
ASB1_MIN_BODY_FRAC=0.40
ASB1_RSI_SHORT_MAX=65.0
ASB1_RSI_LONG_MIN=35.0

# ── CRITICAL: Macro bearish filter ───────────────────────────
# Only short when 4h MACD histogram is NEGATIVE (below zero line).
# Proof from WF-22: without this filter AvgPF=0.949 (WEAK).
# With this filter: AvgPF=1.228 (VIABLE).
ASB1_MACRO_TF=240
ASB1_MACRO_REQUIRE_BEARISH=1
ASB1_MACRO_REQUIRE_BULLISH=0
ASB1_MACRO_MACD_FAST=12
ASB1_MACRO_MACD_SLOW=26
ASB1_MACRO_MACD_SIGNAL=9

# ── Exits ─────────────────────────────────────────────────────
ASB1_SL_ATR_MULT=0.80
ASB1_TP1_RR=1.5
ASB1_TP2_RR=3.0
ASB1_TP1_FRAC=0.50
ASB1_BE_TRIGGER_RR=1.00
ASB1_BE_LOCK_RR=0.02
ASB1_TIME_STOP_BARS_5M=576
ASB1_COOLDOWN_BARS_5M=72

# ── Direction ─────────────────────────────────────────────────
ASB1_ALLOW_LONGS=0
ASB1_ALLOW_SHORTS=1

# ─────────────────────────────────────────────────────────────
# WF-22 SUMMARY (macro_mid config, 22 × 45-day windows):
#   AvgPF:     1.228
#   PF>1.00:   13/22 (59%)
#   PF>1.15:   10/22 (45%)
#   AvgTrades: ~19/window
#
# STRONG windows: Jun-20, Aug-04/19, Sep-03, Nov-02/17,
#                 Jan-01, Jan-31, Feb-15, Apr-01
# WEAK windows:   Jul-20, Oct-03, Jan-16, Mar-02/17 (low trade count)
#
# COMPLEMENT TO PORTFOLIO:
#   ATT1: trendline bounce (both directions)  — WF AvgPF=1.35
#   Elder: MACD momentum shorts              — WF AvgPF=1.127
#   ASB1:  trendline breakdown shorts        — WF AvgPF=1.228
# All three fire on DIFFERENT signal types → low correlation
# ─────────────────────────────────────────────────────────────
